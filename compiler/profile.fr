
ENABLE_TRACY :: Foreign.ENV.FRANCA_TRACY.get_environment_variable().is_some();
USE_MY_ZONE_VIEWER :: str(Foreign.ENV.FRANCA_TRACY.get_environment_variable() || "") == "z";

TraceCtx :: @if(ENABLE_TRACY, TracyZoneContext, void);

TraceZone :: @enum(i64) (EmitIr, AotPump, Backend, Scope, LoadFile, Parse, SemaFunction, SemaOverloads, Task, CallDynamic, BakeConstArgs, Wait, CloneExpr, CheckCache, ImportCache);
// TODO: can't index by pointer a const array
ZONE_COLOURS :: @static @array(0x00FF0066, 0x00FF0000, 0x00FF6600, 0x0000FF00, 0x000000FF, 0x000000FF, 
    0x00FF00FF, 0x00EE00AA, 0x00AAFFAA, 0x00888800, 0x00AA0099, 0x00000001, 0x0000FF44, 0x000055FF, import_cache_colour);

import_cache_colour :: 0x335533FF;
// TODO: caller location
fn zone_begin(zone: TraceZone) TraceCtx = {
    @if(!ENABLE_TRACY) return();
        src :: {
            n := ast_alloc().alloc_zeroed(TracySourceLocation, enum_count(TraceZone));
            for_enum TraceZone { e |
                n[@as(i64) e] = (
                    name = e.name_str().sym().c_str(),
                    function = "",
                    file = "",
                    line = 0, 
                    color = ZONE_COLOURS.items()[e.raw()],
                );
            };
            n
        };
        ZONE_COLOURS;
        s := src.index(@as(i64) zone);
        ___tracy_emit_zone_begin(s, 1)
};

fn zone_end(c: TraceCtx) void = {
    @if(ENABLE_TRACY, ___tracy_emit_zone_end(c), ());
}

//! https://github.com/wolfpld/tracy/blob/master/public/tracy/TracyC.h

TracySourceLocation :: @struct(
    name: CStr, // ?
    function: CStr,
    file: CStr,
    line: u32,
    color: u32,
);

TracyZoneContext :: @struct(
    id: u32,
    active: i32,
);

init_zone_tracing :: @if(USE_MY_ZONE_VIEWER, fn() void #inline = {
    self := zone_information;
    @debug_assert_eq(self.start, 0, "called init_zone_tracing twice");
    self.arena = init(general_allocator(), page_size());
    self.zones = init(10, self.arena&.borrow());
    self.start = timestamp_s();

ZoneInfo :: @struct {
    loc: TracySourceLocation;
    start: f32;
    end: f32;
    tid: u16;
    name_length: u16 = 0;
};
Zones :: @struct {
    arena: Arena.Allocator;
    zones: BucketArray(ZoneInfo);
    mutex: import("@/lib/sys/sync/mutex.fr").Mutex;
    // offset before casting to f32 gets you more precision by being closer to zero. 
    // ex. timestamp_s = 2553986 ~= 2^21 means 250ms gap between adjacent floats 
    //     (if dear wikipedia is right about (2^n .. 2^(n+1)) -> spacing = 2^(n-23))
    start: f64;  
};
zone_information :: @static_mut @zeroed Zones;

fn get(self: *Zones, id: TracyZoneContext) *ZoneInfo = {
    self.zones&.nested_index(id.id.zext())
}

// TODO: mach_abosolute_time isn't super fast (~2% of compiling examples/gpu/terminal when this is enabled). 
//       there are the magic instructions (CNTVCT_EL0 / rdtsc), but i fear you have to do something extra to keep in sync if you swapped cores? idk
fn new(self: *Zones, it: *TracySourceLocation) TracyZoneContext = {
    self.mutex&.lock();
    // not copying name,function,file. for my usage: name lives forever and function/file are empty. 
    self.zones&.push(loc = it[], start = timestamp_s().sub(self.start).cast(), end = -1, tid = tls(.thread_index)[].trunc());
    id: u32 = self.zones&.len().trunc() - 1;
    self.mutex&.unlock();
    (id = id, active = 1)
}

fn ___tracy_emit_zone_begin(srcloc: *TracySourceLocation, _: i32) TracyZoneContext = 
    zone_information.new(srcloc);
fn ___tracy_emit_zone_name(ctx: TracyZoneContext, txt: []u8) void = {
    self := zone_information;
    with self.mutex& {
        it := self.get(ctx);
        txt.len = min(txt.len, 0xFFFF);
        it.loc.name = txt.alloc_cstr(self.arena&.borrow());
        it.name_length = txt.len.trunc();
    };
}
fn ___tracy_emit_zone_color(ctx: TracyZoneContext, color: u32) void = {
    zone_information.get(ctx)[].loc.color = color;
}
fn ___tracy_emit_zone_end(ctx: TracyZoneContext) void = {
    self := zone_information;
    self.get(ctx)[].end = timestamp_s().sub(self.start).cast();
}
fn finish_zone_tracing() void = {  // TODO: won't be called if child program exits.
    @debug_assert(ENABLE_TRACY);
    self := zone_information;
    self.mutex&.lock();
    
    out := @ref u8.list(self.zones&.len() * 50, self.arena&.borrow());
    out.reserve_type(ZoneFile)[] = (
        zone_count = self.zones&.len(),
        byte_count = -1, // patched
    );
    each self.zones& { it |
        // TODO: super inefficient, default named zone strings duplicated many times. 
        if it.name_length == 0 {
            it.name_length = it.loc.name.str().len().trunc();
        };
        name := it.loc.name.ptr.slice(it.name_length.zext());
        out.reserve_type(ZoneFile.Entry)[] = (
            start = it.start, 
            end = it.end, 
            colour = it.loc.color, 
            tid = it.tid, 
            name_length = name.len.trunc(),
        );
        out.push_all(name);  
        @debug_assert_ge(it.end, it.start, "unfinished zone");
    };
    bit_cast_unchecked(*u8, *ZoneFile, out.as_ptr())[].byte_count = out.len;
    
    write_entire_file_or_crash(ZoneFile.PATH, out.items());
    self.arena&.deinit();
    self[] = @zeroed Zones;
}

// FRANCA_TRACY=z franca examples/default_driver.fr build compiler/main.fr -o trace.out
// ./trace.out a.fr
// franca examples/gpu/zones.fr -jit
}, fn() void #inline = {

fn ___tracy_emit_zone_begin(srcloc: *TracySourceLocation, active: i32) TracyZoneContext #import("tracy");
// Note: these rely on the abi of slices being the same as seperate ptr/len arguments
fn ___tracy_emit_zone_name(ctx: TracyZoneContext, txt: []u8) void = {
    ___tracy_emit_zone_name :: fn(ctx: TracyZoneContext, txt: []u8) void #import("tracy");
    // assertion: (size < std::numeric_limits<uint16_t>::max()), file TracyProfiler.cpp
    txt.len = min(txt.len, 1.shift_left(16) - 2);  
    ___tracy_emit_zone_name(ctx, txt)
}
fn ___tracy_emit_zone_color(ctx: TracyZoneContext, color: u32) void #import("tracy");
fn ___tracy_emit_zone_end(ctx: TracyZoneContext) void #import("tracy");
fn finish_zone_tracing() void = ();

// /Users/luke/Downloads/tracy-master/profiler/cmake-build-release/tracy-profiler
// FRANCA_TRACY=true franca examples/default_driver.fr build compiler/main.fr -o trace.out
// ./trace.out a.fr
});

// this is the format that examples/gpu/zones.fr can read. 
// output to PATH when USE_MY_ZONE_VIEWER=true
ZoneFile :: @struct {
    MAGIC :: "FR\x00\x01ZONE".peek_type(i64)[];
    PATH :: "target/zones.g.out";
    magic: i64 = MAGIC;
    byte_count: i64;  // including header and entry data
    zone_count: i64;
    // zones: []Entry #inline;
    Entry :: @struct {
        start: f32;
        end: f32;
        colour: u32;
        tid: u16;
        name_length: u16;
        // name: []u8 #inline;  // TODO: wasteful. u32 offset to string pool after would be better
    };
};
