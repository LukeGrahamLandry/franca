//
// UNSAFE
//  the Memo data structure uses copying garbage collection, 
//  you can't hold a *Node or NodeId without laundering it 
//  through gc_roots across any call to gc_reserve. 
//

do_life :: fn(w: i64, h: i64, $P: @Fn(x: i64, y: i64) u32 #duplicated, $yield: @Fn(x: i64, y: i64, value: bool) void) void = {
    range(0, h) { y |
        range(0, w) { x |
            n := P(x-1,y+1)+P(x,y+1)+P(x+1,y+1)
                +P(x-1,y+0)         +P(x+1,y+0)
                +P(x-1,y-1)+P(x,y-1)+P(x+1,y-1);
            live := P(x, y) == 1;
            new := (live && (n == 2 || n == 3)) || (!live && n == 3);
            yield(x, y, new);
        };
    };
}

// the most important thing is that the Node doesn't know its position in the grid so it can be reused. 
Node :: @rec @struct {
    children: Array(NodeId, 4);
    next := zeroed(NodeId);  // memoized eval_center()
    population: u32 = 0;
    next_fast := false;  // :SLOW 1 bit costs 4 bytes (but when i want to allow more different speeds, this will need more bits)
};

// index in memo.active_buf.
// id=0 is reserved so zeroed(Array(NodeId)) still works as uninit when being filled in a loop.
// id=0 is also is also used for children[0,1] of base nodes ([2,3] have bit set of cells).  
// since arrays are filled in order, collect_garbage can stop on 0 in a gc_root and not treat the base bits as indices. 
NodeId :: @struct(id: u32);  

base_case_w :i32: 0x00000002;  // TODO: profile different sizes: 2/4/8
Memo :: @struct {
    active_buf: *RawList(Node);  // memo.buf&[buf_i]&... can't hurt
    table: []NodeId;  // hash table with masked node.hash() (the flat/linear probing kind not the linked list buckets kind)
    buf: Array(RawList(Node), 2);
    buf_i: i64;
    root: NodeId;
    size: i32;
    // these addresses (not ids) must be unique so collect_garbage doesn't try to process an id that's already been moved. 
    gc_roots: List([]NodeId);
    // parallel to buf but only need one side at a time and only while running collect_garbage so don't waste locality of buf when doing actual work. 
    gc_forward: []NodeId;  
    a: Alloc;
    empty_node_cache: Array(NodeId, 64);  // weak
};

new_memo :: fn(self: *Memo, a: Alloc) void = {
    self[] = zeroed(Memo);
    n := 25;
    self.buf&[0] = init(a, 1.shift_left(n));
    self.active_buf = self.buf&[0]&;
    self.gc_forward = a.alloc_uninit(NodeId, self.buf&[0].cap);
    self.table = a.alloc_zeroed(NodeId, 1.shift_left(n + 2));
    @eprintln("buf=%mb x2; table=%mb", self.buf&[0].cap * size_of(Node) / 1024 / 1024, self.table.len * size_of(NodeId) / 1024 / 1024);
    self.gc_roots = list(1, a);
    self.gc_roots&.push(self.root&.slice(1));
    self.a = a;
    self.buf&[0]&.push(junk_node, panicking_allocator);
}

fn drop(memo: *Memo) void = {
    a := memo.a;
    for memo.buf& { it | drop(it&, a); };
    a.dealloc(NodeId, memo.table);
    a.dealloc(NodeId, memo.gc_forward);
    memo.gc_roots&.drop();
}

fn hash(node: *Node) i64 #inline = {
    hash: u64 = 0;
    for node.children& { it |
        hash = hash.bit_xor(it.id.zext().bitcast()) + 1;
        hash *= 15120273018600372767;
    };
    hash.bitcast()
}

fn get(memo: *Memo, node: NodeId) *Node #inline = {
    @debug_assert(node.id != 0, "get null node");
    memo.active_buf.index(node.id.zext())
}

fn push(self: *Memo, node: Node) NodeId = {
    @run @assert(base_case_w*base_case_w <= 64 && base_case_w.up_pow2() == base_case_w);
    mask := self.table.len - 1;
    i := node&.hash().bit_and(mask);
    j := 0;    
    loop {
        n := self.table[i]&;
        @debug_assert(j != self.table.len);
        if n.id == 0 {
            buf := self.active_buf;
            @if(node.children&[0].id != 0) for node.children& { it |
                node.population += self.get(it)[].population;
            };
            buf.push_assume_capacity(node);
            n[] = (id = buf.len.trunc() - 1);
            
            return n[];
        };
        
        it := self.get(n[]);
        a, b := (it.children&, node.children&);
        if a[0].id == b[0].id
        && a[1].id == b[1].id
        && a[2].id == b[2].id
        && a[3].id == b[3].id
        {
            return n[];
        };
        i = (i + 1).bit_and(mask);
        j += 1;
    };
}

// UNSAFE: node must be unique
fn gc_table_insert(self: *Memo, nid: NodeId, node: *Node) void = {
  mask := self.table.len - 1;
  i := node.hash().bit_and(mask);
  j := 0;    
  loop {
      n := self.table[i]&;
      @debug_assert(j != self.table.len);
      if n.id == 0 {
          n[] = nid;
          return();
      };
      i = (i + 1).bit_and(mask);
      j += 1;
  };
}

fn zero_fill_grow_root(memo: *Memo) NodeId = {
    // an extra level of quadtree where the old root node is just surrounded by dead cells. 
    // ex. top left of old root becomes bottom right of the new root's top left node. children are clockwise.
    size := memo.size;
    invert :: @const_slice(2, 3, 0, 1);
    memo.gc_reserve(size.trailing_zeros() + 5);
    empty := memo.empty_node(size/2);  // :SLOW
    children := zeroed Array(NodeId, 4);
    root := memo.get(memo.root)[].children&;
    @debug_assert(root[0].id != 0, "TODO: allow zero_fill_grow_root when only two layers");
    range(0, 4) { i |
        n: Node = (children = (empty,empty,empty,empty));
        n.children&[invert[i]] = root[i];
        children&[i] = memo.push(n);
    };
    memo.push(children = children)
}

fn eval(memo: *Memo, fast: bool) void = {
    wrapped_root := memo.zero_fill_grow_root();
    size := memo.size;
    root_one(memo, wrapped_root) { wrapped_root |
        memo.gc_roots&.reserve((size*2).trailing_zeros().zext() * 2);
        memo.root = eval_center(memo, wrapped_root, size*2, fast);
    };
}

// the grinch's heart shrank to half sizes that day
// UNSAFE: `node` must be rooted and gc_roots must have reserved enough capacity for all the levels of recursion
fn eval_center(memo: *Memo, n: *NodeId, size: i32, fast: bool) NodeId = {
    node := memo.get(n[]);
    @debug_assert(node.children&[0].id != 0, "eval_center too low");
    if node.next.id != 0 && node.next_fast == fast {
        return node.next;
    };
    ::if(NodeId);
    new := if size == base_case_w * 2 {
        center_base_case(memo, n)
    } else {
        eval_center_split_merge(memo, n, size, fast)
    };
    node := memo.get(n[]);
    node.next = new;
    node.next_fast = fast;
    new
};

// from one node, can eval a centered node with half side length. 
// to eval the whole node, need to eval from parents, multiple smaller squares. 
// to cover the whole node, need to reorganize children 
// (into new nodes that aren't aligned to the original quad tree). 
// UNSAFE: `node` must be rooted
fn eval_center_split_merge(memo: *Memo, node: *NodeId, size: i32, fast: bool) NodeId = {
    // children are clickwise starting at top left (but grandchildren are sorta a spiral)
    N :: fn(T: Type) #fold = size_of(Deref(T))/size_of(NodeId);
    grandchildren :: fn(children: ~T) *Array(NodeId, N(T)*4) #inline/*semantic*/ #where => {
        n := @ref @zeroed Array(NodeId, N(T)*4);
        enumerate children { i, node |
            node := memo.get(node[]);
            enumerate node.children& { j, it |
                n[i*4 + j] = it[];
            };
        };
        n
    };
    // you have to draw the picture to think about where the a,b,c,d numbers come from
    // https://lukegrahamlandry.ca/assets/hashlife.jpg
    join :: fn(n,a,b,c,d) => memo.push(children = (n[a], n[b], n[c], n[d]));
    
    memo.gc_reserve(5);
    node := memo.get(node[]);
    n1 := grandchildren(node.children&);
    
    // right to left, top to bottom
    n2 := @ref @as(Array(NodeId, 9)) (
        node.children&[0],
        n1.join(1,4,7,2),        // up
        node.children&[1],
        n1.join(3,2,13,12),      // left
        n1.join(2,7,8,13),       // center
        n1.join(7,6,9,8),        // right
        node.children&[3],
        n1.join(13,8,11,14),     // down
        node.children&[2],
    );
    n1 := ();  // not rooted
    
    size /= 2;
    pin_for_eval :: fn(in, n: i32, $eval: @Fn(*NodeId) NodeId) => {
        out := @ref @zeroed (Array(NodeId, size_of(@type in[])/size_of(NodeId)));
        memo.gc_roots&.push_assume_capacity(out.items());
        memo.gc_roots&.push_assume_capacity(in.items());
        range(0, in.len()) { i |
            out[i] = eval(in[i]&);
        };
        memo.gc_reserve(n);
        memo.gc_roots.len -= 2;
        out
    };
    eval_centers :: fn(in, n: i32) => pin_for_eval(in, n, fn(node) => 
        eval_center(memo, node, size, fast));
    
    n3 := eval_centers(n2, 5);
    
    if !fast && size != base_case_w * 2 {
        n6 := grandchildren(n3);
        n7 := @ref @as(Array(NodeId, 4)) (  // clockwise
            n6.join( 2, 7,16,13), // 0,0
            n6.join( 6,11,20,17), // 1,0
            n6.join(18,23,32,29), // 1,1
            n6.join(14,19,28,25), // 1,0
        );
        return memo.push(children = n7[]);
    };
    
    n4 := @ref @as(Array(NodeId, 4)) (  // clockwise
        n3.join(0,1,4,3), // 0,0
        n3.join(1,2,5,4), // 1,0
        n3.join(4,5,8,7), // 1,1
        n3.join(3,4,7,6), // 1,0
    );
    
    if !fast {  
        // grandchildren are base nodes so can't just rearrange pointers, need to mix the bit sets in _.hash.
        n8 := pin_for_eval(n4, 1, fn(node: *NodeId) NodeId => 
            get_center_base_case_no_eval(memo, node));
        return memo.push(children = n8[]);
    };
    
    // when fast=true: eval_centers twice per recursion so skip 2^depth generations. 
    n5 := eval_centers(n4, 1);
    memo.push(children = n5[])
};

// need to be able to access neighbours so stop one level before base case size. output is one whole base level. 
fn center_base_case(memo: *Memo, node: *NodeId) NodeId = {
    build_center_base_node(memo, node) { h |
        do_life(base_case_w, base_case_w, fn(x, y) => {
            get_bit_from_base_children(memo, node, x, y).int().trunc()
        }, fn(x, y, value) => {
            set_base_bit(h, x, y, value);
        });
    }
}

fn get_center_base_case_no_eval(memo: *Memo, node: *NodeId) NodeId = {
    build_center_base_node(memo, node) { h |
        range(0, base_case_w) { y |
            range(0, base_case_w) { x |
                value := get_bit_from_base_children(memo, node, x, y);
                set_base_bit(h, x, y, value);
            };
        };
    }
}

// UNSAFE: `node` must be rooted
fn build_center_base_node(memo: *Memo, node: *NodeId, $body: @Fn(h: *u64) void) NodeId = {
    size := base_case_w * 2;
    memo.gc_reserve(size*size + 1);
    new: u64 = 0;
    body(new&);
    memo.base_node(new)
}

// :SLOW feels like maybe there'd be a more elegant bitwise way to do this.
//
// node.children are base nodes (grandchildren(node)=null). 
// x,y is in coordinate system of (the center square of node). 
// info about that center square is split between the bit set in each node.children.hash, 
// so need to dispatch to the right child based on which quadrent of the center x,y is in. 
get_bit_from_base_children :: fn(memo: *Memo, node: *NodeId, x: i64, y: i64) bool = {
    node := memo.get(node[]);
    @debug_assert(node.children&[0].id != 0);
    size := base_case_w * 2;
    size := v2(size);
    base := size / 4;  // corner of output square in node's coordinates
    quad_size := size/2;
    parent_local_pos := base + v2(x, y);
    enumerate direction { child_i, dir |
        top_left := dir[] * quad_size;
        bottom_right := top_left + quad_size;
        if hit_square(parent_local_pos, top_left, bottom_right) {
            child_local_pos := parent_local_pos - top_left;
            xx, yy := child_local_pos.int();
            child := memo.get(node.children&[child_i]);
            i := yy*base_case_w+xx;
            value := child.base_children().shift_right_logical(i).bit_and(1) == 1;
            return value;
        }
    };
    panic("no hits");
}

set_base_bit :: fn(h: *u64, x: i64, y: i64, value: bool) void = {
    i := y*base_case_w+x;
    h[] = h[].bit_or(value.int().shift_left(i).bitcast());
}

hit_square :: fn(pos: V2, top_left: V2, bottom_right: V2) bool = 
    pos.x >= top_left.x && pos.y >= top_left.y && pos.x < bottom_right.x && pos.y < bottom_right.y;

fn base_node(memo: *Memo, bits: u64) NodeId = {
    node := zeroed Node;
    node.children&[2] = (id = bits.bitcast().trunc());
    if base_case_w == 8 {
        node.children&[3] = (id = bits.shift_right_logical(32).bitcast().trunc());
    };
    node.population = bits.count_ones();
    memo.push(node)
}

fn empty_node(memo: *Memo, size: i32) NodeId = {
    @debug_assert(size.count_ones().zext() == 1, "empty_node non power of two");
    slot := memo.empty_node_cache&[size.trailing_zeros().zext()]&;
    if slot.id == 0 {
        slot[] = empty_node_cold(memo, size);
    };
    slot[]
}

fn empty_node_cold(memo: *Memo, size: i32) NodeId = {
    memo.gc_reserve(size.trailing_zeros());
    s, n := (base_case_w, memo.base_node(0));
    while => s < size {
        n = memo.push(children = (n,n,n,n));
        s *= 2;
    };
    n
}

// moves any live (reachable from gc_roots) nodes to the other memo.buf and updates references. 
// id=0 is a valid value in gc_roots: (childen of base node) or (partial array being filled in a loop). 
fn collect_garbage(memo: *Memo) void = {
    memo.empty_node_cache&.items().set_zeroed();
    new_buf_i := memo.buf_i.bit_xor(1);
    to_space, from_space := (memo.buf&[new_buf_i]&, memo.buf&[memo.buf_i]&);
    @debug_assert_eq(to_space.len, 0);
    if to_space.cap < from_space.cap {
        to_space.reserve(from_space.cap, memo.a);
    };
    to_space.push(junk_node, panicking_allocator);
    memo.gc_forward.slice(0, from_space.len).set_zeroed();
    memo.table.set_zeroed();
    enumerate memo.gc_roots& { i, it |
        @debug_assert(!from_space.items().interpret_as_bytes().contains_address(bit_cast_unchecked(*NodeId, *u8, it.ptr)), "interned node child as root is redundant (and will get indices confused)");
        @debug_assert(!memo.gc_roots&.items().slice(0, i).contains(fn(jt) => it[].contains_address(jt.ptr) || jt[].contains_address(it.ptr)), "non unique gc_root (will get indices confused)");
        recur(memo, it[], to_space);
    };
    recur :: fn(memo: *Memo, it: []NodeId, to_space: *RawList(Node)) void = {
        each it { it |
            @if(it.id == 0) return(); // the rest are 0 or base node cells
            
            forward := memo.gc_forward[it.id.zext()]&;
            if forward.id != 0 {
                it[] = forward[];
            } else {
                node := memo.get(it[]);  // from_space
                i := to_space.len;
                to_space.push_assume_capacity(node[]);
                node := to_space[i]&;
                forward[] = (id = i.trunc());
                it[] = forward[];
                recur(memo, node.children&.items(), to_space);
                memo.gc_table_insert(it[], node);
                recur(memo, node.next&.slice(1), to_space);
            };
        };
    };
    @debug_assert_le(to_space.len, from_space.len);
    @eprintln("GC: % -> %", from_space.len, to_space.len);
    from_space.clear();
    memo.buf_i = new_buf_i;
    memo.active_buf = to_space;
}

fn gc_reserve(memo: *Memo, n: i32) void #inline = {
    n := n.zext();
    b := memo.active_buf;
    @if(b.len + n <= b.cap) return();
    memo.collect_garbage();
    b := memo.active_buf;
    // TODO: resize. annoying thing is there might technically never too big a live set but you're slow because keep doing redundant work by clearing the cache. 
    //                    plus have to resize and rehash the table.
    @debug_assert(b.len + n <= b.cap, "too many live nodes");
}

fn root_one(memo: *Memo, node: NodeId, $body: @Fn(node: *NodeId) void) void = {
    root_count := memo.gc_roots.len;
    node := @ref node;
    memo.gc_roots&.push(node.slice(1));
    body(node);
    memo.gc_roots&.pop().unwrap();
    @debug_assert_eq(root_count, memo.gc_roots.len);
}

fn compress(flat: *BitBoard, memo: *Memo) void = {  // frame -> memo
    positions := collect_positions(flat);
    memo.gc_roots&.reserve(flat.size.trailing_zeros().zext());
    memo.root = zeroed(NodeId);  // allow gc-ing the old one
    memo.root = recur(memo, positions, flat.size, v2(0));
    memo.size = flat.size;
    recur :: fn(memo: *Memo, p: []V2, size: i32, node_pos: V2) NodeId = {
        @if(p.len == 0) return(memo.empty_node(size));
    
        if size == base_case_w {
            h: u64 = 0;
            for p { pos |
                x, y := (pos - node_pos).int();
                set_base_bit(h&, x, y, true);
            };
            memo.gc_reserve(1);
            return memo.base_node(h);
        };
        
        size /= 2;
        p := partition(p, node_pos + v2(size));
        
        c := @ref @zeroed Array(NodeId, 4);
        memo.gc_roots&.push_assume_capacity(c.items());
        range(0, 4) { i |
            pos := node_pos + direction[i]*size;
            c[i] = recur(memo, p&[i], size, pos);
        };
        memo.gc_reserve(1);
        memo.gc_roots.len -= 1;
        memo.push(children = c[])
    };
    
    collect_positions :: fn(flat: *BitBoard) []V2 = {
        p := V2.list(zext(flat.size*flat.size/150), temp());
        bits := i64.reinterpret_bytes(flat.bits.interpret_as_bytes());
        import("@/lib/collections/bit_set.fr")'for_bits(bits) { i |
            y, x := i.udiv_mod(flat.size.zext());
            p&.push(v2(x, y));
        };
        p.items()
    };
    
    partition :: fn(p: []V2, middle: V2) Array([]V2, 4) = {
        split :: fn(p, $cond) => {
            n := Sort'partition_unordered(V2, p, cond);
            (p.slice(0, n), p.rest(n))
        };
        left, right := split(p, fn(it) => it.x < middle.x);
        ul, dl := split(left, fn(it) => it.y < middle.y);
        ur, dr := split(right, fn(it) => it.y < middle.y);
        (ul, ur, dr, dl)  // clockwise
    };
}

fn decompress(flat: *BitBoard, memo: *Memo) void = {  // memo -> frame
    decompress_recur(@ref @as(Decomp) (
        flat = flat, memo = memo,
        view_start = v2(0), 
        view_end = v2(memo.size),
        pixels_per_cell = 1,
    ), memo.root, v2(0), memo.size);
}

Decomp :: @struct {
    flat: *BitBoard;
    memo: *Memo;
    view_start: V2; 
    view_end: V2;
    pixels_per_cell: f32;
};

decompress_recur :: fn(self: *Decomp, node: NodeId, pos: V2, size: i32) void = {
        node := self.memo.get(node);
        @if(node.population == 0) return();
        
        v0, v1, n0, n1 := (self.view_start, self.view_end, pos, pos + v2(size));
        no_overlap := v0.x > n1.x || n0.x > v1.x || v0.y > n1.y || n0.y > v1.y;
        if no_overlap {
            return();
        };
        
        node_pixels := size.zext().float().cast() * self.pixels_per_cell;
        
        if size == base_case_w || node_pixels/2 < 1 {
            @debug_assert(size != base_case_w || node.children&[0].id == 0, "decompress void_node child at wrong depth");
            s := self.flat.size.zext().float().cast();
            start := ((pos - self.view_start).float() * vec2(self.pixels_per_cell));
            end := start + vec2(node_pixels);
            start := v2 clamp(start, vec2(0), vec2(s));
            end := v2 clamp(end, vec2(0), vec2(s));
            range(start.y.zext(), end.y.zext()) { y |
                range(start.x.zext(), end.x.zext()) { x |
                    if size == base_case_w {
                        // note: if screen size is a power of two, pixels_per_cell is always 1.0 or 0.5 here
                        cell := v2((v2(x, y) - start).float() / self.pixels_per_cell);
                        cx, cy := cell.int();
                        j := cy*base_case_w + cx;
                        value := node.base_children().bit_and(1.shift_left(j)) != 0;
                        if value {
                            self.flat.set(x, y, true);
                        };
                    } else {
                        self.flat.set(x, y, node.population != 0);
                    };
                };
            };
            return();
        };
        
        
        
        
        @debug_assert(node.children&[0].id != 0);
        size /= 2;
        enumerate node.children& { i, it |
            self.decompress_recur(it[], pos + direction[i] * size, size);
        };
};

fn base_children(node: *Node) u64 = {
    @debug_assert(node.children&[0].id == 0);
    a: u64 = node.children&[2].id.zext().bitcast();
    b: u64 = @if(base_case_w == 8, node.children&[3].id.zext().bitcast(), 0);
    a.bit_or(b.shift_left(32))
}

direction :: @const_slice(v2(0), v2(1, 0), v2(1, 1), v2(0, 1));

BitGame :: @struct(boards: Array(BitBoard, 2), parity: bool);

empty_bit_game :: fn(a: Alloc, w: i32) BitGame = 
    (boards = (empty_bitboard(a, w), empty_bitboard(a, w)), parity = false); 
fn get(self: *BitGame) *BitBoard = 
    self.boards&[self.parity.int()]&;
fn drop(self: *BitGame, a: Alloc) void = 
    for self.boards& { it | a.dealloc(u32, it.bits); it.bits.len = 0; };

fn eval(self: *BitGame) void = {
    eval(self.boards&[self.parity.not().int()]&, self.get());
    self.parity = !self.parity;
}

BitBoard :: @struct(bits: []u32, size: i32);

empty_bitboard :: fn(a: Alloc, w: i32) BitBoard = 
    (bits = a.alloc_zeroed(u32, zext(w*w)/32), size = w);

fn get(it: *BitBoard, x: i32, y: i32) u32 = {
    I := y * it.size + x;
    s, i := I.udiv_mod(32);
    it.bits[s].shift_right_logical(i).bit_and(1)
}

fn set(it: *BitBoard, x: i64, y: i64, new: bool) void = {
    I := y * it.size.zext() + x;
    s, i := I.udiv_mod(32);
    slot := it.bits[s]&;
    slot[] = slot[]
        .bit_and(1.shift_left(i).bit_not())
        .bit_or(int(new).trunc().shift_left(i));
}

fn eval(new: *BitBoard, old: *BitBoard) void = {
    w := old.size;
    do_life(w, w, P, fn(x, y, val) => new.set(x, y, val));
    P :: fn(x: i64, y: i64) u32 => {
        oob := x < 0 || y < 0 || x >= w || y >= w;
        @if(oob, 0, old.get(x, y))
    };
}

junk_node: Node : (children=((id=0xFFFFFFFF),(id=0xFFFFFFFF),(id=0xFFFFFFFF),(id=0xFFFFFFFF)),next=(id=0xFFFFFFFF));

up_pow2 :: fn(w: i32) i32 = {
    n := 63 - w.leading_zeros().zext();
    @if(1.shift_left(n) == w, w, 1.shift_left(n + 1))
}

#use("@/graphics/vec.fr");
V2 :: Vec(i32, 2); 
fn v2(a: i32, b: i32) V2 = (v = (a, b));
fn v2(a: i64, b: i64) V2 = (v = (a.trunc(), b.trunc()));
fn v2(a: i32) V2 = v2(a, a);
fn v2(a: i64) V2 = v2(@as(i32) a.intcast());
fn v2(a: Vec2) V2 = v2(a.x.cast().int(), a.y.cast().int());
fn v2(a: f32) V2 = v2(a.cast().int());
fn int(a: V2) Ty(i64, i64) = (a.x.intcast(), a.y.intcast());
fn float(a: V2) Vec2 = (v = (a.x.intcast().float().cast(), a.y.intcast().float().cast()));
