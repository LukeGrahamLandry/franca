//
// UNSAFE
//  the Memo data structure uses copying garbage collection, 
//  you can't hold a *Node without laundering it 
//  through gc_roots across any call to gc_reserve. 
//

do_life :: fn(w: i64, h: i64, $P: @Fn(x: i64, y: i64) u32 #duplicated, $yield: @Fn(x: i64, y: i64, value: bool) void) void = {
    range(0, h) { y |
        range(0, w) { x |
            n := P(x-1,y+1)+P(x,y+1)+P(x+1,y+1)
                +P(x-1,y+0)         +P(x+1,y+0)
                +P(x-1,y-1)+P(x,y-1)+P(x+1,y-1);
            live := P(x, y) == 1;
            new := (live && (n == 2 || n == 3)) || (!live && n == 3);
            yield(x, y, new);
        };
    };
}

// the most important thing is that the Node doesn't know its position in the grid so it can be reused. 
// for base case, node.children[_]=0 and node.hash is the cell data for base_case_w wide square. 
Node :: @rec @struct {
    children: Array(*Node, 4);   // TODO: these could be u32 index?
    next := zeroed(*Node);
    hash: u64 = 0;
    forward: u32 = 0;
    population: u32 = 0;
    next_fast := false;  // :SLOW 1 bit costs 8 bytes (but when i want to allolw more different speeds, this will need more bits)
};

base_case_w :: 2;  // TODO: profile different sizes: 2/4/8
Memo :: @struct {
    table: []*Node;  // hash table with masked node.hash (the flat/linear probing kind not the linked list buckets kind)
    buf: Array(RawList(Node), 2);
    buf_i: i64;
    root: *Node;
    size: i64;
    gc_roots: List([]*Node);
    a: Alloc;
};

new_memo :: fn(self: *Memo, a: Alloc) void = {
    self[] = zeroed(Memo);
    n := 24;
    self.buf&[0] = init(a, 1.shift_left(n));
    self.table = a.alloc_zeroed(*Node, 1.shift_left(n + 2));
    @eprintln("buf=%kb x2; table=%kb", self.buf&[0].cap * size_of(Node) / 1024, self.table.len * 8 / 1024);
    self.gc_roots = list(1, a);
    self.gc_roots&.push(self.root&.slice(1));
    self.a = a;
}

fn drop(memo: *Memo) void = {
    a := memo.a;
    for memo.buf& { it | drop(it&, a); };
    a.dealloc(*Node, memo.table);
    memo.gc_roots&.drop();
}

fn push(self: *Memo, node: Node) *Node = {
    if !node.children&[0].is_null() {
        @debug_assert(node.hash == 0 && node.population == 0);
        for node.children& { it |
            node.hash = node.hash.bit_xor(it.hash) + 1;
            node.hash *= 15120273018600372767;
            node.population += it.population;
        };
    };  // else: node.hash is bit set of cells
    @run @assert(base_case_w*base_case_w <= 64 && base_case_w.up_pow2() == base_case_w);
    
    mask := self.table.len - 1;
    i := node.hash.bitcast().bit_and(mask);
    j := 0;    
    loop {
        n := self.table[i]&;
        @debug_assert(j != self.table.len);
        if n[].is_null() {
            buf := self.buf&.index(self.buf_i);
            @debug_assert_lt(buf.len, buf.cap, "TODO: resize and copy starting at root to gc");
            buf.push(node, panicking_allocator);
            
            n[] = buf.index(buf.len - 1);
            return n[];
        };
        
        if n.hash == node.hash 
        && identical(n.children&[0], node.children&[0])
        && identical(n.children&[1], node.children&[1])
        && identical(n.children&[2], node.children&[2])
        && identical(n.children&[3], node.children&[3]) 
        {
            return n[];
        };
        i = (i + 1).bit_and(mask);
        j += 1;
    };
}

// UNSAFE: node must be unique
fn gc_table_insert(self: *Memo, node: *Node) void = {
  mask := self.table.len - 1;
  i := node.hash.bitcast().bit_and(mask);
  j := 0;    
  loop {
      n := self.table[i]&;
      @debug_assert(j != self.table.len);
      if n[].is_null() {
          n[] = node;
          return();
      };
      i = (i + 1).bit_and(mask);
      j += 1;
  };
}

fn zero_fill_grow_root(memo: *Memo) *Node = {
    // an extra level of quadtree where the old root node is just surrounded by dead cells. 
    // ex. top left of old root becomes bottom right of the new root's top left node. children are clockwise.
    size := memo.size;
    invert :: @const_slice(2, 3, 0, 1);
    memo.gc_reserve(size.trailing_zeros() + 5);
    empty := memo.empty_node(size/2);  // :SLOW
    children := zeroed Array(*Node, 4);
    
    range(0, 4) { i |
        n: Node = (children = (empty,empty,empty,empty));
        n.children&[invert[i]] = memo.root.children&[i];
        children&[i] = memo.push(n);
    };
    memo.push(children = children)
}

fn eval(memo: *Memo, fast: bool) void = {
    wrapped_root := memo.zero_fill_grow_root();
    size := memo.size;
    root_one(memo, wrapped_root) { wrapped_root |
        memo.gc_roots&.reserve((size*2).trailing_zeros() * 2);
        prev := memo.root.population;
        memo.root = eval_center(memo, wrapped_root, size*2, fast);
        @eprintln("eval; population: % -> %; ", prev, memo.root.population);
    };
}

// the grinch's heart shrank to half sizes that day
// UNSAFE: `node` must be rooted and gc_roots must have reserved enough capacity for all the levels of recursion
fn eval_center(memo: *Memo, node: **Node, size: i64, fast: bool) *Node = {
    @debug_assert(!is_null(node.children&[0]), "eval_center too low");
    if !node.next.is_null() && node.next_fast == fast {
        return node.next;
    };
    ::if(*Node);
    new := if size == base_case_w * 2 {
        center_base_case(memo, node)
    } else {
        eval_center_split_merge(memo, node, size, fast)
    };
    node.next = new;
    node.next_fast = fast;
    new
};

// from one node, can eval a centered node with half side length. 
// to eval the whole node, need to eval from parents, multiple smaller squares. 
// to cover the whole node, need to reorganize children 
// (into new nodes that aren't aligned to the original quad tree). 
// UNSAFE: `node` must be rooted
fn eval_center_split_merge(memo: *Memo, node: **Node, size: i64, fast: bool) *Node = {
    // children are clickwise starting at top left (but grandchildren are sorta a spiral)
    N :: fn(T: Type) #fold = size_of(Deref(T))/8;
    grandchildren :: fn(children: ~T) *Array(*Node, N(T)*4) #inline/*semantic*/ #where = {
        n := @ref @zeroed Array(*Node, N(T)*4);
        enumerate children { i, node |
            enumerate node.children& { j, it |
                n[i*4 + j] = it[];
            };
        };
        n
    };
    // you have to draw the picture to think about where the a,b,c,d numbers come from
    // https://lukegrahamlandry.ca/assets/hashlife.jpg
    join :: fn(n,a,b,c,d) => memo.push(children = (n[a], n[b], n[c], n[d]));
    
    memo.gc_reserve(5);
    n1 := grandchildren(node.children&);
    
    // right to left, top to bottom
    n2 := @ref @as(Array(*Node, 9)) (
        node.children&[0],
        n1.join(1,4,7,2),        // up
        node.children&[1],
        n1.join(3,2,13,12),      // left
        n1.join(2,7,8,13),       // center
        n1.join(7,6,9,8),        // right
        node.children&[3],
        n1.join(13,8,11,14),     // down
        node.children&[2],
    );
    n1 := ();  // not rooted
    
    size /= 2;
    pin_for_eval :: fn(in, n, $eval: @Fn(**Node) *Node) => {
        out := @ref @zeroed (Array(*Node, size_of(@type in[])/8));
        memo.gc_roots&.push_assume_capacity(out.items());
        memo.gc_roots&.push_assume_capacity(in.items());
        range(0, in.len()) { i |
            out[i] = eval(in[i]&);
        };
        memo.gc_reserve(n);
        memo.gc_roots.len -= 2;
        out
    };
    eval_centers :: fn(in, n) => pin_for_eval(in, n, fn(node) => 
        eval_center(memo, node, size, fast));
    
    n3 := eval_centers(n2, 5);
    
    if !fast && size != base_case_w * 2 {
        n6 := grandchildren(n3);
        n7 := @ref @as(Array(*Node, 4)) (  // clockwise
            n6.join( 2, 7,16,13), // 0,0
            n6.join( 6,11,20,17), // 1,0
            n6.join(18,23,32,29), // 1,1
            n6.join(14,19,28,25), // 1,0
        );
        return memo.push(children = n7[]);
    };
    
    n4 := @ref @as(Array(*Node, 4)) (  // clockwise
        n3.join(0,1,4,3), // 0,0
        n3.join(1,2,5,4), // 1,0
        n3.join(4,5,8,7), // 1,1
        n3.join(3,4,7,6), // 1,0
    );
    
    if !fast {  
        // grandchildren are base nodes so can't just rearrange pointers, need to mix the bit sets in _.hash.
        n8 := pin_for_eval(n4, 1, fn(node) => 
            get_center_base_case_no_eval(memo, node));
        return memo.push(children = n8[]);
    };
    
    // when fast=true: eval_centers twice per recursion so skip 2^depth generations. 
    n5 := eval_centers(n4, 1);
    memo.push(children = n5[])
};

// need to be able to access neighbours so stop one level before base case size. output is one whole base level. 
fn center_base_case(memo: *Memo, node: **Node) *Node = {
    build_center_base_node(memo, node) { h |
        do_life(base_case_w, base_case_w, fn(x, y) => {
            get_bit_from_base_children(node, x, y).int().trunc()
        }, fn(x, y, value) => {
            set_base_bit(h, x, y, value);
        });
    }
}

fn get_center_base_case_no_eval(memo: *Memo, node: **Node) *Node = {
    build_center_base_node(memo, node) { h |
        range(0, base_case_w) { y |
            range(0, base_case_w) { x |
                value := get_bit_from_base_children(node, x, y);
                set_base_bit(h, x, y, value);
            };
        };
    }
}

// UNSAFE: `node` must be rooted
fn build_center_base_node(memo: *Memo, node: **Node, $body: @Fn(h: *u64) void) *Node = {
    size := base_case_w * 2;
    memo.gc_reserve(size*size + 1);
    @debug_assert(is_null(node.children&[0].children&[0]), "center_base_case too deep");
    @debug_assert(memo.buf&[memo.buf_i]&.items().contains_address(node[]), "out of arena");
    new: u64 = 0;
    body(new&);
    memo.base_node(new)
}

// :SLOW feels like maybe there'd be a more elegant bitwise way to do this.
//
// node.children are base nodes (grandchildren(node)=null). 
// x,y is in coordinate system of (the center square of node). 
// info about that center square is split between the bit set in each node.children.hash, 
// so need to dispatch to the right child based on which quadrent of the center x,y is in. 
get_bit_from_base_children :: fn(node: **Node, x: i64, y: i64) bool = {
    size := base_case_w * 2;
    size := vec2(size.float().cast());
    base := size / 4;  // corner of output square in node's coordinates
    quad_size := size/2;
    parent_local_pos := base + vec2(x.float().cast(), y.float().cast());
    enumerate direction { child_i, dir |
        top_left := dir[] * quad_size;
        bottom_right := top_left + quad_size;
        if hit_square(parent_local_pos, top_left, bottom_right) {
            child_top_left := direction[child_i] * quad_size;
            child_local_pos := parent_local_pos - child_top_left;
            xx, yy := child_local_pos.int();
            child := node.children&[child_i];
            i := yy*base_case_w+xx;
            value := child.hash.shift_right_logical(i).bit_and(1) == 1;
            return value;
        }
    };
    panic("no hits");
}

set_base_bit :: fn(h: *u64, x: i64, y: i64, value: bool) void = {
    i := y*base_case_w+x;
    h[] = h[].bit_or(value.int().shift_left(i).bitcast());
}

hit_square :: fn(pos: Vec2, top_left: Vec2, bottom_right: Vec2) bool = 
    pos.x >= top_left.x && pos.y >= top_left.y && pos.x < bottom_right.x && pos.y < bottom_right.y;

fn base_node(memo: *Memo, bits: u64) *Node = {
    node := zeroed Node;
    node.hash = bits;
    node.population = bits.count_ones();
    memo.push(node)
}

// UNSAFE: call gc_reserve first
fn empty_node(memo: *Memo, size: i64) *Node = {
    if size == base_case_w {
        return memo.base_node(0);
    };
    n := memo.empty_node(size/2);
    memo.push(children = (n,n,n,n))
}

// moves any live (reachable from gc_roots) nodes to the other memo.buf and updates pointers. 
// null is a valid value in gc_roots: (childen of base node) or (partial array being filled in a loop). 
fn collect_garbage(memo: *Memo) void = {
    new_buf_i := memo.buf_i.bit_xor(1);
    to_space, from_space := (memo.buf&[new_buf_i]&, memo.buf&[memo.buf_i]&);
    @debug_assert_eq(to_space.len, 0);
    if to_space.cap < from_space.cap {
        to_space.reserve(from_space.cap, memo.a);
    };
    memo.table.set_zeroed();
    for memo.gc_roots& { it |
        recur(memo, it, to_space, from_space);
    };
    recur :: fn(memo: *Memo, it: []*Node, to_space: *RawList(Node), from_space: *RawList(Node)) void = {
        each it { it |
            if from_space.items().contains_address(it[]) {
                if it.forward != 0 {
                    it[] = to_space.index(it.forward.zext() - 1);
                } else {
                    to_space.push(it[][], panicking_allocator);
                    it.forward = to_space.len.trunc();
                    it[] = to_space.index(it.forward.zext() - 1);
                    it.forward = 0;
                    recur(memo, it.children&.items(), to_space, from_space);
                    memo.gc_table_insert(it[]);
                    recur(memo, it.next&.slice(1), to_space, from_space);
                };
            };
        };
    };
    @debug_assert_le(to_space.len, from_space.len);
    @eprintln("GC: % -> %", from_space.len, to_space.len);
    from_space.clear();
    memo.buf_i = new_buf_i;
    
    @if(@run safety_check_enabled(.DebugAssertions)) {
    check :: fn(it: *Node) => {
        @debug_assert(it.is_null() || {
            to_space.items().contains_address(it) && {
                it.next.is_null() || to_space.items().contains_address(it.next)
            }
        }, "unmoved child")
    };
    for(to_space, fn(it) => for(it.children&, check));
    for(memo.gc_roots, fn(it) => for(it, check));
    };
}

fn gc_reserve(memo: *Memo, n: i64) void #inline = {
    b := memo.buf&[memo.buf_i]&;
    @if(b.len + n <= b.cap) return();
    memo.collect_garbage();
    b := memo.buf&[memo.buf_i]&;
    // TODO: resize. annoying thing is there might technically never too big a live set but you're slow because keep doing redundant work by clearing the cache. 
    //                    plus have to resize and rehash the table.
    @debug_assert(b.len + n <= b.cap, "too many live nodes");
}

fn root_one(memo: *Memo, node: *Node, $body: @Fn(node: **Node) void) void = {
    root_count := memo.gc_roots.len;
    node := @ref node;
    memo.gc_roots&.push(node.slice(1));
    body(node);
    memo.gc_roots&.pop().unwrap();
    @debug_assert_eq(root_count, memo.gc_roots.len);
}

fn compress(flat: *BitBoard, memo: *Memo) void = {  // frame -> memo
    memo.gc_roots&.reserve(flat.size.trailing_zeros());
    memo.root = recur(flat, memo, vec2(0), flat.size);
    memo.size = flat.size;
    recur :: fn(flat: *BitBoard, memo: *Memo, pos: Vec2, size: i64) *Node = {
        if size == 32 {  // handle large empty blocks more efficiently
            break :: local_return;
            x, y := pos.int();
            @debug_assert(x.mod(32) == 0 && y.mod(32) == 0);
            range(y, y + 32) { y |
                @if(flat.bits[(y*flat.size + x).udiv(32)] != 0) break();
            };
            memo.gc_reserve(32.trailing_zeros());
            return memo.empty_node(32);
        };
    
        if size == base_case_w {
            x, y := pos.int();
            j := 0;
            h: u64 = 0;
            range(y, y + base_case_w) { y |
                range(x, x + base_case_w) { x |
                    value := flat.get(x, y);
                    h = h.bit_or(value.zext().shift_left(j).bitcast());
                    j += 1;
                };
            };
            return memo.base_node(h);
        };
            node := zeroed Node;
            size /= 2;
            vsize := vec2(size.float().cast());
            memo.gc_roots&.push_assume_capacity(node.children&.items());
            enumerate node.children& { i, it |
                it[] = recur(flat, memo, pos + vsize*direction[i], size);
            };
            memo.gc_reserve(1);
            memo.gc_roots.len -= 1;
        memo.push(node)
    };
}

fn decompress(flat: *BitBoard, memo: *Memo) void = {  // memo -> frame
    decompress_recur(@ref @as(Decomp) (
        flat = flat, memo = memo,
        view_start = vec2(0), 
        view_end = vec2(memo.size.float().cast()),
        pixels_per_cell = 1,
    ), memo.root, vec2(0), memo.size);
}

Decomp :: @struct {
    flat: *BitBoard;
    memo: *Memo;
    view_start: Vec2; 
    view_end: Vec2;
    pixels_per_cell: f32;
};

decompress_recur :: fn(self: *Decomp, node: *Node, pos: Vec2, size: i64) void = {
        @debug_assert(self.memo.buf&[self.memo.buf_i].items().contains_address(node), "tree node outside arena (%)", fmt_hex(node));
        @if(node.population == 0) return();
        
        v0, v1, n0, n1 := (self.view_start, self.view_end, pos, pos + vec2(size.float().cast()));
        no_overlap := v0.x > n1.x || n0.x > v1.x || v0.y > n1.y || n0.y > v1.y;
        if no_overlap {
            return();
        };
        
        node_pixels := size.float().cast() * self.pixels_per_cell;
        if size == base_case_w || node_pixels/2 < 1 {
            @debug_assert(size != base_case_w || node.children&[0].is_null(), "decompress void_node child at wrong depth");
            s := self.flat.size.float().cast();
            start := (pos - self.view_start) * vec2(self.pixels_per_cell);
            end := start + vec2(node_pixels);
            start := floor clamp(start, vec2(0), vec2(s));
            end := floor clamp(end, vec2(0), vec2(s));
            range(start.y.cast().int(), end.y.cast().int()) { y |
                range(start.x.cast().int(), end.x.cast().int()) { x |
                    if size == base_case_w {
                        cell := (vec2(x.float().cast(), y.float().cast()) - start) / self.pixels_per_cell;
                        cx, cy := cell.int();
                        j := cy*base_case_w + cx;
                        value := node.hash.bit_and(1.shift_left(j)) != 0;
                        if value {
                            self.flat.set(x, y, true);
                        };
                    } else {
                        self.flat.set(x, y, node.population != 0);
                    };
                };
            };
            return();
        };
        
        size /= 2;
        vsize := vec2(size.float().cast());
        enumerate node.children& { i, it |
            self.decompress_recur(it[], pos + vsize*direction[i], size);
        };
};

direction :: @const_slice(vec2(0), vec2(1, 0), vec2(1, 1), vec2(0, 1));

BitGame :: @struct(boards: Array(BitBoard, 2), parity: bool);

empty_bit_game :: fn(a: Alloc, w: i64) BitGame = 
    (boards = (empty_bitboard(a, w), empty_bitboard(a, w)), parity = false); 
fn get(self: *BitGame) *BitBoard = 
    self.boards&[self.parity.int()]&;
fn drop(self: *BitGame, a: Alloc) void = 
    for self.boards& { it | a.dealloc(u32, it.bits); it.bits.len = 0; };

fn eval(self: *BitGame) void = {
    eval(self.boards&[self.parity.not().int()]&, self.get());
    self.parity = !self.parity;
}

BitBoard :: @struct(bits: []u32, size: i64);

empty_bitboard :: fn(a: Alloc, w: i64) BitBoard = 
    (bits = a.alloc_zeroed(u32, w*w/32), size = w);

fn get(it: *BitBoard, x: i64, y: i64) u32 = {
    I := y * it.size + x;
    s, i := I.udiv_mod(32);
    it.bits[s].shift_right_logical(i).bit_and(1)
}

fn set(it: *BitBoard, x: i64, y: i64, new: bool) void = {
    I := y * it.size + x;
    s, i := I.udiv_mod(32);
    slot := it.bits[s]&;
    slot[] = slot[]
        .bit_and(1.shift_left(i).bit_not())
        .bit_or(int(new).trunc().shift_left(i));
}

fn eval(new: *BitBoard, old: *BitBoard) void = {
    w := old.size;
    do_life(w, w, P, fn(x, y, val) => new.set(x, y, val));
    P :: fn(x: i64, y: i64) u32 => {
        oob := x < 0 || y < 0 || x >= w || y >= w;
        @if(oob, 0, old.get(x, y))
    };
}

up_pow2 :: fn(w: i64) i64 = {
    n := 63 - w.leading_zeros();
    @if(1.shift_left(n) == w, w, 1.shift_left(n + 1))
}

#use("@/graphics/vec.fr");
