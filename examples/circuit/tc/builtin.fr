RamDualLoad :: with_pins(2, 6, .Device,
    Ram.compute_storage.unwrap(),
    fn(world: *World, o: *Array(i64, 2), i: *Array(i64, 6), param: i64) void = {
        _load0, save, a0, value, _load1, a1 := (i[0] != 0, i[1] != 0, i[2], i[3], i[4] != 0, i[5]);
        param: Settings.Ram = (repr = param.bitcast());
        word_size_index, storage_size := (param.get(.word_size_index), param.get(.storage_size));
        word_size := param.word_size();
        
        n := (storage_size * word_size).ualign_to(8).udiv(8);
        bytes := interpret_as_bytes(world.storage.subslice(world.instance, n));
        a := @slice(a0, a1);
        // :SLOW
        impl :: fn($T: Type) => {
            data := T.reinterpret_bytes(bytes);
            enumerate a { I, a |
                if a[].ult(storage_size) {
                    slot := data[a[]]&;
                    o[I] = slot[].int();
                    // TODO: technically should still be checking z_input_mask probably but since there's only one store slot it's a skill issue to ask for save without giving a value. (if change here, need to fix in find_pins too)
                    if !world.doing_pre_read && save && I == 0 {
                        slot[] = @if(@run(T == i64), value, value.trunc());
                    }
                } else {
                    o[I] = 0;
                };
            };
        };
        @switch(word_size_index) {
            @case(0) => impl(u8);
            @case(1) => impl(u16);
            @case(2) => impl(u32);
            @case(3) => impl(i64);
            @default => unreachable();
        };
        
        world.instance += n;
    },
);
