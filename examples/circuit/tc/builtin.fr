Register64 :: device(1, 3, 
    fn(_) => 8*8,
    fn(world: *World, o: *Array(i64, 1), i: *Array(i64, 3), instance: i64, doing_pre_read: bool) void = {
        _load, save, value := (i[0] != 0, i[1] != 0, i[2]);
        slot := world.storage[instance]&;
        o[0] = slot[];
        if !doing_pre_read && save {
            slot[] = value;
        };
    },
);
VirtualRegister64 :: todo();
Switch8 :: Switch64;
// TODO: the cmov one might be better because easier to keep things in registers
Mux8 :: math(1, 3) { o, i | o[0] = i[1 + int(i[0] != 0)]; };
Decoder1 :: math(2, 1) { o, i | o[] = (i[0].bit_and(1).bit_xor(1), i[0].bit_and(1)); };
Decoder3 :: math(8, 4) { o, i | 
    o[] = (0, 0, 0, 0, 0, 0, 0, 0);
    n := @or(i[0], i[1].shift_left(1), i[2].shift_left(2));
    o[n] = i[3].bit_xor(1);
};
Constant8 :: Constant64;
Not8 :: mask(8, Not64);
Or8 :: Or;
And8 :: And;
Xor8 :: Xor;
Equal8 :: math(1, 2) { o, i | o[0] = int(i[0] == i[1]); };
_41 :: todo();
_42 :: todo();
Neg8 :: mask(8, Neg64);
Add8 :: math(2, 3) { o, i | 
    r := i[0] + i[1] + i[2];
    o[0] = bit_and(r, 255); 
    o[1] = int(r >= 256);
};
Mul8 :: math(2, 2) { o, i |
    r := i[0] * i[1];
    o[0] = r.bit_and(0xFF); 
    o[1] = r.shift_right_logical(8).bit_and(0xFF);
};
Splitter8 :: math(8, 1) { o, i | 
    r := i[0];
    inline_range(0, 8) { i |
        o[i] = r.shift_right_logical(i).bit_and(1);
    };
};
Maker8 :: math(1, 8) { o, in |
    r := 0;
    inline_range(0, 8) { i |
        r = r.bit_or(in[i].shift_left(i));
    };
    o[0] = r;
};
Splitter64 :: make_split_bytes(8);
Maker64 :: make_from_bytes(8);
FullAdder :: math(2, 3) { o, i |
    w4 := bit_xor(i[0], i[1]);
    w6 := bit_or(bit_and(w4, i[2]), bit_and(i[0], i[1]));
    w7 := bit_xor(w4, i[2]);
    o[] = (w7, w6);
};
BitMemory :: device(1, 2, 
    fn(_) => 64,
    fn(world: *World, o: *Array(i64, 1), i: *Array(i64, 2), instance: i64, doing_pre_read: bool) void = {
        value, save := (i[0], i[1] != 0);
        slot := world.storage[instance]&;
        o[0] = slot[];
        if !doing_pre_read && save {
            slot[] = i[0];
        };
    },
);
VirtualBitMemory :: todo();
_53 :: todo();
Decoder2 :: math(4, 2) { o, i | 
    n := @or(i[0], i[1].shift_left(1));
    inline_range(0, 4) { i |
        o[i] = int(n == i);
    };
};
Timing :: device(1, 1, 
    fn(_) => 0,
    fn(world: *World, o: *Array(i64, 1), i: *Array(i64, 1)) void = {
        enable := i[0] != 0;
        o[0] = if enable {
            world.timestamp_us || {
                x := realtime_us();
                world.timestamp_us = (Some = x);
                x
            }
        } else {
            0
        };
    },
);
NoteSound :: device(0, 3, 
    fn(_) => 0,
    fn(world: *World, o: *Array(i64, 0), i: *Array(i64, 3)) void = {
        // TODO
    },
);
_57 :: todo();
_58 :: todo();
// out: (event waiting, key value, key up)
Keyboard :: device(3, 1, 
    fn(_) => 64,
    fn(world: *World, o: *Array(i64, 3), i: *Array(i64, 1), _: i64, instance: i64, doing_pre_read: bool) void = {
        read_next := i[0] != 0;
        @assert_eq(size_of(KeyboardData), size_of(WireValue));
        data := bit_cast_unchecked(*WireValue, *KeyboardData, world.storage.index(instance));
        o[] = (int(data.have_next > 0 || data.prev_value != 0), data.prev_value.int(), data.prev_up.int());
        if read_next {
            o[] = (int(data.have_next > 0 || data.value != 0), data.value.int(), data.up.int());
            if !doing_pre_read {
                data.prev_value = data.value;
                data.prev_up = data.up;
                data.valid = false;
            };
        };
    },
);

FileLoader :: device(1, 2, 
    fn(_) => 0,
    fn(world: *World, o: *Array(i64, 1), i: *Array(i64, 2), param: i64) void = {
        enable, offset := (i[0] != 0, i[1]);
        want_length := offset == -1;
        oob := !param.ult(world.tc_file_loader_device.len);  // (-1 means failed to read file)
        file := @if(oob, "", world.tc_file_loader_device[param].data);
        o[0] = @if_else {
            @if(!enable) => 0;
            @if(want_length) => file.len;
            @if(!offset.ult(file.len)) => 0;
            @if((offset + 8).ule(file.len)) => file.rest(offset).peek_type(i64)[];
            @else => {
                r: i64 = 0;
                range_rev(offset, min(offset + 8, file.len)) { i |
                    r = r.shift_left(8).bit_or(file[i].zext());
                };
                r
            };
        };
    },
);
Halt :: device(0, 1, 
    fn(_) => 0,
    fn(world: *World, o: *Array(i64, 0), i: *Array(i64, 1), param: i64) void = {
        halt := i[0] != 0;
        if halt {
            world.tc_halt_device = param;
        };
    },
);
