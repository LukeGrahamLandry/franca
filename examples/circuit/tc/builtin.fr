Ram :: with_pins(4, 7, .Device,
    256*8,
    fn(world: *World, o: *Array(i64, 4), i: *Array(i64, 7)) void = {
        load, save, address := (i[0] != 0, i[1] != 0, i[2]);
        inputs := i.items().rest(3);
        
        n := (256*8)/64;
        slot := world.storage.subslice(world.instance, n);
        bytes := interpret_as_bytes(slot);
        range(0, 4) { I |
            slot := bytes[bit_and(address + I, 255)]&;
            o[I] = slot[].zext();
            if !world.doing_pre_read && save {
                slot[] = inputs[I].trunc();
            }
        };
        world.instance += n;
    },
);

