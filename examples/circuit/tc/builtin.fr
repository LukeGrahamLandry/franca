Rom :: with_pins(1, 4, .Device,
    Ram.compute_storage.unwrap(),
    fn(world: *World, o: *Array(i64, 1), i: *Array(i64, 4), param: i64) void = {
        O := zeroed(Array(i64, 4));
        (@run Ram'fid.unwrap())(world, O&, @ref @as(Array(i64, 7)) (i[0], i[1], i[2], i[3], 0, 0, 0), param);
        o[0] = O&[0];
    },
);
