Program :: with_pins(1, 1, .Device,
    @const_slice((13, -7), (-13, -7)),
    256*8,
    fn(world: *World, o: *Array(i64, 1), i: *Array(i64, 1)) void = {
        // TODO: actually 4 outputs, configurable size. 
        address := i[0].bit_and(255);
        n := (256*8)/64;
        @debug_assert_ule(world.instance + n, world.storage.len, "must preallocate storage_count");
        slot := world.storage.subslice(world.instance, n);
        bytes := interpret_as_bytes(slot);
        o[0] = bytes[address].zext();
        world.instance += n;
    },
);
