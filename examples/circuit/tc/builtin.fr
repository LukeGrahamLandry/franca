DotMatrixDisplay :: with_pins(0, 4, .Device, 
    fn(_) => 48*32*2,
    fn(world: *World, o: *Array(i64, 0), i: *Array(i64, 4), param: i64) void = {
        coloumn_major_pixels := param == 1;  // TODO
        @debug_assert(!world.doing_pre_read, "don't need to preread something without outputs");
        n := 48*32*2/64;
        buf := world.storage.subslice(world.instance, n);
        world.instance += n;
        enable, pixel_mask, colour := (i[1].bit_and(1) == 1 && i[3].bit_and(1) == 1, i[0], i[2]);
        @if(!enable) return();
        flush := pixel_mask.shift_right_logical(56) == 1;
        
        buf := u32.reinterpret_bytes(buf.interpret_as_bytes());
        active, scratch := (buf.subslice(0, 48), buf.subslice(48, 48));
        // TODO: for_bits
        if coloumn_major_pixels {
            range(0, 48) { i |
                y, x := i.div_mod(6);  // :SLOW
                I := x*8+y;
                if pixel_mask.bit_and(1.shift_left(I+8)) != 0 {
                    scratch[i] = colour.trunc();
                };
            };
        } else {
            range(0, 48) { i |
                if pixel_mask.bit_and(1.shift_left(i+8)) != 0 {
                    scratch[i] = colour.trunc();
                };
            };
        };
        
        if flush {
            active.copy_from(scratch);
        };
    },
);
// each bit enables one segment
SegmentDisplay :: with_pins(0, 2, .Device, 
    fn(_) => 64,
    fn(world: *World, o: *Array(i64, 0), i: *Array(i64, 2), param: i64) void = {
        @debug_assert(!world.doing_pre_read, "don't need to preread something without outputs");
        world.storage[world.instance] = @if(i[1] == 0, 0, i[0]);
        world.instance += 1;
    },
);
