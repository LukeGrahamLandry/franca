get_width_data :: fn(it: *Template) []u8 = {
    a := ast_alloc();
    all_one :: @const_slice(GateName(.Tc1).BitMemory, .And3, .Or3, .FullAdder, .Decoder3, .Decoder1, .Decoder2, .On, .Off, .Halt, .LevelOutput1Sum, .LevelOutput1Car);
    all_suffix :: @const_slice("DelayLine", "Input", "Output", "Bidirectional", "Shl", "Shr", "Ashr", "Rol", "Ror", "And", "Or", "Xor", "Nand", "Xnor", "Nor", "Not", "Constant", "DivMod", "Mul", "Neg", "LevelInput", "LevelOutput");
    cmp_suffix :: @const_slice("Equal", "LessU", "LessI");
    suffix_int :: fn(s: Str) ?u8 = {
        i := s.len - 1;
        @if(!s[i].is_ascii_digit()) return(.None);
        while => i > 0 && s[i].is_ascii_digit() {
            i -= 1;
        };
        (Some = s.rest(i+1).parse_int().trunc())
    };
    pin_count := it.in_arity + it.out_arity;
    k := import("@/examples/circuit/tc/load.fr")'gate_name(it.kind, .Tc1);
    if all_one.contains(fn(x) => x[] == k) {
        return a.alloc_init(u8, pin_count, fn(_) => 1);
    }
    for all_suffix { prefix |
        if suffix_int(it.name) { i |
            if it.name.starts_with(prefix) {
                return a.alloc_init(u8, pin_count, fn(_) => i);
            };
        };
        if it.name == prefix {
            return a.alloc_init(u8, pin_count, fn(_) => 1);
        }
    };
    
    for cmp_suffix { prefix |
        if it.name.starts_with(prefix) {
            i := suffix_int(it.name).unwrap();
            return @slice(0x01, i, i) a;
        }
    };
    if it.name.starts_with("Output") && it.name.ends_with("z") {
        i := suffix_int(it.name.slice(0, it.name.len - 1)).unwrap();
        return @slice(i, 0x01) a;
    }
    
    if it.name.starts_with("Mux"){
        i := suffix_int(it.name).unwrap();
        return @slice(i, 0x01, i, i) a;
    }
    if it.name.starts_with("Switch") || it.name.starts_with("Counter") {
        i := suffix_int(it.name).unwrap();
        return @slice(i, i, 0x01) a;
    }
    
    @if(k == .IndexerBit) return(@slice(0x01, 64) a);
    @if(k == .IndexerByte) return(@slice(0x08, 64) a);
    @if(it.name == "LevelInputArch" || it.name == "LevelOutputArch") return(@slice(0x08, 0x01) a);
    @if(k == .FileLoader) return(@slice(0x40, 0x01, 0x40) a);
    if it.name.starts_with("Register") {
        if suffix_int(it.name) { i |
            return @slice(i, 0x01, 0x01, i) a;
        };
    }
    @if(k == .Maker8) return(@slice(0x08, 0x01, 0x01, 0x01, 0x01, 0x01, 0x01, 0x01, 0x01) a);
    @if(k == .Splitter8) return(@slice(0x01, 0x01, 0x01, 0x01, 0x01, 0x01, 0x01, 0x01, 0x08) a);
    @if(k == .Maker16) return(@slice(0x10, 0x08, 0x08) a);
    @if(k == .Splitter16) return(@slice(0x08, 0x08, 0x10) a);
    @if(k == .Maker32) return(@slice(0x20, 0x08, 0x08, 0x08, 0x08) a);
    @if(k == .Splitter32) return(@slice(0x08, 0x08, 0x08, 0x08, 0x20) a);
    @if(k == .Maker64) return(@slice(0x40, 0x08, 0x08, 0x08, 0x08, 0x08, 0x08, 0x08, 0x08) a);
    @if(k == .Splitter64) return(@slice(0x08, 0x08, 0x08, 0x08, 0x08, 0x08, 0x08, 0x08, 0x40) a);
    if it.name.starts_with("Add") {
        i := suffix_int(it.name).unwrap();
        return @slice(i, 0x01, 0x01, i, i) a;
    }
    
    @if(k == .Timing) return(@slice(0x40, 0x01) a);
    @if(k == .Console) return(@slice(0x40) a);
    @if(k == .Keyboard) return(@slice(0x01, 0x10, 0x01, 0x01) a);
    @if(k == .SegmentDisplay) return(@slice(0x08, 0x01) a);
    @if(k == .DotMatrixDisplay) return(@slice(0x40, 0x01, 0x20, 0x01) a);
    @if(k == .NoteSound) return(@slice(0x40, 0x40, 0x40) a);  // TODO
    @if(k == .SpriteDisplay) return(@slice(0x08, 0x08, 0x20, 0x20) a);
    
    i := 0x40;  // :SpecialOutputBitWidth
    @if(k == .Ram || k == .RamFast) return(@slice(i, i, i, i, 0x01, 0x01, 0x40, i, i, i, i) a);
    @if(k == .Program) return(@slice(i, i, i, i, 0x40) a);
    @if(k == .Rom) return(@slice(i, 0x01, 0x01, 0x40, i) a);
    @if(k == .RamDualLoad) return(@slice(i, i, 0x01, 0x01, 0x40, i, 0x01, 0x40) a);
    
    empty()
}

parse_pin_layouts :: fn($g: Tc.GateGroup) FuncId = (fn(e: FatExpr) FatExpr #macro = {
    G :: GateName(g);
    result: OptionalEnumMap(G, []Pin) = empty();
    each e&.items() { entry |
        e := entry.items();
        names, pins := (e[0]&, e[1]&);
        pins_value := collect_values(Pin, pins);
        names_value := collect_values(G, names);
        for names_value { name |
            prev := result&.insert(name, pins_value);
            @ct_assert(prev.is_none(), entry.loc, "% used twice in pin_layouts", name);
        };
    };
    collect_values :: fn($T: Type, e: *FatExpr) []T #generic = {
        es := e.items();
        out := T.list(es.len, ast_alloc());
        if !es[0].expr&.is(.Tuple) && !es[0].expr&.is(.ContextualField) {
            out&.push(T.const_eval(e[]));
        } else {
            each es { e |
                out&.push(T.const_eval(e[]));
            };
        }
        out.items()
    }
    @literal result
});

multiply_high_u64 :: AsmFunction(fn(a: i64, b: i64) i64 = (), { #use("@/backend/arm64/bits.fr"); @const_slice(
    @bits(0b1, 0b00, 0b1, 0b101, 0b1, 0b1, 0b10, @as(u5) x1, 0b0, 0b11111, @as(u5) x0, @as(u5) x0),  // UMULH
    ret(),
)}, (fn(out) #use("@/backend/amd64/bits.fr") = @asm_x64(  // rdi, rsi -> rax
    encode_bin(PrimaryOp.MovReg, X86Reg.rax, X86Reg.rdi),
    encode_extended_op(ModrmMode.Direct, 0xF7, 4, X86Reg.rsi),  // MUL: rdx:rax = rax*rsi
    encode_bin(PrimaryOp.MovReg, X86Reg.rax, X86Reg.rdx),
    PrimaryOp.Ret,
) out), (fn(out) = {
    // TODO: this one's going to be a nightmare i fear
    out.push_all(@slice(0x00, 0x42, 0x00, 0x0B)); // wasm { 0 locals. i64.const(0). end.
}), { #use("@/backend/rv64/bits.fr"); @const_slice(
    R(0b0000001, RvReg.A1.bits(), RvReg.A0.bits(), 0b011, RvReg.A0.bits(), .op), // MULHU
    jalr(.RA, 0, .Zero),
)});
