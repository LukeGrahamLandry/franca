Register64 :: with_pins(1, 3, .Device, 
    fn(_) => 8*8,
    fn(world: *World, o: *Array(i64, 1), i: *Array(i64, 3)) void = {
        _load, save, value := (i[0] != 0, i[1] != 0, i[2]);
        slot := world.storage[world.instance]&;
        o[0] = slot[];  // TODO: need to do something about unpowered when !load. 
        if !world.doing_pre_read && save {
            slot[] = value;
        };
        world.instance += 1;
    },
);
VirtualRegister64 :: todo();
Switch8 :: Switch64;
// TODO: the cmov one might be better because easier to keep things in registers
Mux8 :: math(1, 3) { o, i | o[0] = i[1 + int(i[0] != 0)]; };
Decoder1 :: math(2, 1) { o, i | o[] = (i[0].bit_and(1).bit_xor(1), i[0].bit_and(1)); };
Decoder3 :: math(8, 4) { o, i | 
    n := @or(i[0], i[1].shift_left(1), i[2].shift_left(2));
    n := @if(i[3] == 0, n, -1);  // disable bit
    inline_range(0, 8) { i |
        o[i] = int(n == i);
    };
};
Constant8 :: Constant64;
Not8 :: mask(8, Not64);
Or8 :: Or;
And8 :: And;
Xor8 :: Xor;
Equal8 :: math(1, 2) { o, i | o[0] = int(i[0] == i[1]); };
_41 :: todo();
_42 :: todo();
Neg8 :: mask(8, Neg64);
Add8 :: math(2, 3) { o, i | 
    r := i[0] + i[1] + i[2];
    o[0] = bit_and(r, 255); 
    o[1] = int(r >= 256);
};
Mul8 :: math(2, 2) { o, i |
    r := i[0] * i[1];
    o[0] = r.bit_and(0xFF); 
    o[1] = r.shift_right_logical(8).bit_and(0xFF);
};
Splitter8 :: math(8, 1) { o, i | 
    r := i[0];
    inline_range(0, 8) { i |
        o[i] = int(r.bit_and(1.shift_left(i)) != 0);
    };
};
Maker8 :: math(1, 8) { o, in |
    r := 0;
    inline_range(0, 8) { i |
        r = r.bit_or(in[i].bit_and(0b1).shift_left(i));
    };
    o[0] = r;
};
Splitter64 :: make_split_bytes(8);
Maker64 :: make_from_bytes(8);
FullAdder :: from_defs("full_add");
BitMemory :: from_defs("memory1");
VirtualBitMemory :: todo();
_53 :: todo();
Decoder2 :: math(4, 2) { o, i | 
    n := @or(i[0], i[1].shift_left(1));
    inline_range(0, 4) { i |
        o[i] = int(n == i);
    };
};
Timing :: with_pins(1, 1, .Device, 
    fn(_) => 0,
    fn(world: *World, o: *Array(i64, 1), i: *Array(i64, 1)) void = {
        enable := i[0] != 0;
        o[0] = if enable {
            // TODO: cache on world for the whole tick in case they have multiple clocks for some reason. 
            //       also then caller could set it early and make it deterministic for testing. 
            it := zeroed(TimeSpec);
            Posix'clock_gettime(Posix.CLOCK.REALTIME, it&);
            it.seconds*US_PER_S + it.nanoseconds/NS_PER_US
        } else {
            0
        };
    },
);
NoteSound :: with_pins(0, 3, .Device, 
    fn(_) => 0,
    fn(world: *World, o: *Array(i64, 0), i: *Array(i64, 3)) void = {
        // TODO
    },
);
_57 :: todo();
_58 :: todo();
// TODO: character mode param
// out: (event waiting, key value, key up)
Keyboard :: with_pins(3, 1, .Device, 
    fn(_) => 64,
    fn(world: *World, o: *Array(i64, 3), i: *Array(i64, 1)) void = {
        read_next := i[0] != 0;
        @assert_eq(size_of(KeyboardData), size_of(WireValue));
        data := bit_cast_unchecked(*WireValue, *KeyboardData, world.storage.index(world.instance));
        world.instance += 1;
        o[] = (data.have_next.int(), data.value.int(), data.up.int());
        if read_next && !world.doing_pre_read {
            data.want_next = true;
        };
    },
);

FileLoader :: with_pins(1, 2, .Device, 
    fn(_) => 0,
    fn(world: *World, o: *Array(i64, 1), i: *Array(i64, 2), param: i64) void = {
        enable, offset := (i[0] != 0, i[1]);
        want_length := offset == -1;
        oob := !param.ult(world.tc_file_loader_device.len);  // (-1 means failed to read file)
        file := @if(oob, "", world.tc_file_loader_device[param].data);
        o[0] = @if_else {
            @if(!enable) => 0;
            @if(want_length) => file.len;
            @if(!offset.ult(file.len)) => 0;
            @if((offset + 8).ult(file.len)) => file.rest(offset).peek_type(i64)[];
            @else => {
                r: i64 = 0;
                range_rev(offset, min(offset + 8, file.len)) { i |
                    r = r.shift_left(8).bit_or(file[i].zext());
                };
                r
            };
        };
    },
);
Halt :: with_pins(0, 1, .Device, 
    fn(_) => 64,
    fn(world: *World, o: *Array(i64, 0), i: *Array(i64, 1), param: i64) void = {
        halt := i[0] != 0;
        if halt && !world.doing_pre_read {
            world.tc_halt_device = param;
        };
        world.instance += 1;
    },
);
