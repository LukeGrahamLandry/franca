    r := i[0] * i[1];
    o[0] = r.bit_and(0xFFFF); 
    o[1] = r.shift_right_logical(16).bit_and(0xFFFF);
};
Equal16 :: Equal64;
LessU16 :: LessU64;
LessI16 :: math(1, 2) { o, i | o[0] = int(lt(i[0].sign_extend(15), i[1].sign_extend(15))); }
Shl16 :: math(1, 2) { o, i | o[0] = i[0].shift_left(i[1].bit_and(0b1111)).bit_and(0xffff); }
Shr16 :: math(1, 2) { o, i | o[0] = i[0].shift_right_logical(i[1].bit_and(0b1111)); }
Mux16 :: Mux8;
Switch16 :: Switch64;
Splitter16 :: make_split_bytes(2);
Maker16 :: make_from_bytes(2);
Register16 :: Register64;
VirtualRegister16 :: todo();
Counter16 :: mask_param(16, Counter64);
VirtualCounter16 :: todo();
Constant32 :: Constant64;
Not32 :: mask(32, Not64);
Or32 :: Or64;
And32 :: And64;
Xor32 :: Xor64;
Neg32 :: mask(32, Neg64);
Add32 :: math(2, 3) { o, i | 
    r := i[0] + i[1] + i[2];
    o[0] = bit_and(r, 0xFFFFFFFF); 
    o[1] = int(r > 0xFFFFFFFF);
};
Mul32 :: math(2, 2) { o, i |
    r := i[0] * i[1];
    o[0] = r.bit_and(0xFFFFFFFF); 
    o[1] = r.shift_right_logical(32);
};
Equal32 :: Equal64;
LessU32 :: LessU64;
LessI32 :: math(1, 2) { o, i | o[0] = int(lt(i[0].intcast(), i[1].intcast())); };
Shl32 :: math(1, 2) { o, i | o[0] = (@as(u32) i[0].trunc()).shift_left(i[1]).zext(); }
Shr32 :: math(1, 2) { o, i | o[0] = (@as(u32) i[0].trunc()).shift_right_logical(i[1]).zext(); }
Mux32 :: Mux8;
Switch32 :: Switch64;
Splitter32 :: make_split_bytes(4);
Maker32 :: make_from_bytes(4);
Register32 :: Register64;
VirtualRegister32 :: todo();
Counter32 :: mask_param(32, Counter64);
VirtualCounter32 :: todo();
LevelOutput8z :: todo();
Nand8 :: mask(8, Nand64);
Nor8 :: mask(8, Nor64);
Xnor8 :: mask(8, Xnor64);
Nand16 :: mask(16, Nand64);
Nor16 :: mask(16, Nor64);
Xnor16 :: mask(16, Xnor64);
Nand32 :: mask(32, Nand64);
Nor32 :: mask(32, Nor64);
Xnor32 :: mask(32, Xor64);
Nand64 :: math(1, 2) { o, i | o[0] = i[0].bit_and(i[1]).bit_not(); };
Nor64 :: math(1, 2) { o, i | o[0] = i[0].bit_or(i[1]).bit_not(); };
Xnor64 :: math(1, 2) { o, i | o[0] = i[0].bit_xor(i[1]).bit_not(); };
// settings; [0] is size, [1] is data width as index in [8,16,32,64,128,256]
// the extra wires are only used in 128/256 bit modes.
Ram :: device(4, 7,
    fn(it) => {
        param: Settings.Ram = (repr = it.param.bitcast());
        param.get(.storage_size) * param.word_size() * 8
    },
    fn(world: *World, o: *Array(i64, 4), i: *Array(i64, 7), param: i64, instance: i64, doing_pre_read: bool) void = {
        param: Settings.Ram = (repr = param.bitcast());
        word_size_index, storage_size := (param.get(.word_size_index), param.get(.storage_size));
        word_size := param.word_size();
        
        _load, save, address := (i[0] != 0, i[1] != 0, i[2]);
        inputs := i.items().rest(3);
        if !address.ult(storage_size) {
            o[] = (0,0,0,0);
            return();
        };
        
        n := (storage_size * word_size).ualign_to(8).udiv(8);
        bytes := interpret_as_bytes(world.storage.subslice(instance, n));
        
        impl :: fn($T: Type, N: i64) => {
            data := T.reinterpret_bytes(bytes);
            count := @if(param.get(.is_program) == 1, 4, N);
            range(0, count) { I |
                a := address*N + I;
                    slot := data[a]&;
                    o[I] = slot[].int();
                    if !doing_pre_read && save {
                        slot[] = @if(@run(T == i64), inputs[I], inputs[I].trunc());
                    }
            };
        };
        @switch(word_size_index) {
            @case(0) => impl(u8, 1);
            @case(1) => impl(u16, 1);
            @case(2) => impl(u32, 1);
            @case(3) => impl(i64, 1);
            @case(4) => impl(i64, 2);
            @case(5) => impl(i64, 4);
            @default => unreachable();
        };
    },
);

VirtualRam :: todo();
RamLatency :: todo();
VirtualRamLatency :: todo();
RamFast :: Ram;
VirtualRamFast :: todo();
Rom :: device(1, 4,
    Ram.compute_storage.unwrap(),
    fn(world: *World, o: *Array(i64, 1), i: *Array(i64, 4), param: i64, instance: i64, doing_pre_read: bool) void = {
        O := @uninitialized Array(i64, 4);
        @inline ((@run Ram'fid.unwrap())(world, O&, @ref @as(Array(i64, 7)) (i[0], i[1], i[2], i[3], 0, 0, 0), param, instance, doing_pre_read));
        o[0] = O&[0];
    },
);
VirtualRom :: todo();
SolutionRom :: todo();
VirtualSolutionRom :: todo();
DelayLine8 :: DelayLine64;
VirtualDelayLine8 :: todo();
DelayLine16 :: DelayLine64;
VirtualDelayLine16 :: todo();
DelayLine32 :: DelayLine64;
VirtualDelayLine32 :: todo();
DelayLine64 ::DelayLine1;
VirtualDelayLine64 :: todo();
// ugh, kinda paste from the other one but not really
RamDualLoad :: device(2, 6,
    Ram.compute_storage.unwrap(),
    fn(world: *World, o: *Array(i64, 2), i: *Array(i64, 6), param: i64, instance: i64, doing_pre_read: bool) void = {
        _load0, save, a0, value, _load1, a1 := (i[0] != 0, i[1] != 0, i[2], i[3], i[4] != 0, i[5]);
        param: Settings.Ram = (repr = param.bitcast());
        word_size_index, storage_size := (param.get(.word_size_index), param.get(.storage_size));
        word_size := param.word_size();
        
        n := (storage_size * word_size).ualign_to(8).udiv(8);
        bytes := interpret_as_bytes(world.storage.subslice(instance, n));
        a := @slice(a0, a1);
        // :SLOW
        impl :: fn($T: Type) => {
            data := T.reinterpret_bytes(bytes);
            enumerate a { I, a |
                if a[].ult(storage_size) {
                    slot := data[a[]]&;
                    o[I] = slot[].int();
                    if !doing_pre_read && save && I == 0 {
                        slot[] = @if(@run(T == i64), value, value.trunc());
                    }
                } else {
                    o[I] = 0;
                };
            };
        };
        @switch(word_size_index) {
            @case(0) => impl(u8);
            @case(1) => impl(u16);
            @case(2) => impl(u32);
            @case(3) => impl(i64);
            // 4,5 => not enough pins
            @default => unreachable();
        };
        
    },
);
VirtualRamDualLoad :: todo();
Hdd :: todo();
VirtualHdd :: todo();
Network :: todo();
// TODO: test these
Rol8 :: math(1, 2) { o, i | r := i[1].bit_and(0b111); o[0] = i[0].shift_left(r).bit_or(i[0].shift_right_logical(8 - r)).bit_and(0xff); }
Rol16 :: math(1, 2) { o, i | r := i[1].bit_and(0b1111); o[0] = i[0].shift_left(r).bit_or(i[0].shift_right_logical(16 - r)).bit_and(0xffff); }
Rol32 :: math(1, 2) { o, i | o[0] = (@as(u32) i[0].trunc()).rotate_left(i[1]).zext(); }
Rol64 :: math(1, 2) { o, i | o[0] = i[0].rotate_left(i[1]); }
Ror8 :: math(1, 2) { o, i | r := i[1].bit_and(0b111); o[0] = i[0].shift_left(8 - r).bit_or(i[0].shift_right_logical(r)).bit_and(0xff); }
Ror16 :: math(1, 2) { o, i | r := i[1].bit_and(0b1111); o[0] = i[0].shift_left(16 - r).bit_or(i[0].shift_right_logical(r)).bit_and(0xffff); }
Ror32 :: math(1, 2) { o, i | o[0] = (@as(u32) i[0].trunc()).rotate_right(i[1]).zext(); }
Ror64 :: math(1, 2) { o, i | o[0] = i[0].rotate_right(i[1]); }
IndexerBit :: math_param(1, 1) { o, i, param | o[0] = i[0].shift_right_logical(param).bit_and(1); }
IndexerByte :: math_param(1, 1) { o, i, param | o[0] = i[0].shift_right_logical(param * 8).bit_and(0xFF); }
DivMod8 :: mask(8, DivMod64);
DivMod16 :: mask(16, DivMod64);
DivMod32 :: mask(32, DivMod64);
DivMod64 :: math(2, 2) { o, i |
    if i[1] == 0 {
        o[] = (0, 0);
    } else {
        a, b := udiv_mod(i[0], i[1]);
        o[0] = a;
        o[1] = b;
    };
};
SpriteDisplay :: device(0, 4,
    fn(it) => size_of(SpriteData) * 256 * 8,
    fn(world: *World, o: *Array(i64, 0), i: *Array(i64, 4), _0: i64, instance: i64, _1: bool) void = {
        command, sprite, position, size := (i[0], i[1], i[2], i[3]);
        data := world.storage.subslice(instance, size_of(SpriteData) * 256);
        data := SpriteData.reinterpret_bytes(data.interpret_as_bytes());
        @switch(command) {
            @case(1) => {
                s := data[sprite]&;
                s.src_x = position.shift_right_logical(16).trunc();
                s.src_y = position.trunc();
                s.w = size.trunc();
                s.h = size.shift_right_logical(16).trunc();
            };
            @case(2) => {
                s := data[sprite]&;
                s.dest_x = position.trunc();
                s.dest_y = position.shift_right_logical(16).trunc();
            };
            @default => ();
        };
    },
);
ConfigDelay :: todo();
Clock :: todo();
LevelInput1 :: Input1;
LevelInput8 :: todo();
LevelOutput1 :: Output1;
LevelOutput8 :: todo();
Ashr8 :: math(1, 2) { o, i | o[0] = sign_extend(i[0], 7).shift_right_arithmetic(i[1].bit_and(0b111)).bit_and(0xff); }
Ashr16 :: math(1, 2) { o, i | o[0] = sign_extend(i[0], 15).shift_right_arithmetic(i[1].bit_and(0b1111)).bit_and(0xffff); }
Ashr32 :: math(1, 2) { o, i | o[0] = (@as(u32) i[0].trunc()).shift_right_arithmetic(i[1]).zext(); }
Ashr64 :: math(1, 2) { o, i | o[0] = i[0].shift_right_arithmetic(i[1]); }
Bidirectional1 :: Bidirectional64;
