Template :: @struct {
    in_arity: i64;
    out_arity: i64;
    pins: []Pin = empty();
    name := "";
    body: Body;
    inputs_for_pure_eval: []i64 = empty(); 
    fid: ?FuncId = .None;
    callee := zeroed(rawptr);
    has_param := false;
    compute_storage: ?(@FnPtr(it: InstanceInfo) i64) = .None;
    switches: []SwitchablePin = empty();
    
    SwitchablePin :: @struct {
        value_output_index: i64;
        condition_input_index: i64;
    };
    
    Body :: @tagged(
        Unimplemented: void,
        Def: Str,  // use nand based implementation from ../defs.fr
        Native,
        // pins become memory that's accessed by the embedder (ie. ram/screen/keyboard)
        Device,
        IO,      // pins compile to function arguments
        Custom,
    );
};
Pin :: Ty(i64, i64);

templates :: {
    out := (*Template).list(ast_alloc());
    S := Type.scope_of(impl);
    for get_constants(S) { name |
        it := (*Template).get_constant(S, name)
            || @panic("expected % to be a function", str(name));
        
        if it.name != "" {
            it = ast_alloc().boxed(Template, it[]);
        };
        it.name = str(name);
        it.inputs_for_pure_eval = ast_alloc().alloc_init(i64, it.in_arity, fn(i) => i);
        
        if it.name.starts_with("Counter") || it.name == "Keyboard" || it.name.starts_with("Register") {
            it.inputs_for_pure_eval = empty();
        };
        
        if it.name == "LevelInputArch" || it.name.starts_with("Register") || it.name == "Rom" || it.name == "Timing" {
            it.switches = (@slice(@as(Template.SwitchablePin) (value_output_index = 0, condition_input_index = 0))).shallow_copy(ast_alloc());
        };
        if it.name == "RamFast" || it.name == "Ram" {
            it.switches = ast_alloc().alloc_init(Template.SwitchablePin, 4, fn(i) => (value_output_index = i, condition_input_index = 0));
            it.inputs_for_pure_eval = ast_alloc().alloc_init(i64, 1, fn(_) => 2);
        };
        if it.name == "RamDualLoad" {
            it.switches = ast_alloc().alloc_init(Template.SwitchablePin, 2, fn(i) => (value_output_index = i, condition_input_index = i*4));
            it.inputs_for_pure_eval = @const_slice(2, 5);
        };
        
        it.has_param = it.has_param || it.name.starts_with("Constant") || it.name.starts_with("Counter") || it.name == "Program" || it.name == "Console" || it.name.starts_with("Ram") || it.name.starts_with("Indexer") || it.name == "FileLoader" || it.name.ends_with("Display") || it.name == "Rom" || it.name == "Halt";
        
        if name == sym("Custom") {
            it.body = .Custom;
        };
        
        @if_let(it.fid) fn Some(fid) => {
            it.callee = current_compiler_context().get_jitted(fid);
        };
        
        if pin_layouts.get(it.name) { pins |
            it.pins = pins;
            @assert_eq(it.pins.len, it.in_arity + it.out_arity, "pin count (%)", it.name);
        };
        out&.push(it);
    };
    out.items()
};

#use("@/examples/circuit/eval.fr");
WireValue :: i64;

Settings :: @struct {
    Ram :: @bit_fields(
        storage_size := 58,
        word_size_index := 2,
        // there are four value input pins but only one store enable pin. 
        // most of the time a disconnected pin is treated as a zero value but a ram allows you to write one slot without extra zeroes.
        z_input_mask := 4,
    );
    Console :: @bit_fields(
        colour := 1, 
        font := 2, 
        ram_word_size_index := 2, 
        linked_ram_instance := 59,
    );
    Halt :: @bit_fields(
        circ_i := 32,
        gate_i := 32,
    );
};

fn word_size(param: Settings.Ram) i64 = (@const_slice(1, 2, 4, 8))[param.get(.word_size_index)];

math :: fn($out_arity: i64, $in_arity: i64, $fid: FuncId) *Template = {
    // TODO: infer a useful name
    wrapped := (fn(w: *World, o: *Array(WireValue, out_arity), i: *Array(WireValue, in_arity)) void = 
        @inline fid(o, i));
    ast_alloc().boxed(Template, (
        in_arity = in_arity, 
        out_arity = out_arity, 
        fid = (Some = wrapped),
        body = .Native,
    ))
};

math_param :: fn($out_arity: i64, $in_arity: i64, $fid: FuncId) *Template = {
    // TODO: infer a useful name
    wrapped := (fn(w: *World, o: *Array(WireValue, out_arity), i: *Array(WireValue, in_arity), param: i64) void = 
        @inline fid(o, i, param));
    ast_alloc().boxed(Template, (
        in_arity = in_arity, 
        out_arity = out_arity, 
        fid = (Some = wrapped),
        body = .Native,
        has_param = true,
    ))
};

mask :: fn($bits: i64, $child: *Template) *Template = {
    // TODO: infer a useful name
    wrapped :: (fn(w: *World, o: *Array(WireValue, child.out_arity), i: *Array(WireValue, child.in_arity)) void = {
        (@run child.fid.unwrap())(w, o, i);
        inline_range(0, child.out_arity) { I |
            o[I] = bit_and(o[I], 1.shift_left(bits) - 1);
        };
    });
    @assert(bits == 1 || bits == 8 || bits == 16 || bits == 32, "invalid mask(%)", bits);
    ast_alloc().boxed(Template, (
        in_arity = child.in_arity, 
        out_arity = child.out_arity,
        fid = @if(!child.fid.is_some(), .None, (Some = wrapped)),
        body = child.body,
        compute_storage = child.compute_storage,
    ))
};

// TODO: way too much paste
mask_param :: fn($bits: i64, $child: *Template) *Template = {
    wrapped :: (fn(w: *World, o: *Array(WireValue, child.out_arity), i: *Array(WireValue, child.in_arity), param: i64) void = {
        (@run child.fid.unwrap())(w, o, i, param);
        inline_range(0, child.out_arity) { I |
            o[I] = bit_and(o[I], 1.shift_left(bits) - 1);
        };
    });
    @assert(bits == 1 || bits == 8 || bits == 16 || bits == 32, "invalid mask(%)", bits);
    ast_alloc().boxed(Template, (
        in_arity = child.in_arity, 
        out_arity = child.out_arity,
        fid = @if(!child.fid.is_some(), .None, (Some = wrapped)),
        body = child.body,
        compute_storage = child.compute_storage,
    ))
};

from_defs :: fn(name: Str) *Template = {
    it := defs.components.find(fn(it) => it.name == name)
        || @panic("missing (%) in defs.fr", name);
    #use("@/examples/circuit/parse.fr");
    o, i := it.arity();
    ast_alloc().boxed(Template, (
        in_arity = i, 
        out_arity = o, 
        body = (Def = name),
    ))
}
fn with_pins(o: i64, i: i64, body: Template.Body) = {
    ast_alloc().boxed(Template, (
        in_arity = i, 
        out_arity = o, 
        body = body,
    ))
}

InstanceInfo :: @struct(param: i64);
fn with_pins(o: i64, i: i64, body: Template.Body, compute_storage: @FnPtr(it: InstanceInfo) i64, fid: FuncId) = {
    ast_alloc().boxed(Template, (
        in_arity = i, 
        out_arity = o, 
        body = body,
        fid = (Some = fid),
        compute_storage = (Some = compute_storage),
    ))
}

make_from_bytes :: fn($n: i64) *Template = math(1, n) { o, in |
    r := 0;
    inline_range(0, n) { i |
        r = r.bit_or(in[i].bit_and(0xFF).shift_left(i*8));
    };
    o[0] = r;
};
make_split_bytes :: fn($n: i64) *Template = math(n, 1) { o, i | 
    r := i[0];
    inline_range(0, n) { i |
        o[i] = r.shift_right_logical(i*8).bit_and(0xFF);
    };
};

todo :: fn() *Template = ast_alloc().boxed(Template, {
    ugh := zeroed(Template);
    ugh.fid = .None;
    ugh.compute_storage = .None;
    ugh
});

fn get_native(a: *Template) FuncId = {
    a.fid || @panic("bad get_native (%)", a.name)
}

KeyboardData :: @struct(value: u16, up: bool, have_next: bool, want_next: bool, _ := zeroed(Array(u8, 3)));

// TODO: should be more careful about data sizes if they don't match expected. 
//       but would know that when compiling so maybe just insert casts aot, not in the impls here. 
//       stuff like what happens if you input something bigger than 8 bits into a Maker64. 
// TODO: on riscv they're annoying about sign extending 32 bit values so extra important to mask the inputs
// TODO: use 32 bit instructions instead of bit_and(0xFFFFFFFF)
// TODO: the registers/program here use more packed storage than the ones in ../defs.fr 
//       so either need to unify them or have the ui know about both for showing ram/disassembly. 
// TODO: move the impls of storage out? because they're different enough that it's annoying to have to search for them. 
// TODO: carry flag, mul high. 

// these are in order by their ComponentKind value in the circuit.data format. 
impl :: @struct {
_0 :: todo();
Off :: math(1, 0) { o, i | o[0] = 0; };
On :: math(1, 0) { o, i | o[0] = 1; };
Buffer1 :: todo();
Not :: math(1, 1) { o, i | o[0] = i[0].bit_xor(1); };
And :: math(1, 2) { o, i | o[0] = i[0].bit_and(i[1]); };
And3 :: math(1, 3) { o, i | o[0] = i[0].bit_and(i[1]).bit_and(i[2]); };
Nand :: math(1, 2) { o, i | o[0] = i[0].bit_and(i[1]).bit_xor(1); };
Or :: math(1, 2) { o, i | o[0] = i[0].bit_or(i[1]); };
Or3 :: math(1, 3) { o, i | o[0] = i[0].bit_or(i[1]).bit_or(i[2]); };
Nor :: mask(1, Nor64);
Xor :: math(1, 2) { o, i | o[0] = i[0].bit_xor(i[1]); };
Xnor :: mask(1, Xnor64);
Counter8 :: mask_param(8, Counter64);
VirtualCounter8 :: todo();
Counter64 :: with_pins(1, 2, .Device, 
    fn(_) => 8*8,
    fn(world: *World, o: *Array(i64, 1), i: *Array(i64, 2), param: i64) void = {
        value, set := (i[0], i[1] != 0);
        slot := world.storage[world.instance]&;
        o[0] = slot[]; 
        if !world.doing_pre_read {
            slot[] = @if(set, value, slot[] + param);
        };
        world.instance += 1;
    },
);
VirtualCounter64 :: todo();
Ram8 :: todo();
VirtualRam8 :: todo();
_19 :: todo();
_20 :: todo();
Stack :: todo();
VirtualStack :: todo();
Register8 :: Register64;
