ProbeMemoryWord :: todo();
AndOrLatch :: todo();
NandNandLatch :: todo();
NorNorLatch :: todo();
LessU8 :: LessU64;
LessI8 :: math(1, 2) { o, i | o[0] = int(lt(i[0].sign_extend(7), i[1].sign_extend(7))); }
DotMatrixDisplay :: device(0, 4, 
    fn(_) => 48*32*2,
    fn(world: *World, o: *Array(i64, 0), i: *Array(i64, 4), param: i64, instance: i64, _: bool) void = {
        coloumn_major_pixels := param == 1;  // TODO
        n := 48*32*2/64;
        buf := world.storage.subslice(instance, n);
        enable, pixel_mask, colour := (i[1] != 0 && i[3] != 0, i[0], i[2]);
        @if(!enable) return();
        flush := pixel_mask.shift_right_logical(56) == 1;
        
        buf := u32.reinterpret_bytes(buf.interpret_as_bytes());
        active, scratch := (buf.subslice(0, 48), buf.subslice(48, 48));
        // TODO: for_bits
        if coloumn_major_pixels {
            range(0, 48) { i |
                y, x := i.div_mod(6);  // :SLOW
                I := x*8+y;
                if pixel_mask.bit_and(1.shift_left(I+8)) != 0 {
                    scratch[i] = colour.trunc();
                };
            };
        } else {
            range(0, 48) { i |
                if pixel_mask.bit_and(1.shift_left(i+8)) != 0 {
                    scratch[i] = colour.trunc();
                };
            };
        };
        
        if flush {
            active.copy_from(scratch);
        };
    },
);
// each bit enables one segment
SegmentDisplay :: device(0, 2, 
    fn(_) => 64,
    fn(world: *World, o: *Array(i64, 0), i: *Array(i64, 2), param: i64, instance: i64, doing_pre_read: bool) void = {
        world.storage[instance] = @if(i[1] == 0, 0, i[0]);
    },
);
