Shl8 :: math(1, 2) { o, i | o[0] = i[0].shift_left(i[1].bit_and(0b111)).bit_and(0xff); }
Shr8 :: math(1, 2) { o, i | o[0] = i[0].shift_right_logical(i[1].bit_and(0b111)); }
Constant64 :: math_param(1, 0) { o, i, param | o[0] = param; }
Not64 :: math(1, 1) { o, i | o[0] = bit_not(i[0]); };
Or64 :: Or;
And64 :: And;
Xor64 :: Xor;
Neg64 :: math(1, 1) { o, i | o[0] = -i[0]; };
Add64 :: math(2, 3) { o, i | 
    r := i[1] + i[2];
    o[0] = r + i[0]; 
    o[1] = int(r.ult(i[1]).or((i[0] == 1).and(o[0] == 0)));
};
// this paramater is a tad silly but i don't want to teach the backend about umulh just for this one thing 
// and doing it in assembly isn't inlinable so since often it won't be used, note that in a way that will be 
// const-known after inlining so the branch can be folded away and don't have to spill things when just using the low part. 
// (i don't have a way to promise the compiler that an AsmFunction is pure / no caller saved registers).  
Mul64 :: math_param(2, 2) { o, i, param |
    param: Settings.Mul64 = (repr = param.bitcast());
    o[0] = i[0] * i[1]; 
    o[1] = @if(param.get(.need_high) == 1, multiply_high_u64(i[0], i[1]), 0);
};
Equal64 :: math(1, 2) { o, i | o[0] = int(eq(i[0], i[1])); };
LessU64 :: math(1, 2) { o, i | o[0] = int(ult(i[0], i[1])); };
LessI64 :: math(1, 2) { o, i | o[0] = int(lt(i[0], i[1])); };
Shl64 :: math(1, 2) { o, i | o[0] = i[0].shift_left(i[1]); };
Shr64 :: math(1, 2) { o, i | o[0] = i[0].shift_right_logical(i[1]); };
Mux64 :: Mux8;
Switch64 :: math(1, 2) { o, i | panic("unreachable: switch is magic in the compiler"); };
