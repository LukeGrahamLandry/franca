pin_layouts :: @static @parse_pin_layouts(
(("Or8", "Equal8", "LessU8", "Xor8", "And8", "Equal64", "Counter8", "Counter16", "Counter32", "Counter64", "Or64", "And64", "Xor64", "LessU64", "LessI64"),
    ((1, 0), (-1, 0), (-1, -1))),
(("Maker16"),
    ((1, 0), (-1, -1), (-1, 0))),
(("Shl8", "Shr8", "Shl64", "Shr64", "Shl16", "Shr16", "Shl32", "Shr32", "Rol8", "Rol16", "Rol32", "Rol64", "Ror8", "Ror16", "Ror32", "Ror64", "Ashr8", "Ashr16", "Ashr32", "Ashr64"),
    ((1, -1), (-1, 0), (-1, -1))),
(("Switch1", "Switch8", "Switch16", "Switch32", "Switch64"),
    ((1, 0), (-1, 0), (0, -1))),
(("Mux8"),
    ((1, 0), (-1, 1), (-1, 0), (-1, -1))),
(("On", "Off", "Constant8", "Constant16", "Constant32", "Constant64"),
    ((1, 0))),
(("Maker8", "Maker64"),
    ((1, 0), (-1, -3), (-1, -2), (-1, -1), (-1, 0), (-1, 1), (-1, 2), (-1, 3), (-1, 4))),
(("Splitter8", "Splitter64"),
    ((1, -3), (1, -2), (1, -1), (1, 0), (1, 1), (1, 2), (1, 3), (1, 4), (-1, 0))),
(("Add8", "Add64"),
    ((1, -1), (1, 0), (-1, -1), (-1, 1), (-1, 0))),
(("DivMod64", "Mul64"),
    ((1, -1), (1, 0), (-1, 0), (-1, -1))),
(("And3", "Or3"), 
    ((2, 0), (-1, 1), (-1, 0), (-1, -1))),
(("Register8"), 
    ((1, 0), (-1, -1), (-1, 0), (-1, 1))),
(("Register64"), 
    ((3, 0), (-3, -1), (-3, 0), (-3, 1))),
(("Decoder3"),
    ((1, -3), (1, -2), (1, -1), (1, 0), (1, 1), (1, 2), (1, 3), (1, 4), (-1, -3), (-1, -2), (-1, -1), (0, -4))),
