Template :: @struct {
    in_arity: i64;
    out_arity: i64;
    pins: []Pin = empty();
    bit_width: []u8 = empty();
    name := "";
    body: Body;
    inputs_for_pure_eval: []i64 = empty(); 
    fid: ?FuncId = .None;
    callee := zeroed(rawptr);
    has_param := false;
    compute_storage: ?(@FnPtr(it: InstanceInfo) i64) = .None;
    switches: []SwitchablePin = empty();
    kind := zeroed(import("@/examples/circuit/parse.fr")'ComponentId);
    
    SwitchablePin :: @struct {
        value_output_index: i64;
        condition_input_index: i64;
    };
    
    Body :: @enum(Unimplemented, Native, IO, Custom);
};
Pin :: Ty(i64, i64);
Tc :: import("@/examples/circuit/tc/load.fr");

collect_templates :: fn($impl: Type, $g: Tc.GateGroup, $pin_layouts: ~A, $body: FuncId) []*Template #where = {
    out := (*Template).list(ast_alloc());
    S := Type.scope_of(impl);
    i := 0;
    for get_constants(S) { name |
        it := (*Template).get_constant(S, name)
            || @panic("expected % to be a function", str(name));
        it.kind = (id = trunc(i + component_offset(g))); i += 1;
        k := Tc'gate_name(it.kind, g);
        
        if it.name != "" {
            it = ast_alloc().boxed(Template, it[]);
        };
        it.name = str(name);
        it.inputs_for_pure_eval = ast_alloc().alloc_init(i64, it.in_arity, fn(i) => i);
        
        if k == .Custom {
            it.body = .Custom;
        };
        
        @if_let(it.fid) fn Some(fid) => {
            it.callee = current_compiler_context().get_jitted(fid);
        };
        
        if pin_layouts.get(k) { pins |
            it.pins = pins;
        };
        body(it, k);
        if it.pins.len != 0 && g == .Tc1 {
            @assert_eq(it.pins.len, it.in_arity + it.out_arity, "pin count (%)", it.name);
            @assert_eq(it.bit_width.len, it.pins.len, "width count (%)", it.name);
        }
        out&.push(it);
    };
    out.items()
};

templates :: collect_templates(impl, .Tc1, pin_layouts) { it, k |
        if it.name.starts_with("Counter") || k == .Keyboard || it.name.starts_with("Register") || it.name.starts_with("DelayLine") || k == .BitMemory {
            it.inputs_for_pure_eval = empty();
        };
        
        if k == .LevelInputArch || it.name.starts_with("Register") || k == .Rom || k == .Timing || k == .FileLoader {
            it.switches = (@slice(@as(Template.SwitchablePin) (value_output_index = 0, condition_input_index = 0))).shallow_copy(ast_alloc());
        };
        if k == .RamFast || k == .Ram {
            it.switches = ast_alloc().alloc_init(Template.SwitchablePin, 4, fn(i) => (value_output_index = i, condition_input_index = 0));
            it.inputs_for_pure_eval = ast_alloc().alloc_init(i64, 1, fn(_) => 2);
        };
        if k == .RamDualLoad {
            it.switches = ast_alloc().alloc_init(Template.SwitchablePin, 2, fn(i) => (value_output_index = i, condition_input_index = i*4));
            it.inputs_for_pure_eval = @const_slice(2, 5);
        };
        
        it.has_param = it.has_param || it.name.starts_with("Constant") || it.name.starts_with("Counter") 
            || it.name.starts_with("Ram") || it.name.starts_with("Indexer") || it.name.ends_with("Display") 
            || @is(k, .Program, .Console, .FileLoader, .Rom, .Halt, .Keyboard, .Mul64);
        
        it.bit_width = get_width_data(it);
};

templates2 :: collect_templates(impl2, .Tc2, pin_layouts2) { it, k |
    it.has_param = it.has_param || @is(k, .Level_gate);
};

#use("@/examples/circuit/eval.fr");
WireValue :: i64;

Settings :: @struct {
    Ram :: @bit_fields(
        storage_size := 60,
        word_size_index := 3,
        is_program := 1,
    );
    Console :: @bit_fields(
        colour := 1, 
        font := 2, 
        linked := 1,
        linked_ram_instance := 60,
    );
    Halt :: @bit_fields(
        circ_i := 32,
        gate_i := 32,
    );
    Mul64 :: @bit_fields(need_high := 1, _ := 63);
};

fn word_size(param: Settings.Ram) i64 = 1.shift_left(param.get(.word_size_index)); // [1, 2, 4, 8, 16, 32]

math :: fn($out_arity: i64, $in_arity: i64, $fid: FuncId) *Template = {
    // TODO: infer a useful name
    wrapped := (fn(w: *World, o: *Array(WireValue, out_arity), i: *Array(WireValue, in_arity)) void = 
        @inline fid(o, i));
    ast_alloc().boxed(Template, (
        in_arity = in_arity, 
        out_arity = out_arity, 
        fid = (Some = wrapped),
        body = .Native,
    ))
};

math_param :: fn($out_arity: i64, $in_arity: i64, $fid: FuncId) *Template = {
    // TODO: infer a useful name
    wrapped := (fn(w: *World, o: *Array(WireValue, out_arity), i: *Array(WireValue, in_arity), param: i64) void = 
        @inline fid(o, i, param));
    ast_alloc().boxed(Template, (
        in_arity = in_arity, 
        out_arity = out_arity, 
        fid = (Some = wrapped),
        body = .Native,
        has_param = true,
    ))
};

mask :: fn($bits: i64, $child: *Template) *Template = {
    // TODO: infer a useful name
    wrapped :: (fn(w: *World, o: *Array(WireValue, child.out_arity), i: *Array(WireValue, child.in_arity)) void = {
        @inline ((@run child.fid.unwrap())(w, o, i));
        inline_range(0, child.out_arity) { I |
            o[I] = bit_and(o[I], 1.shift_left(bits) - 1);
        };
    });
    @assert(bits == 1 || bits == 8 || bits == 16 || bits == 32, "invalid mask(%)", bits);
    ast_alloc().boxed(Template, (
        in_arity = child.in_arity, 
        out_arity = child.out_arity,
        fid = @if(!child.fid.is_some(), .None, (Some = wrapped)),
        body = child.body,
        compute_storage = child.compute_storage,
    ))
};

// TODO: way too much paste
mask_param :: fn($bits: i64, $child: *Template) *Template = {
    wrapped :: (fn(w: *World, o: *Array(WireValue, child.out_arity), i: *Array(WireValue, child.in_arity), param: i64, instance: i64, doing_pre_read: bool) void = {
        @inline ((@run child.fid.unwrap())(w, o, i, param, instance, doing_pre_read));
        inline_range(0, child.out_arity) { I |
            o[I] = bit_and(o[I], 1.shift_left(bits) - 1);
        };
    });
    @assert(bits == 1 || bits == 8 || bits == 16 || bits == 32, "invalid mask(%)", bits);
    ast_alloc().boxed(Template, (
        in_arity = child.in_arity, 
        out_arity = child.out_arity,
        fid = @if(!child.fid.is_some(), .None, (Some = wrapped)),
        body = child.body,
        compute_storage = child.compute_storage,
    ))
};

fn io(o: i64, i: i64) = {
    ast_alloc().boxed(Template, (in_arity = i,  out_arity = o, body = .IO))
}

InstanceInfo :: @struct(param: i64);
fn device(o: i64, i: i64, compute_storage: @FnPtr(it: InstanceInfo) i64, fid: FuncId) = {
    ast_alloc().boxed(Template, (
        in_arity = i, 
        out_arity = o, 
        body = .Native,
        fid = (Some = fid),
        compute_storage = (Some = compute_storage),
    ))
}

make_from_bytes :: fn($n: i64) *Template = math(1, n) { o, in |
    r := 0;
    inline_range(0, n) { i |
        r = r.bit_or(in[i].shift_left(i*8));
    };
    o[0] = r;
};
make_split_bytes :: fn($n: i64) *Template = math(n, 1) { o, i | 
    r := i[0];
    inline_range(0, n) { i |
        o[i] = r.shift_right_logical(i*8).bit_and(0xFF);
    };
};

todo :: fn() *Template = ast_alloc().boxed(Template, {
    ugh := zeroed(Template);
    ugh.fid = .None;
    ugh.compute_storage = .None;
    ugh
});

fn get_native(a: *Template) FuncId = {
    a.fid || @panic("bad get_native (%)", a.name)
}

KeyboardData :: @struct(up: bool, prev_up: bool, value: u16, prev_value: u16, have_next: u8, valid: bool);
SpriteData :: @struct(src_x: u16, src_y: u16, w: u16, h: u16, dest_x: u16, dest_y: u16);

// these are in order by their ComponentKind value in the circuit.data format. 
impl :: @struct {
_0 :: todo();
Off :: math(1, 0) { o, i | o[0] = 0; };
On :: math(1, 0) { o, i | o[0] = 1; };
Buffer1 :: todo();
Not :: math(1, 1) { o, i | o[0] = i[0].bit_xor(1); };
And :: math(1, 2) { o, i | o[0] = i[0].bit_and(i[1]); };
And3 :: math(1, 3) { o, i | o[0] = i[0].bit_and(i[1]).bit_and(i[2]); };
Nand :: math(1, 2) { o, i | o[0] = i[0].bit_and(i[1]).bit_xor(1); };
Or :: math(1, 2) { o, i | o[0] = i[0].bit_or(i[1]); };
Or3 :: math(1, 3) { o, i | o[0] = i[0].bit_or(i[1]).bit_or(i[2]); };
Nor :: mask(1, Nor64);
Xor :: math(1, 2) { o, i | o[0] = i[0].bit_xor(i[1]); };
Xnor :: mask(1, Xnor64);
Counter8 :: mask_param(8, Counter64);
VirtualCounter8 :: todo();
Counter64 :: device(1, 2, 
    fn(_) => 8*8,
    fn(world: *World, o: *Array(i64, 1), i: *Array(i64, 2), param: i64, instance: i64, doing_pre_read: bool) void = {
        value, set := (i[0], i[1] != 0);
        slot := world.storage[instance]&;
        o[0] = slot[]; 
        if !doing_pre_read {
            slot[] = @if(set, value, slot[] + param);
        };
    },
);
VirtualCounter64 :: todo();
Ram8 :: todo();
VirtualRam8 :: todo();
_19 :: todo();
_20 :: todo();
Stack :: todo();
VirtualStack :: todo();
Register8 :: Register64;
