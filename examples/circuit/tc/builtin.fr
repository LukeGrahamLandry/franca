Mux8 :: math(1, 3) { o, i | o[0] = @if(i[0] == 0, i[1], i[2]); };
Decoder1 :: math(2, 1) { o, i | o[] = (int(i[0] == 1), int(i[0] == 0)); };
Decoder3 :: from_defs("decode3");
Constant8 :: todo();
Not8 :: math(1, 1) { o, i | o[0] = bit_not(i[0]); };
Or8 :: Or;
And8 :: And;
Xor8 :: Xor;
Equal8 :: math(1, 2) { o, i | o[0] = int(i[0] == i[1]); };
_41 :: todo();
_42 :: todo();
Neg8 :: math(1, 1) { o, i | o[0] = bit_and(-i[0], 255); } 
Add8 :: math(2, 2) { o, i | 
    r := i[0] + i[1];
    o[0] = bit_and(r, 255); 
    o[1] = int(r >= 256);
};
Mul8 :: todo();
Splitter8 :: math(8, 1) { o, i | 
    r := i[0];
    inline_range(0, 8) { i |
        o[i] = int(r.bit_and(1.shift_left(i)) != 0);
    };
};
Maker8 :: math(1, 8) { o, in |
    r := 0;
    inline_range(0, 8) { i |
        r = r.bit_or(in[i].shift_left(i));
    };
    o[0] = r;
};
Splitter64 :: math(8, 1) { o, i | 
    r := i[0];
    inline_range(0, 8) { i |
        o[i] = r.shift_right_logical(i*8).bit_and(0xFF);
    };
};
Maker64 :: math(1, 8) { o, in |
    r := 0;
    inline_range(0, 8) { i |
        r = r.bit_or(in[i].shift_left(i*8));
    };
    o[0] = r;
};
