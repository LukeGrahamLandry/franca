    ((-2, 0))),
(("Mux64", "Mux16", "Mux32"),
    ((1, 0), (-1, 1), (-1, 0), (-1, -1))),
(("Register32", "Register16"),
    ((2, 0), (-2, -1), (-2, 0), (-2, 1))),
(("RamFast", "Ram", "RamLatency"),
    ((13, -7), (13, -6), (13, -5), (13, -4), (-13, -7), (-13, -6), (-13, -5), (-13, -4), (-13, -3), (-13, -2), (-13, -1))),
(("Output8", "LevelOutput1Car", "LevelOutput1Sum", "Output1", "Halt", "LevelOutput1"),
    ((-1, 0))),
(("Not64", "Neg64", "Not32", "Neg32", "IndexerBit", "Not", "Not8", "Neg8", "DelayLine1"),
    ((1, 0), (-1, 0))),
(("Output64z"),
    ((-3, 0), (0, 2))),
(("LevelOutputArch", "Output1z", "Output8z", "Output16z", "Output32z"),
    ((-1, 0), (0, 1))),
(("Nor", "Xor", "Xnor", "And", "Nand", "Or", "BitMemory", "Or32", "And32", "Xor32", "Nand8", "Nor8", "Xnor8", "Nand16", "Nor16", "Xnor16", "Nand32", "Nor32", "Xnor32", "Nand64", "Nor64", "Xnor64"),
    ((2, 0), (-1, 1), (-1, -1))),
);

parse_pin_layouts :: fn(e: FatExpr) FatExpr #macro = {
    result: HashMap(Str, []Pin) = init(ast_alloc());
    each e&.items() { entry |
        e := entry.items();
        names, pins := (e[0]&, e[1]&);
        pins_value := collect_values(Pin, pins);
        names_value := collect_values(Str, names);
        for names_value { name |
            prev := result&.insert(name, pins_value);
            @ct_assert(prev.is_none(), entry.loc, "% used twice in pin_layouts", name);
        };
    };
    collect_values :: fn($T: Type, e: *FatExpr) []T #generic = {
        es := e.items();
        out := T.list(es.len, ast_alloc());
        if !es[0].expr&.is(.Tuple) && !es[0].expr&.is(.String) {
            out&.push(T.const_eval(e[]));
        } else {
            each es { e |
                out&.push(T.const_eval(e[]));
            };
        }
        out.items()
    }
    @literal result.raw
};
