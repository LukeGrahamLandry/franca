Template :: @struct {
    in_arity: i64;
    out_arity: i64;
    pins: []Ty(i64, i64) = empty();
    name := "";
    body: Body;
    inputs_for_pure_eval: []i64 = empty(); 
    fid: ?FuncId = .None;
    callee := zeroed(rawptr);
    storage_count := 0;
    
    Body :: @tagged(
        Unimplemented: void,
        Def: Str,  // use nand based implementation from ../defs.fr
        Native,
        Constant,
        // pins become memory that's accessed by the embedder (ie. ram/screen/keyboard)
        Device,
        IO,      // pins compile to function arguments
        Custom,
    );
};

templates :: {
    X :: const_slice;
    y_shape :: @X((2, 0), (-1, 1), (-1, -1));
    tri_shape :: @X((2, 0), (-1, 1), (-1, 0), (-1, -1));
    y_shape8 :: @X((1, 0), (-1, 0), (-1, -1));
    h_line :: @X((1, 0), (-1, 0));
    line8 :: @X((1, -3), (1, -2), (1, -1), (1, 0), (1, 1), (1, 2), (1, 3), (1, 4), (-1, 0));

    out := (*Template).list(ast_alloc());
    S := Type.scope_of(impl);
    for get_constants(S) { name |
        it := (*Template).get_constant(S, name)
            || @panic("expected % to be a function", str(name));
        
        if it.name != "" {
            it = ast_alloc().boxed(Template, it[]);
        };
        it.name = str(name);
        it.inputs_for_pure_eval = ast_alloc().alloc_init(i64, it.in_arity, fn(i) => i);
        
        if it.name.starts_with("Register") || it.name.starts_with("Counter") {
            it.inputs_for_pure_eval = empty();
        };
        
        if it.name == "Or8" {
            it.pins = y_shape8;
        };
        if it.pins.len == 0 {
        if it.in_arity == 2 && it.out_arity == 1 {
            it.pins = y_shape;
            if it.name.starts_with("Switch") {
                it.pins = @X((1, 0), (-1, 0), (0, -1));
            };
        };
        if it.in_arity == 3 && it.out_arity == 1 {
            it.pins = tri_shape;
        };
        if it.name.starts_with("Counter") {
            it.pins = @const_slice((1, 0), (-1, 0), (-1, -1));
        };
        
        if it.name == "On" || it.name == "Off" {
            x :: (1, 0);
            it.pins = @X(x);
        };
        
        if it.in_arity == 1 && it.out_arity == 1 {
            it.pins = h_line;
        };
        if it.in_arity == 1 && it.out_arity == 8 {
            it.pins = line8;
        };
        if it.name == "Decoder3" {
            it.pins = cat(line8.slice(0, line8.len() - 1), @X((-1, -3), (-1, -2), (-1, -1), (0, -4)));
        };
        if it.name == "Add8" {
            it.pins = @X((1, -1), (1, 0), (-1, -1), (-1, 1), (-1, 0));
        };
        };
        
        if name == sym("Custom") {
            it.body = .Custom;
        };
        if it.name.starts_with("Constant") {
            it.body = .Constant;
        };
        
        @if_let(it.fid) fn Some(fid) => {
            it.callee = current_compiler_context().get_jitted(fid);
        };
        out&.push(it);
        
        if it.pins.len != 0 {
            @assert_eq(it.pins.len, it.in_arity + it.out_arity, "pin count (%)", it.name);
        }
    };
    out.items()
};

cat :: fn(a: []Ty(i64, i64), b: []Ty(i64, i64)) []Ty(i64, i64) = {
    c := ast_alloc().alloc_uninit(Ty(i64, i64), a.len + b.len);
    c.slice(0, a.len).copy_from(a);
    c.rest(a.len).copy_from(b);
    c
};

#use("@/examples/circuit/eval.fr");
WireValue :: i64;

math :: fn($out_arity: i64, $in_arity: i64, $fid: FuncId) *Template = {
    // TODO: infer a useful name
    wrapped := (fn(w: *World, o: *Array(WireValue, out_arity), i: *Array(WireValue, in_arity)) void = 
        @inline fid(o, i));
    ast_alloc().boxed(Template, (
        in_arity = in_arity, 
        out_arity = out_arity, 
        fid = (Some = wrapped),
        body = .Native,
    ))
};
mask :: fn($bits: i64, $child: *Template) *Template = {
    // TODO: infer a useful name
    wrapped :: (fn(w: *World, o: *Array(WireValue, child.out_arity), i: *Array(WireValue, child.in_arity)) void = {
        (@run child.fid.unwrap())(w, o, i);
        inline_range(0, child.out_arity) { I |
            o[I] = bit_and(o[I], 1.shift_left(bits) - 1);
        };
    });
    ast_alloc().boxed(Template, (
        in_arity = child.in_arity, 
        out_arity = child.out_arity,
        fid = @if(!child.fid.is_some(), .None, (Some = wrapped)),
        body = child.body,
        storage_count = child.storage_count,
    ))
};
from_defs :: fn(name: Str) *Template = {
    it := defs.components.find(fn(it) => it.name == name)
        || @panic("missing (%) in defs.fr", name);
    #use("@/examples/circuit/parse.fr");
    o, i := it.arity();
    ast_alloc().boxed(Template, (
        in_arity = i, 
        out_arity = o, 
        // todo: hook it up and also need to make everything else use i64 as wire value
        body = (Def = name),
    ))
}
fn with_pins(o: i64, i: i64, body: Template.Body, pins: []Ty(i64, i64)) = {
    @assert_eq(o + i, pins.len, "wire arity typo");
    ast_alloc().boxed(Template, (
        in_arity = i, 
        out_arity = o, 
        body = body,
        pins = pins,
    ))
}

fn with_pins(o: i64, i: i64, body: Template.Body, pins: []Ty(i64, i64), storage_count: i64, fid: FuncId) = {
    @assert_eq(o + i, pins.len, "wire arity typo");
    ast_alloc().boxed(Template, (
        in_arity = i, 
        out_arity = o, 
        body = body,
        pins = pins,
        fid = (Some = fid),
        storage_count = storage_count.ualign_to(64).udiv(64),
    ))
}


todo :: fn() *Template = ast_alloc().boxed(Template, {
    ugh := zeroed(Template);
    ugh.fid = .None;
    ugh
});

fn get_native(a: *Template) FuncId = {
    a.fid || @panic("bad get_native (%)", a.name)
}

// TODO: should be more careful about data sizes if they don't match expected. 
//       but would know that when compiling so maybe just insert casts aot, not in the impls here. 
//       stuff like what happens if you input something bigger than 8 bits into a Maker64. 
// TODO: use 32 bit instructions instead of bit_and(0xFFFFFFFF)
// TODO: all the io devices should just be treated like a memory and then the outer simulation deals with it between ticks. 
//       the actual input/output pins need to be special to compile custom components. 
// TODO: check if their shift/rot is supposed to wrap the amount like mine do
// TODO: the registers/program here use more packed storage than the ones in ../defs.fr 
//       so either need to unify them or have the ui know about both for showing ram/disassembly. 
// TODO: move the impls of storage out? because they're different enough that it's annoying to have to search for them. 

// these are in order by their ComponentKind value in the circuit.data format. 
impl :: @struct {
_0 :: todo();
Off :: math(1, 0) { o, i | o[0] = 0; };
On :: math(1, 0) { o, i | o[0] = 1; };
Buffer1 :: todo();
Not :: math(1, 1) { o, i | o[0] = int(i[0] == 0); };
And :: math(1, 2) { o, i | o[0] = i[0].bit_and(i[1]); };
And3 :: math(1, 3) { o, i | o[0] = i[0].bit_and(i[1]).bit_and(i[2]); };
Nand :: math(1, 2) { o, i | o[0] = i[0].bit_and(i[1]).bit_xor(1); };
Or :: math(1, 2) { o, i | o[0] = i[0].bit_or(i[1]); };
Or3 :: math(1, 3) { o, i | o[0] = i[0].bit_or(i[1]).bit_or(i[2]); };
Nor :: mask(2, Nor64);
Xor :: math(1, 2) { o, i | o[0] = i[0].bit_xor(i[1]); };
Xnor :: mask(2, Xnor64);
// the defs one has the bits spread out in an annoying way
//Counter8 :: from_defs("counter");
Counter8 :: mask(8, Counter64);
VirtualCounter8 :: todo();
Counter64 :: with_pins(1, 2, .Device, 
    @const_slice((1, 0), (-1, 0), (-1, -1)),
    8*8,
    fn(world: *World, o: *Array(i64, 1), i: *Array(i64, 2)) void = {
        value, set := (i[0], i[1] != 0);
        @debug_assert_ult(world.instance, world.storage.len, "must preallocate storage_count");
        slot := world.storage[world.instance]&;
        o[0] = slot[]; 
        if !world.doing_pre_read {
            if set {
                slot[] = value;
            } else {
                slot[] += 1;
            };
        };
        world.instance += 1;
    },
);
VirtualCounter64 :: todo();
Ram8 :: todo();
VirtualRam8 :: todo();
_19 :: todo();
_20 :: todo();
Stack :: todo();
VirtualStack :: todo();
Register8 :: Register64;
VirtualRegister8 :: todo();
Register8Red :: todo();
VirtualRegister8Red :: todo();
Register8RedPlus :: todo();
VirtualRegister8RedPlus :: todo();
Register64 :: with_pins(1, 3, .Device, 
    @const_slice((1, 0), (-1, -1), (-1, 0), (-1, 1)),
    8*8,
    fn(world: *World, o: *Array(i64, 1), i: *Array(i64, 3)) void = {
        load, save, value := (i[0] != 0, i[1] != 0, i[2]);
        @debug_assert_ult(world.instance, world.storage.len, "must preallocate storage_count");
        slot := world.storage[world.instance]&;
        o[0] = slot[];  // TODO: need to do something about unpowered when !load. 
        if !world.doing_pre_read && save {
            slot[] = value;
        };
        world.instance += 1;
    },
);
VirtualRegister64 :: todo();
Switch8 :: Switch64;
Mux8 :: math(1, 3) { o, i | o[0] = @if(i[0] == 0, i[1], i[2]); };
Decoder1 :: math(2, 1) { o, i | o[] = (int(i[0] == 1), int(i[0] == 0)); };
Decoder3 :: math(8, 4) { o, i | 
    n := @or(i[0], i[1].shift_left(1), i[2].shift_left(2));
    n := @if(i[3] == 0, n, -1);  // disable bit
    inline_range(0, 8) { i |
        o[i] = int(n == i);
    };
};
Constant8 :: todo();
Not8 :: math(1, 1) { o, i | o[0] = bit_not(i[0]); };
Or8 :: Or;
And8 :: And;
Xor8 :: Xor;
Equal8 :: math(1, 2) { o, i | o[0] = int(i[0] == i[1]); };
_41 :: todo();
_42 :: todo();
Neg8 :: math(1, 1) { o, i | o[0] = bit_and(-i[0], 255); } 
Add8 :: math(2, 3) { o, i | 
    r := i[0]*256 + i[1] + i[2];
    o[0] = bit_and(r, 255); 
    o[1] = int(r >= 256);
};
Mul8 :: todo();
Splitter8 :: math(8, 1) { o, i | 
    r := i[0];
    inline_range(0, 8) { i |
        o[i] = int(r.bit_and(1.shift_left(i)) != 0);
    };
};
Maker8 :: math(1, 8) { o, in |
    r := 0;
    inline_range(0, 8) { i |
        r = r.bit_or(in[i].shift_left(i));
    };
    o[0] = r;
};
Splitter64 :: math(8, 1) { o, i | 
    r := i[0];
    inline_range(0, 8) { i |
        o[i] = r.shift_right_logical(i*8).bit_and(0xFF);
    };
};
Maker64 :: math(1, 8) { o, in |
    r := 0;
    inline_range(0, 8) { i |
        r = r.bit_or(in[i].shift_left(i*8));
    };
    o[0] = r;
};
