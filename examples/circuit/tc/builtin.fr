// TODO: test these
Rol8 :: math(1, 2) { o, i | r := i[1].bit_and(0b111); o[0] = i[0].shift_left(r).bit_or(i[0].shift_right_logical(8 - r)).bit_and(0xff); }
Rol16 :: math(1, 2) { o, i | r := i[1].bit_and(0b1111); o[0] = i[0].shift_left(r).bit_or(i[0].shift_right_logical(16 - r)).bit_and(0xffff); }
Rol32 :: math(1, 2) { o, i | o[0] = (@as(u32) i[0].trunc()).rotate_left(i[1]).zext(); }
Rol64 :: math(1, 2) { o, i | o[0] = i[0].rotate_left(i[1]); }
Ror8 :: math(1, 2) { o, i | r := i[1].bit_and(0b111); o[0] = i[0].shift_left(8 - r).bit_or(i[0].shift_right_logical(r)).bit_and(0xff); }
Ror16 :: math(1, 2) { o, i | r := i[1].bit_and(0b1111); o[0] = i[0].shift_left(16 - r).bit_or(i[0].shift_right_logical(r)).bit_and(0xffff); }
Ror32 :: math(1, 2) { o, i | o[0] = (@as(u32) i[0].trunc()).rotate_right(i[1]).zext(); }
Ror64 :: math(1, 2) { o, i | o[0] = i[0].rotate_right(i[1]); }
IndexerBit :: math_param(1, 1) { o, i, param | o[0] = int(i[0].bit_and(1.shift_left(param)) != 0); }
IndexerByte :: math_param(1, 1) { o, i, param | o[0] = i[0].shift_right_logical(param * 8).bit_and(0xFF); }
DivMod8 :: mask(8, DivMod64);
DivMod16 :: mask(16, DivMod64);
DivMod32 :: mask(32, DivMod64);
DivMod64 :: math(2, 2) { o, i |
    if i[1] == 0 || (i[0] == MIN_i64 && i[1] == -1) {
        o[] = (0, 0);
    } else {
        a, b := div_mod(i[0], i[1]);
        o[0] = a;
        o[1] = b;
    };
};
