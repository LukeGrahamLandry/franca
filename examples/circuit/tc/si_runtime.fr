};

add_keyboard_value :: fn(g: *Global, up: Bool, key: u8) void = {

};

get_memory :: fn(g: *Global, name: String) Int = {
    // TODO
}

get_load_port_input :: fn(g: *Global, name: String) Int = {
    
}

get_last_time :: fn(g: *Global) Int = {
    
}

get_component_count :: fn(g: *Global) Int = {

}

random :: fn(g: *Global, limit: Int) Int = 
    g.rng&.rand_int(limit);

hex :: fn(g: *Global, length: Int, value: Int) String = {
    // TODO
    ""
};

bin :: fn(g: *Global, length: Int, value: Int) String = {
    // TODO
    ""
};


str :: fn(g: *Global, value: Int) String = {
    // TODO
    ""
};

clz :: fn(_: *Global, x: Int) Int = x.leading_zeros();
asr :: fn(_: *Global, lhs: Int, rhs: Int) Int = lhs.shift_right_arithmetic(rhs);

array :: fn(_: *Global, $T: Type, $length: i64) Array(T, length) #generic = zeroed(Array(T, length));

// TODO: (string, array).len
