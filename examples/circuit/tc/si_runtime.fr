// Input/Output types are different structs in each level, so need to generate a wrapper around the si code to type erase
VTableArch :: @struct {
    arch_get_input: @FnPtr(test: Int, input: Int, output: Int) TestResult;
    arch_check_output: @FnPtr(test: Int, input: Int, output: Int) TestResult;
    on_manual_input: @FnPtr(input: Int) TestResult;
    on_ui_update: @FnPtr(input: []i64, output: []i64) void;
};

VTableComponent :: @struct {
    get_input: @FnPtr(tick: Int, uninit_input: []i64) void;
    check_output: @FnPtr(tick: Int, input: []i64, output: []i64) TestResult;
};

#use(constants);
constants :: @struct {
    TestResult :: @enum(u8) (pass, fail, win);
    String :: []u8;
    Int :: i64;
    Char :: u8;
    Bool :: bool;
};

Translation :: Ty(i64, String);
Global :: *@struct {
    world: *World;
    test_index: Int;
    rng: Random.Rng;
};

// user code calls these with an implicit global context
callbacks :: @struct {

ui_set_text :: fn(g: *Global, key: String, value: Translation) void = {
    
};

set_error :: fn(g: *Global, value: Translation) void = {
    
};

ui_set_hidden :: fn(g: *Global, name: String, hidden: bool) void = {
    
};

ui_set_position :: fn(g: *Global, name: String, x: Int, y: Int) void = {
    
};

ui_set_instruction :: fn(g: *Global, _idk: Int, value: Int, tick: Int) void = {

};

get_test :: fn(g: *Global) Int = g.test_index;

get_output :: fn(g: *Global, name: String, i: Int) Int = {
    // TOOD
    0
};

get_ram_value :: fn(g: *Global, name: String, addr: Int, $T: Type) T #generic = {
