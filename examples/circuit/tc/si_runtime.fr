};

// string interpolation and operator "+" compile to calls to these functions
StringBuilder :: @struct(it: RawList(u8));
fn new_string_builder() StringBuilder = (it = empty());
fn push(self: *StringBuilter, it: String) *StringBuilder = {
    self.it&.push(it, temp());
    self
}
fn push(self: *StringBuilter, it: Int) *StringBuilder = {
    todo();
    self
}
fn end(self: *StringBuilder) String = self.it.items();
