
fn init(world: *World, a: Alloc, save_wire_values: bool) void = 
    init(world, a, save_wire_values, finished_defs.components);

fn init(world: *World, a: Alloc, save_wire_values: bool, components: []Component) void = {
    wire_sum, wire_depth, storage_count := {
        ws, wd, s := (0, 0, 0);
        for components { it |
            ws = max(ws, it.wire_sum);
            wd = max(wd, it.wire_depth);
            s = max(s, it.storage_count);
        };
        (ws, wd, s)
    };
    wires := @if(save_wire_values, wire_sum, wire_depth);
    world[] = (
        components = components,
        scratch = from_capacity(a.alloc_uninit(WireValue, wires)),
        instance = 0,
        storage = a.alloc_zeroed(WireValue, storage_count),
        doing_pre_read = false,
        save_wire_values = save_wire_values,
    );
}

fn drop(world: *World, a: Alloc) void = {
    world.scratch&.drop(a);
    a.dealloc(WireValue, world.storage);
    world[] = zeroed(World);
}

OldWireValue :: @struct {
    value: (@union(bit: bool, byte: u8)) #use;
    _pad := zeroed(Array(u8, 7));
};
WireValue :: i64;

World :: @struct {
    components: []Component;
    scratch: RawList(WireValue);
    // each instance of a delay component needs a unique bit of storage. including when 
    // nested inside other components. so reset this index for each top level eval call 
    // and evaluation it never short circuits, an instance will always get the same slot. 
    instance: i64;
    storage: []WireValue;
    // i evaluate the gates in order but output of a memory can be used before def. 
    // so do a prepass where just read from storage into wire. 
    doing_pre_read: bool;
    // for visualization, don't unscratch so can show values of wires in nested gates. 
    save_wire_values: bool;
    pre_read_depth := 0;
};

fn eval(world: *World, parent: []WireValue, it: *Component.Gate) void = {
    c := world[it.kind]&;
    // can't just early return here on (doing_pre_read&&storage_count==0) 
    // ex. memory8 needs to use make_byte to write its output. 
    
    @if(FEAT_TC_CIRCUIT) if it.kind.id > defs.tc_components_offset.trunc() && c.gates.len == 0 {
        eval_compiled(world, parent, it);
        return();
    };
    
    if c.wire_count == 0 {
        f := defs.primitives[it.kind.id.zext()];
        return f(world, parent, it);
    };
    
    if world.doing_pre_read && get_compiled(world, it.kind).is_some() {
        eval_compiled(world, parent, it);
        return();
    };
    
    wires := world.scratch(c.wire_count);
    wires.set_zeroed();  // switches with none enabled default to zero TODO: could just do it for those specific wires, compile the list like compile_order etc. 
    
    inputs, outputs := (c.gates[0].outputs, c.gates[c.gates.len - 1].inputs);
    @debug_assert_eq(inputs.len, it.inputs.len, "eval input arity %", c.name);
    range(0, inputs.len) { i |
        wires[inputs[i].id.zext()] = parent[it.inputs[i].id.zext()];
    };
    gates := c.gates.slice(1, c.gates.len - 1);
    doing_pre_read, instance := (world.doing_pre_read, world.instance);
    // TODO: compiler crash if this is `false` (works if indirection through a #noinline function)? :compiler :fucked !!
    if true {  // TODO: remove this block, im just documenting the bug^
    if c.storage_count != 0 && !doing_pre_read && c.compile_order.len != 0 {
        for c.compile_order.slice(1, c.compile_order.len - 1) { op |
            if op.pre_read {
                world.doing_pre_read = true;
                world.pre_read_depth += 1;
                prev := world.instance;
                world.instance = instance + c.instance_offset_by_gate[op.gate_i];
                world.eval(wires, c.gates.index(op.gate_i));
                world.instance = prev;
                world.pre_read_depth -= 1;
            } else {
                @debug_assert_eq(world.instance, instance + c.instance_offset_by_gate[op.gate_i]);
                world.doing_pre_read = false;
                world.eval(wires, c.gates.index(op.gate_i));
            };
        };
    } else {
        each gates { it |
            world.eval(wires, it);
        };
    };
    };
    
    world.doing_pre_read = doing_pre_read;
    @debug_assert_eq(outputs.len, it.outputs.len, "eval output arity %", c.name);
    range(0, outputs.len) { i |
        parent[it.outputs[i].id.zext()] = wires[outputs[i].id.zext()];
    };
    
    // pre_read_depth: when a preread calls one without stroage it sets doing_pre_read to false but still want to unscratch those until called again for.
    if !world.save_wire_values || world.pre_read_depth > 0 {
        world.unscratch(wires);
    };
}

primitives :: @struct {
    #arity(1, 2)
    nand :: fn(world, parent, it) = {
        in, out := (it.inputs, it.outputs);
        a, b := (parent[in[0].id.zext()] != 0, parent[in[1].id.zext()] != 0);
        parent[out[0].id.zext()] = int(a.int().bit_and(b.int()) == 0);
    };
    input :: fn(world, parent, it) = panic("only one input allowed");
    output :: fn(world, parent, it) = panic("only one output allowed");
    #arity(8, 1)
    byte_split :: fn(world, parent, it) = {
        in, out := (it.inputs, it.outputs);
        r := parent[in[0].id.zext()];
        inline_range(0, 8) { i |
            parent[out[i].id.zext()] = int(r.bit_and(1.shift_left(i)) != 0);
        };
    };
    #arity(1, 8)
    byte_make :: fn(world, parent, it) = {
        in, out := (it.inputs, it.outputs);
        r := 0;
        inline_range(0, 8) { i |
            r = r.bit_or(parent[in[i].id.zext()].shift_left(i));
        };
        parent[out[0].id.zext()] = r;
    };
    // CONST_INDEX :: 5;  // TODO: :fragile!!
    #arity(1, 0)
    const :: fn(world, parent, it) = {
        out, param := (it.outputs, it.param);
        parent[out[0].id.zext()] = param;
    };
    // TODO: detect same wire being written by multiple switches in the same tick
    // TODO: default to off if none write
    // TODO: detect use before all writes done
    switch1 :: switch8;
    #arity(1, 2)
    switch8 :: fn(world, parent, it) = {
        in, out := (it.inputs, it.outputs);
        a, b := (parent[in[0].id.zext()], parent[in[1].id.zext()] != 0);  // value, cond
        if b {
            parent[out[0].id.zext()] = a;
        };
    };
    #arity(1, 1)
    delay :: fn(world, parent, it) = {
        in, out := (it.inputs, it.outputs);
        parent[out[0].id.zext()] = eval_delay_gate(world, parent[in[0].id.zext()], world.doing_pre_read);
    };
}

fn eval_delay_gate(world: *World, input: WireValue, doing_pre_read: bool) WireValue #inline = {
    @debug_assert_ult(world.instance, world.storage.len, "must preallocate storage_count");
    slot := world.storage[world.instance]&;
    output := slot[];
    if !doing_pre_read {
        slot[] = input;
    };
    world.instance += 1;
    output
}

fn scratch(world: *World, n: i64) []WireValue #inline = {
    @debug_assert_ule(world.scratch.len + n, world.scratch.cap, "must preallocate wire_depth");
    world.scratch.len += n;
    world.scratch.slice(world.scratch.len - n, world.scratch.len)
}

fn unscratch(world: *World, wires: []WireValue) void #inline = {
    @debug_assert(identical(world.scratch.items().end_pointer(), wires.end_pointer()), "scratch bad nesting");
    world.scratch.len -= wires.len;
}

fn index(world: *World, i: ComponentId) *Component = world.components.index(i.id.zext()); 

fixwirevalue :: fn(a: []OldWireValue) []WireValue = 
    bit_cast_unchecked([]OldWireValue, []WireValue, a);

fn tick_overture(world: *World, root_component: ComponentId, input: u8, write_program: bool, save_wire_values: bool) ?u8 = {
    world.instance = 0; 
    world.scratch.len = 0;
    
    prev := world.save_wire_values;
    @debug_assert(prev || !save_wire_values, "if init(save_wire_values=false), won't have preallocated enough");
    world.save_wire_values = prev && save_wire_values;  
    values := fixwirevalue @slice(@as(OldWireValue) (byte = input), (bit = write_program), (byte = 0), (bit = false), (bit = false));
    out := @const_slice(@as(WireId) (id = 2), (id = 3), (id = 4));
    name := world[root_component].name;
    if name != "leg" {
        out.len -= 1;
    };
    in := @const_slice(@as(WireId) (id = 0), (id = 1));
    base_gate := @ref @as(Component.Gate) (
        outputs = out, 
        inputs = in,
        kind = root_component, 
        param = 0,
    );
    if !world.save_wire_values && get_compiled(world, base_gate.kind).is_some() {
        eval_compiled(world, values, base_gate);
    } else {
        eval(world, values, base_gate);
    };
    
    world.save_wire_values = prev;
    @if(values[3] != 0, (Some = values[2].trunc()), .None)
}

// expose the compiled version with the intepreter's calling convention. 
fn eval_compiled(world: *World, parent: []WireValue, it: *Component.Gate) void = {
    o_n, i_n := world[it.kind]&.arity();
    // redundant if the gate is from a Component but be safe for base_gate in the top level call. 
    @assert(it.inputs.len == i_n && it.outputs.len == o_n, "arity error calling compiled gate");  
    a := Arena'stack_alloc(size_of(WireValue) * max_in_out_wires);
    values := a.alloc_zeroed(WireValue, it.outputs.len + it.inputs.len);
    range(0, it.inputs.len) { i |
        values[i + o_n] = parent[it.inputs[i].id.zext()];
    };
    eval_compiled(world, values, it.kind, it.param);
    range(0, it.outputs.len) { i |
        parent[it.outputs[i].id.zext()] = values[i];
    };
}

// values is (uninit outputs, inputs)
fn eval_compiled(world: *World, values: []WireValue, kind: ComponentId, param: i64) []i64 = {
    child := world[kind]&;
    compiled := get_compiled(world, kind)
        || @panic("expected eval_compiled gate to have fast_eval for (%)", child.name);
    o_n, i_n := child.arity();
    @assert_eq(o_n + i_n, values.len, "arity error calling compiled gate");  
    // SAFETY: *Array(T, N) has same repr as *T. compile_gates chooses N based on Gate arity. 
    if child.has_param {  // TODO: this is stupid. only matters on wasm. should probably just always add a junk param:i64 in the compiler instead. 
        compiled := bit_cast_unchecked(rawptr, @FnPtr(*World, *WireValue, *WireValue, i64) void, compiled);
        compiled(world, values.ptr, values.ptr.offset(o_n), param);
    } else {
        compiled := bit_cast_unchecked(rawptr, @FnPtr(*World, *WireValue, *WireValue) void, compiled);
        compiled(world, values.ptr, values.ptr.offset(o_n));
    };
    values.slice(0, o_n)
}

fn eval(world: *World, values: []WireValue, kind: ComponentId) []i64 = {
    a := Arena'stack_alloc(size_of(WireId) * max_in_out_wires);
    o_n, i_n := world[kind]&.arity();
    it: Component.Gate = (
        inputs = a.alloc_init(WireId, i_n, fn(i) => (id = (i + o_n).trunc())),
        outputs = a.alloc_init(WireId, o_n, fn(i) => (id = i.trunc())),
        kind = kind,
    );
    eval(world, values, it&);
    values.slice(0, o_n)
}

fn get_compiled(world: *World, kind: ComponentId) ?rawptr #inline = {
    f := world[kind].fast_eval;
    if !f.is_null() {
        return(Some = f);
    };
    .None
}

#use("@/examples/circuit/parse.fr");
#use("@/lib/collections/map.fr");

get_component_by_name :: fn(name: Str, components: []Component) ComponentId #fold = {
    kind := components.index_of(fn(it) => it.name == name).unwrap();
    (id = kind.trunc())
};

fn find_component(world: *World, name: Str) ?ComponentId = {
    kind := world.components.index_of(fn(it) => it.name == name)
        || return(.None);
    (Some = (id = kind.trunc()))
}

