
// stress test for getting preempted mid-syscall
// also enough that i run out of space for page tables if they're not reused. 
main :: fn() void = {
    size := page_size();
    range(0, 100_000_000) { _ |
        buf := page_allocator.alloc_uninit(u8, size);
        page_allocator.dealloc(u8, buf);
    };
    print("ok\n");
}
