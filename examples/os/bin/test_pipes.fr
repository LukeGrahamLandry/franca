
main :: fn() void = {
    multi_thread();
    multi_process();
    subprocess_api();
    println("ok");
}

multi_thread :: fn() void = {
    poll :: pollXX;
    pipes :: @static_mut zeroed(Array(Array(Fd, 2), 2));
    each pipes { p |
        Syscall'pipe(p).unwrap();
    };
    fd := pipes[0]&[0];
    @assert_eq(poll(fd), 0);
    t := start_thread_nodata {
        buf := msg;
        fd := pipes[0]&[1];
        @assert_eq(poll(fd), Posix.POLL.OUT, "out?");
        Syscall'write(fd, buf.ptr, buf.len).unwrap();
        Syscall'close(fd);
        pipes[0]&[1].fd = -1;
    };
    t.join();
    @assert_eq(poll(fd), @or(Posix.POLL.IN, Posix.POLL.HUP));
    buf := temp().alloc_zeroed(u8, 64);
    buf.len = Syscall'read(fd, buf.ptr, buf.len).unwrap();
    @assert_eq(poll(fd), Posix.POLL.HUP, "hup?");
    @assert_eq(buf, msg);
    each(pipes, fn(it) => for(it, fn(it) => { Syscall'close(it); }));
    println(buf);
    msg :: "Hello World!";
}

multi_process :: fn() void = {
    #use(Syscall);
    out := zeroed(pid_t);
    path := "franca";
    argv := import("@/lib/sys/subprocess.fr")'make_args_for_exec(path, @slice("examples/toy/hello2.fr"), temp());
    
    pipe := zeroed Array(Fd, 2);
    Syscall'pipe(pipe&).unwrap();
    
    // error handling is when we don't get the right answer at the end. 
    a := @uninitialized PosixSpawnActions;
    posix_spawn_file_actions_init(a&);
    posix_spawn_file_actions_adddup2(a&, pipe&[1], STD_OUT);
    posix_spawn_file_actions_addclose(a&, pipe&[0]);
    posix_spawn_file_actions_addclose(a&, pipe&[1]);
    posix_spawnp(out&, path.as_cstr(), a&, zeroed(*PosixSpawnAttr), argv.ptr, tls(.environment_variables)[]).unwrap();
    posix_spawn_file_actions_destroy(a&);
    Syscall'close(pipe&[1]);
    
    status: i32 = 0;
    res := Posix'waitpid(out, status&, 0);
    @assert(res.is_ok() && status == 0, "pid=% err=% status=%", out, res.Err._, status);
    
    buf := temp().alloc_zeroed(u8, 64);
    buf.len = Syscall'read(pipe&[0], buf.ptr, buf.len).unwrap();
    @assert_eq(pollXX(pipe&[0]), Posix.POLL.HUP, "hup?");
    Syscall'close(pipe&[0]);
    @println("from %'s pipe[%][%]", out, buf.len, buf);
    @assert_eq(buf, "Hello World!\n");
}

subprocess_api :: fn() void = {
    #use("@/lib/sys/subprocess.fr");
    ok, out, err := exec_and_catch("franca", @slice("examples/toy/hello2.fr"), temp());
    @assert(ok && out.items() == "Hello World!\n", "%\n%%", ok, out.items(), err.items());
    
    {
        ok, out, err := exec_and_catch("franca", @slice("examples/toy/crash.fr"), temp());
        @assert(!ok && err.items().contains("Goodbye"), "expected panic(Goodbye) %\n%%", ok, out.items(), err.items());
    };
};

pollXX :: fn(fd: Fd) i64 = {
    fd := @slice(@as(Posix.pollfd) (fd = fd, events = @or(Posix.POLL.IN, Posix.POLL.OUT), revents = 0));
    Posix'poll(fd, 0).unwrap();
    fd[0].revents.zext()
};

