
ioctl :: fn(f: Fd, op: i64, va: CVariadic) i32 /*#inline*/ = 
    FR_ioctl(f, op, va&.start().next(rawptr));

FR_ioctl :: fn(f: Fd, op: i64, data: rawptr) i32 = {
    @trace("ioctl(%, %, %)", f.fd, op, fmt_hex(data));
    fd := get_file(f) || return(-1);
    for fd.vtable.ioctls { n, callee |
        if n == op {
            return callee(fd.data, data).intcast();
        };
    };
    fd'vtable'ioctl(fd.data, op, data).intcast()
}

#use("@/lib/variadic.fr");
