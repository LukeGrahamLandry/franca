#use("@/examples/os/user/vfs.fr");

pread :: fn(f: Fd, buf: *u8, len: i64, offset: i64) i64 = {
    @if(len == 0) return(0);
    fd := get_file(f) || return(-1);
    result := fd'vtable'read(fd.data, buf.slice(len), offset);
    @trace("pread(%, %, %, %) = %", f.fd, u8.int_from_ptr(buf), len, offset, result);
    result
};

read :: fn(f: Fd, buf: *u8, len: i64) i64 = {
    @if(len == 0) return(0);
    fd := get_file(f) || return(-1);
    result := fd'vtable'read(fd.data, buf.slice(len), fd.position);
    @trace("read(%, %, %) = %", f.fd, u8.int_from_ptr(buf), len, result);
    if result >= 0 {
        use_file f { it |
            it.position += result;
        };
    };
    result
};

write :: fn(f: Fd, buf: *u8, size: i64) i64 = {
    @if(size == 0) return(0);
    fd := get_file(f) || return(-1);
    
    append := fd.flags.bit_and(LinuxLibc.O_arm.APPEND) != 0;
    if append {
        // TODO: this needs to be atomic
        _ := fd'vtable'lseek(fd.data, 0, .End, fd.position&);
    };
    
    result := fd'vtable'write(fd.data, buf.slice(size), fd.position);
    @trace("write(%, %, %) = %", f.fd, u8.int_from_ptr(buf), size, result);
    if result >= 0 {
        use_file f { it |
            it.position += result;
        };
    };
    result
};

close :: fn(f: Fd) i64 = {
    fs := get_vfs();
    @if(f.fd == { xxx := LinuxLibc.AT_FDCWD; xxx.fd }) return(-1);
    fd := get_file(f) || return(-1);
    ::ptr_utils(@type fd.vtable[]);
    @if(identical(fd.vtable, closed_file_vtable)) return(-1);
    old_refs := i32.atomic_add(fd.refs&, -1);
    @trace("close(%)", f.fd);
    if old_refs == 1 {
        fd'vtable'close(fd.data);
    };
    // default impl for everything to just error
    closed_file_vtable :: @static { 
        it: FileVTable = ();
        it.debug = fn(self, out) = @fmt(out, "CLOSED");
        it 
    };
    closed_file_instance :: @static @as(FileInstance) (vtable = closed_file_vtable, data = zeroed(rawptr), refs = 0);
    with fs.mutex& {
    fs.cloexec&.unset(f.fd.intcast());
    fs.fd[f.fd.intcast()] = closed_file_instance;
    fs.free&.push_back(f, fs.allocator);
    if old_refs == 1 {
        fs.allocator.dealloc_one(FileInstance, fd);
    };
    };
    0
};

lseek :: fn(f: Fd, offset: i64, whence: Whence) i64 = {
    fd := get_file(f) || return(-1);
    result := fd'vtable'lseek(fd.data, offset, whence, fd.position&);
    use_file f { it |
        it.position = fd.position;
    };
    @trace("lseek(fd = %, %, %) = %", f.fd, offset, whence, result);
    result
};

readlinkat :: fn(parent: Fd, path: CStr, ptr: *u8, len: i64) i64 = 
    -1;

openat :: fn() void = panic("TODO: use CVariadic");

// note: this is the linux syscall abi, not the libc abi
//       (in the c one mode is variadic)
FR_openat :: fn(f: Fd, path: CStr, flags: i64, mode: i64) i64 = {
    path := path;
    need_close := false;
    if path.str().contains("/") {  // :SLOW
        parent, file := or follow_path_prefix(f, path.str()) { e |
            return(e);
        };
        f = parent;
        need_close = true;
        path = file;
    };
    fd := get_file(f) || return(-1);

    d := flags;  // :HostUserNightmare
    if query_current_arch() == .x86_64 && d.bit_and(LinuxLibc.O_amd.DIRECTORY) != 0 { 
        d = d.bit_and(bit_not(LinuxLibc.O_amd.DIRECTORY)).bit_or(LinuxLibc.O_arm.DIRECTORY);
    };
    
    result := fd'vtable'openat(fd.data, path, d, mode);
    @trace("openat(fd = %, %, %, %) = %", f.fd, path, d, mode, result);
    @assert(f.fd.intcast() != result, "openat must return new fd");
    if need_close {
        close(f);
    };
    result
}

fstat :: fn(f: Fd, out: *Syscall.SysStat) i64 = {
    out[] = zeroed(@type out[]);
    fd := get_file(f) || return(-1);
    s := zeroed(Vfs.FStatOut);
    result := fd'vtable'fstat(fd.data, s&);
    @trace("fstat(%) = %; %", f.fd, result, @if(result == 0, {
        ifmt := s.st_mode.int().bit_and(Posix.S.IFMT);
        @if(ifmt == Posix.S.IFDIR, "DIR", "REG")
    }, "-"));
    
    if query_current_arch() == .x86_64 {  // :HostUserNightmare
        out.l.st_mode = s.st_mode;
    } else {
        out.la.st_mode = s.st_mode;
    };
    
    result
};

fstatat :: fn(fd: Fd, path: CStr, out: *Syscall.SysStat, _: i64) i64 = {
    fd := FR_openat(fd, path, LinuxLibc.O_arm.CLOEXEC, 0);
    @if(fd < 0) return(fd);
    fd: Fd = (fd = fd.intcast());
    result := fstat(fd, out);
    close(fd);
    result
}

mkdirat :: fn(parent: Fd, path: CStr, mode: i64) i64 = {
    parent2, path2 := follow_path_prefix(parent, path.str()) 
        .or(fn(e) => return(e));
    @trace("mkdir(%, %) => mkdir(%, %)", parent.fd, path, parent2.fd, path2);
    f := get_file(parent2) || return(-1);
    result := f'vtable'mkdir(f'data, path2, mode);
    @trace("mkdir(%, %, %) = %", parent.fd, path, mode, result);
    if parent2.fd != parent.fd {
        _ := close(parent2);
    };
    result
}

access :: fn(path: CStr, mode: i64) i64 = {
    fd := FR_openat(Posix'AT'FDCWD(), path, LinuxLibc.O_arm.CLOEXEC, 0);
    @if(fd < 0) return(fd);
    fd: Fd = (fd = fd.intcast());
    f := get_file(fd) || return(-1);
    result := f'vtable'access(f'data, mode);
    @trace("access(%, %) = %", path, mode, result);
    close(fd);
    result
}

renameat :: fn(old_dir: Fd, old: CStr, new_dir: Fd, new: CStr) i64 = {
    new_dir2, new_file := follow_path_prefix(new_dir, new.str()) 
        .or(fn(e) => return(e));
    old_dir2, old_file := or follow_path_prefix(old_dir, old.str()) { e |
        if new_dir2.fd != new_dir.fd {
            _ := close(new_dir2);
        };
        return(e)
    };

    f := get_file(old_dir2) || return(-1);
    result := f'vtable'rename(f'data, new_dir2, old_file, new_file);
    @trace("renameat(%, %, %, %) = %", old_dir.fd, old, new_dir.fd, new, result);
    if old_dir2.fd != old_dir.fd {
        _ := close(old_dir2);
    };
    if new_dir2.fd != new_dir.fd {
        _ := close(new_dir2);
    };
    result
}

fsync :: fn(_: u32) i64 = 0;  // TODO

chdir :: fn(path: CStr) i64 = {
    fs := get_vfs();
    fd := FR_openat(Posix'AT'FDCWD(), path, Posix'O'RDWR, 0);
    @if(fd < 0) return(fd);
    // TODO: don't leak the old one
    fs.cwd.fd = fd.intcast();
    0
}

getpid :: fn() i32 = {  // needed for anon_temp_path
    g := get_current_tls()[].thread_group;
    g.vfs.mutex&.lock();
    r := g.threads[0].tid;
    g.vfs.mutex&.unlock();
    r
};

dup2 :: fn(old: Fd, new: Fd) Fd = {
    fs := get_vfs();
    @if(old.fd == new.fd || new.fd < 0) return(new);
    old := get_file(old) || return(fd = -1);
    with fs.mutex& {
        close(new);
        free_new := fs.free&.pop_back().unwrap();
        @debug_assert_eq(new.fd, free_new.fd, "dup2 failed to recycle dest?");
        @debug_assert(!fs.cloexec&.get(new.fd.intcast()), "close must unset cloexec on the slot");
        i32.atomic_add(old.refs&, 1);
        fs.fd[new.fd.intcast()] = old;
    };
    new
}

unlinkat :: fn(parent: Fd, path: CStr, mode: i64) i64 = {
    -1
}
