#use("@/lib/sys/jump.fr")
main :: fn() = {
    buf := JumpBuf.zeroed();
    @match_try(buf&) {
        fn Try() => {
            println("A");
            throw(buf&);
        }
        fn Catch() => {
            println("B");
        };
    };
    println("C");
}
