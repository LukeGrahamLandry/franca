// some of my programs output image files 
// and my belief system is that my stuff should be self contained 
// so i want to provide a way to view them.
HELP :: """
drag to pan and scroll to zoom. 
cli/dragndrop/paste to open image. 
left/right to cycle images. 
r: reload file.
space: toggle file name. 
h: toggle help (always on if no image).
c: reset scale/pos.
""";

// TODO: figure out how to get os events to watch files

FEAT_PNG :: true; // adds dependency on stb_image to support more formats, otherwise only a subset of ppm. 

load_texture_from_file :: fn(sg: *Sg.Self, path: Str) Result(Ty(Sg.Image, i64, i64), Str) = {
    #use("@/lib/sys/fs.fr");
    
    prefix := "data:image/png;base64,";
    in := if path.starts_with(prefix) {
        out := u8.list(temp());
        decode :: import("@/lib/encoding/base64.fr").base64_decode;
        decode(out&, path.rest(prefix.len));
        out.items()
    } else {
        read_entire_file(temp(), path) 
            || return(Err = "failed to read")
    };
    
    data, width, height := @if(FEAT_PNG, {
        (w: i32, h: i32, c: i32) := (0, 0, 4);
        pixels := Stb'stbi_load_from_memory(in.ptr, in.len.intcast(), w&, h&, zeroed(*i32), c);
        if pixels.is_null() {
            // TODO: import_c support thread locals :FUCKED
            s := Stb'stbi_failure_reason();
            s: CStr = (ptr = bit_cast_unchecked(*i8, *u8, s));
            return(Err = s.str());
        };
        (pixels.slice(intcast(w*h*c)), w, h)
    }, {
        // https://netpbm.sourceforge.net/doc/ppm.html
        ppm := @try(read_ppm_header(in)) return;
        size := ppm.width * ppm.height;
        bpp := @switch(ppm.magic) {
            @case(5) => 1;
            @case(6) => 3;
            @default => return(Err = "unsupported ppm");
        };
        if size * bpp < ppm.rest.len || ppm.max != 255 {
            return(Err = "unsupported ppm");
        };
        in = ppm.rest.slice(0, size*bpp);
        data := @switch(ppm.magic) {
            @case(5) => temp().alloc_init(u32, size, fn(i) => pack_rgba(in[i], in[i], in[i], 255));
            @case(6) => temp().alloc_init(u32, size, fn(i) => pack_rgba(in[i*3+0], in[i*3+1], in[i*3+2], 255));
            @default => unreachable();
        };
        (data.interpret_as_bytes(), ppm.width.intcast(), ppm.height.intcast())
    });

    d := zeroed(Sg.ImageData);
    d.subimage&[0]&[0] = data;
    img: Sg.Image = sg.make(
        width = width, height = height,
        pixel_format = .RGBA8,
        data = d,
    );
    @if(FEAT_PNG) Stb'stbi_image_free(u8.raw_from_ptr(data.ptr));
    (Ok = (img, width.intcast(), height.intcast()))
}

open_image :: fn(state: *State, it: Str) bool = {
    img, width, height := @match(load_texture_from_file(state.sg, it)) {
        fn Ok(it) => it;
        fn Err(err) => {
            @eprintln("[%]: %", it, err);
            return false;
        }
    };
    @eprintln("[%]: ok", it);
    push_image(state, it, img, width, height);
    true
}

push_image :: fn(state: *State, title: Str, img: Sg.Image, width: i64, height: i64) void = {
    state.images&.push(
        img = img, 
        name = title.shallow_copy(state.images.gpa), 
        aspect = width.float() / height.float(),
    );
    state.dirty = true;
    state.image_i = state.images.len - 1;
}

Ppm :: @struct(magic: i64, width: i64, height: i64, max: i64, rest: []u8);
read_ppm_header :: fn(in: []u8) Result(Ppm, Str) = {
    if in.len < 3 || in[0] != "P".ascii() || !in[2].is_ascii_whitespace() {
        return(Err = "bad ppm magic");
    };
    magic: i64 = in[1].zext() - "0".char();
    in = in.rest(2);
    n := @ref zeroed(Array(i64, 3));
    range(0, 3) { i |
        while => in.len > 0 && in[0].is_ascii_whitespace() {
            in = in.rest(1);
        };
        it, ss := convert_number(in, 10, dec_digit);
        @if(ss.len == in.len) return(Err = @tfmt("missing header component %", i));
        n[i] = it;
        in = ss;
    };
    in = in.rest(1);
    width, height, max_colour := (n[0], n[1], n[2]);
    (Ok = (magic = magic, width = n[0], height = n[1], max = n[2], rest = in))
}

fn on_render(state: *State, sapp: *Sapp.Self, sg: *Sg.Self) void = {
    @if(Easy'should_skip_frame(sapp, state.dirty&)) return();
    
    sgl := state.draw&;
    sgl.defaults();
    sgl.viewport(0.intcast(), 0.intcast(), sapp.width().intcast(), sapp.height().intcast(), true);
    sgl.load_pipeline(state.pipe);
    
    sdtx := state.text.default_context&;
    image_aspect := 1.0;
    x := 1.0 / sapp.dpi_scale;
    sdtx.canvas(sapp.width().float().cast().mul(x), sapp.height().float().cast().mul(x));
    if state.images.len > 0 {
        it := state.images[state.image_i];
        sgl.texturing_enabled = true;
        sgl.texture(it.img, (id = Sg.INVALID_ID));
        
        sdtx.color = 0xFF005555;
        @if(state.show_name) sdtx.put(it.name);
        
        image_aspect = it.aspect;
    };
    if state.show_help || state.images.len == 0 {
        sdtx.color = 0xFF000000;
        sdtx.put(HELP);
        sdtx.put(@tfmt("\nFEAT_PNG=%;\n", FEAT_PNG));
    };
    
    sgl.begin(.QUADS);
    sgl.load_identity();
    sgl.translate(state.pos.x, state.pos.y, 0.0);
    sgl.scale(state.scale, state.scale, 0.0);
    sgl.rotate(PI, 1.0, 0.0, 0.0);

    screen_aspect := sapp.width().float() / sapp.height().float();
    (x1: f32, x2: f32, y1: f32, y2: f32) := (0, 1, 0, cast(screen_aspect / image_aspect));
    sgl.v2f_t2f(x1, y1, 0, 0);
    sgl.v2f_t2f(x2, y1, 1, 0);
    sgl.v2f_t2f(x2, y2, 1, 1);
    sgl.v2f_t2f(x1, y2, 0, 1);
    sgl.end();
    
    Easy'glue_begin_pass(sapp, sg, (colors = ((
        load_action = .CLEAR,
        clear_value = (r = 0.15, g = 0.15, b = 0.15, a = 1),
    ), ..)));
    sgl.draw_layer(sg, 0);
    sdtx.draw_layer(0);
    sg.end_pass();
    sg.commit();
};

State :: @struct {
    HIGH_DPI :: true;
    pipe: Sgl.Pipeline;
    draw: Sgl.Self;
    text: Sdtx.Self;
    pos: Vec2;
    scale: f32;
    sg: *Sg.Self;
    sapp: *Sapp.Self;
    images: List(Img);
    image_i: i64;
    dirty: bool;
    show_name: bool;
    show_help: bool;
};

Img :: @struct {
    img: Sg.Image;
    name: Str;
    aspect: f64;
};

fn on_init(state: *State, sapp: *Sapp.Self, sg: *Sg.Self) void = {
    state.sg = sg; state.sapp = sapp;
    sapp.desc.enable_clipboard = true;
    sapp.desc.enable_dragndrop = true;
    state.draw&.setup(
        allocator = general_allocator(),
        sg = sg,
    );
    
    state.scale = 1.0;
    state.pos = vec2(-1.0, 1.0);
    
    init_pipeline(state.draw&, state.pipe&, sg, (colors = (
        (blend = (  // This makes transparency work
            enabled = true,
            src_factor_rgb = .SRC_ALPHA,
            dst_factor_rgb = .ONE_MINUS_SRC_ALPHA,
        )),
        ..,
    )));
    
    state.text&.setup(
        sg = sg,
        allocator = general_allocator(),
        fonts = @slice(Sdtx.font.cpc),
    );
    
    state.images = list(general_allocator());
    for cli_args() { it |
        it := it.str();
        open_image(state, it);
    };
    state.dirty = true;  // show the white square even if nothing loaded
}

fn on_event(state: *State, sapp: *Sapp.Self, event: *Sapp.Event) void = {
    screen := vec2(sapp.framebuffer_width.float().cast(), sapp.framebuffer_height.float().cast()) 
        / 2;
    mouse := vec2(event.mouse_x, -event.mouse_y) / screen + vec2(-1.0, 1.0);
    delta_mouse := vec2(event.mouse_dx, -event.mouse_dy) / screen;
    @match(event.type) {
        fn RESIZED() => ();
        fn KEY_DOWN() => @match(event.key_code) {
            fn LEFT() => state.next_example(-1);
            fn RIGHT() => state.next_example(1);
            fn SPACE() => { state.show_name = !state.show_name; }
            fn H() => { state.show_help = !state.show_help; }
            fn R() => if state.images.len > 0 {
                i := state.image_i;
                if open_image(state, state.images[i].name) {
                    state.images&.swap(i, state.images.len - 1);
                    old := state.images&.pop().unwrap();
                    state.sg.destroy(old.img);
                    state.images.gpa.dealloc(u8, old.name);
                    state.image_i = i;
                }
            }
            fn C() => {
                state.scale = 1.0;
                state.pos = vec2(-1.0, 1.0);
            }
            @default => return();
        };
        fn MOUSE_MOVE() => {
            @if(event.modifiers.get(.left_mouse) == 0) return();
            state.pos += delta_mouse;
        }
        fn MOUSE_SCROLL() => {
            (lo: f32, hi: f32) := (0.01, 10000);
            delta := event.scroll_y * state.scale * 3 / screen.x;
            delta := clamp(state.scale + delta, lo, hi) - state.scale;
            
            pos := (mouse - state.pos) / state.scale;
            pos0 := pos * vec2(state.scale);
            pos1 := pos * vec2(state.scale + delta);
            state.pos -= pos1 - pos0;
            state.scale += delta;
        }
        fn CLIPBOARD_PASTED() => {
            open_image(state, event.pasted);
        }
        fn FILES_DROPPED() => {
            for event.drop { s |
                open_image(state, s);
            };
        }
        @default => return();
    };
    state.dirty = true;
}

fn next_example(state: *State, delta: i64) void = {
    @if(state.images.len == 0) return();
    state.image_i = mod(state.image_i + delta + state.images.len, state.images.len);
}

driver :: fn(vtable: *ImportVTable) void = 
    Easy'build_for_graphics(vtable, @source_file_name());

main :: fn() void = 
    Easy'start(State);

#use("@/graphics/lib.fr");

Stb :: {
    root := Foreign'stb();
    Ffi  :: import("@/examples/import_c/ffi.fr");
    c_source := @tfmt("""
        #define STB_IMAGE_IMPLEMENTATION
        #define STBI_NO_SIMD
        #define STBI_NO_STDIO
        #define STBI_FAILURE_USERMSG
        #include "%/stb_image.h"
    """, root);
    Ffi'include(current_compiler_context(), c_source)
}
