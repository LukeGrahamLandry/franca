
debug_trace_execution :: false;
debug_print_code :: false;
debug_stress_gc :: false;
debug_log_gc :: false;
stack_max :: 128*256;
gc_heap_grow_factor :: 2;
gc_heap_base_size :: 1024 * 1024;

Vm :: @struct(
    stack_top: *Value,
    frame: *CallFrame,
    stack: []Value,
    last_return: Value,
    gc: Alloc,
    objects: *Obj,
    strings: Table,
    globals: Table,
    errors: List(u8),
    frames: List(CallFrame),
    init_string: *ObjString,
    start_time: f64,
    // location still points to the stack. 
    // values captured by OpCode.Closure but not yet OpCode.CloseUpvalue. 
    // sorted by position in the stack. 
    open_upvalues: *ObjUpvalue,  
    gc_storage: CountingAllocator,
    // only used when one of the debug options is enabled
    debug: List(u8),   
    user_data: rawptr,
    print_callback: @FnPtr(vm: rawptr, user_data: rawptr, value: Value) void,
    except: ?*JumpBuf,
    xxxxx: rawptr,
    aot_roots: []*Obj,
);
JumpBuf :: import("@/lib/sys/jump.fr").JumpBuf;

CallFrame :: @struct {
    closure: *ObjClosure #use;
    ip: *u8;
    first_local: i64;
};

fn init(self: *Vm) *Vm = {
    self[] = zeroed Vm;
    self.except = .None;
    self.xxxxx = ::@as(@Fn(vm: *Vm) void) run;
    a := general_allocator();
    self.print_callback = fn(_0, _1, value) = @print("%\n", value);
    self.gc_storage.parent = a;
    self.gc_storage.bytes_next_gc = gc_heap_base_size;
    self.gc = self.gc_storage&.borrow();
    if debug_trace_execution || debug_print_code || debug_log_gc {
        self.debug = list(a);
    }
    self.stack = self.gc.alloc_zeroed(Value, stack_max);
    // TODO: EXTRA: grow stack but it's hard because of capture_upvalue
    self.objects = Obj.ptr_from_int(0); // EVIL
    self.reset_stack();
    self.errors = list(self.gc);
    self.frames = list(128, self.gc);
    self.init_string = self.copy_string("init");
    inline_for get_constants(Natives) { $name |
        fid :: FuncId.get_constant(Natives, name[]).unwrap();
        self.define_native(@run name[].str(), fid);
    };
    self.start_time = timestamp_s();
    self
}

Natives :: Type.scope_of(@struct {
    clock :: fn(vm: *Vm, _: []Value) Value = 
        (timestamp_s() - vm.start_time).to_value();
        
    getc :: fn(vm: *Vm, args: []Value) Value = {
        @if(args.len != 0) vm.runtime_error("arity");
        c := getchar_UNBUFFERED();  // TODO: let caller provide this like they do print?
        c.intcast().float().to_value()
    }
    chr :: fn(vm: *Vm, args: []Value) Value = {
        @if(args.len != 1) vm.runtime_error("arity");
        @if(!args[0].is_number()) vm.runtime_error("type");
        c := args[0].to_number().int();
        @if(c < 0 || c > 255) vm.runtime_error("range");
        c: u8 = c.trunc();
        vm.copy_string(c&.slice(1)).to_value()
    }
    exit :: fn(vm: *Vm, args: []Value) Value = {
        @if(args.len != 1) vm.runtime_error("arity");
        @if(!args[0].is_number()) vm.runtime_error("type");
        status := args[0].to_number().int();
        @if(status < 0 || status > 255) vm.runtime_error("range");
        Syscall'exit(status.intcast());
    }
    print_error :: fn(vm: *Vm, args: []Value) Value = {
        @if(args.len != 1) vm.runtime_error("arity");
        @if(!args[0].is(.String)) vm.runtime_error("type");
        eprint(args[0].to(.String)[].data);
        nil_value
    }
});

fn define_native(self: *Vm, name: Str, callee: ObjNative.F) void = {
    name := self.copy_string(name);
    obj := self.allocate_obj(ObjNative);
    obj.function = callee;
    obj.name = name.data;
    self.globals&.insert(name, obj.obj&.to_value(), self.gc);
}

fn drop(self: *Vm) void = {
    self.free_objects();
    self.gc.dealloc(Value, self.stack);
    self.globals&.drop(self.gc);
    self.strings&.drop(self.gc);
    self.errors&.drop();
    self.frames&.drop();
    self.debug&.drop();
    leaked := self.gc_storage.bytes_allocated;
    @if(debug_log_gc && leaked != 0) @print("leaked bytes_allocated = %", leaked);
}

InterpretResult :: @enum(i64) (Ok, CompileError, RuntimeError);

fn interpret(self: *Vm, source: Str, collect_errors: bool) InterpretResult = {
    ::if(InterpretResult);
    function := self.compile(source) || {
        @if(!collect_errors) println(self.errors.items());
        return(.CompileError);
    };
    result := self.interpret(function, collect_errors);
    if !collect_errors && self.errors.len > 0 {
        println(self.errors.items());
    }
    result
}

fn interpret(self: *Vm, source: Str) InterpretResult = {
    self.interpret(source, false)
}

fn interpret(self: *Vm, function: *ObjFunction, collect_errors: bool) InterpretResult = {
    self.stack_top = self.stack.ptr;
    
    closure := self.new_closure(function);
    self.frames&.push(
        closure = closure, ip = 
        function.chunk.code.index_unchecked(0), 
        first_local = ptr_diff(self.stack.ptr, self.stack_top),
    );
    self.push(closure.to_value());
    
    self.except = .None;
    if !collect_errors {
        self.run();
        return(.Ok);
    };
    
    except := @uninitialized JumpBuf;
    self.except = (Some = except&);
    @match(try(except&)) {
        fn Try() => {
            self.run();
            .Ok
        }
        fn Catch() => .RuntimeError;
    }
}

is_falsy :: fn(v: Value) bool = v.is_bool().and(=> v.to_bool().not()).or(v.is_nil()); 

fn run(self: *Vm) void = {
    end := self.frames.len - 1;
    self.frame = self.frames[self.frames.len - 1]&;
    if !self.frame.function.aot.is_null() {
        f := bit_cast_unchecked(rawptr, OpFn, self.frame.function.aot);
        return f(self);
    };
    loop {
        continue :: local_return;
        frame := self.frame;
        ip := frame.ip&;
        @debug_assert(ptr_diff(frame.function.chunk.code.maybe_uninit.ptr, ip[]) < frame.function.chunk.code.len, "fell off the end of function");
        self.trace_inst();
        instruction := self.read_byte();
        
        S :: Type.scope_of(Opcodes);
        inline_for get_constants(S) { $name |
            fid :: FuncId.get_constant(S, name[]).unwrap();
            op :: OpCode.from_name(name[].str()).unwrap();
            i := @as(OpCode) instruction;
            if op == i {
                @if(has_value_literal(op), 
                    fid(self, self.read_constant()), 
                    @if(has_index_literal(op), fid(self, self.read_byte().zext()), 
                        @if(@run @is(op, .Invoke, .InvokeSuper), fid(self, self.read_constant(), self.read_byte().zext()),
                            fid(self))));
                @if(op == .Return) @if(self.frames.len == end) return();
                continue();
            };
        };
        self.runtime_error2(@tfmt("LOX_ICE: bad opcode %", @as(u8) instruction));
    };
}

// see comment on maybe_collect_garbage (i'm lazy with the stack because don't run gc inside opcodes)
Opcodes :: fix_opcodes(@struct {
            Constant :: fn(self, constant: Value) = {
                self.push(constant);
            };
            Call :: fn(self, arg_count: i64) = {
                self.call_value(self.peek(arg_count), arg_count);
            };
            Return :: fn(self) = {
                frame := self.frame;
                self.maybe_collect_garbage();
                value := self.pop();
                self.close_upvalues(self.stack.index_unchecked(frame.first_local));
                self.frames.len -= 1;
                if self.frames.len == 0 {
                    self.frame = zeroed(*CallFrame);
                    self.last_return = value;
                    return();
                }
                self.frame = self.frames[self.frames.len - 1]&;
                self.stack_top = self.stack.index_unchecked(frame.first_local);
                self.push(value);
            };
            Negate :: fn(self) = {
                val := self.pop();
                if(val.is_number().not()){
                    self.runtime_error("Operand must be a number.");
                };
                self.push(val.to_number().neg().to_value());
            };
            Add :: fn(self) = {
                rhs := self.pop();
                lhs := self.pop();
                if rhs.is_number() {
                    if !lhs.is_number() {
                        self.runtime_error("Second operand must be a number.");
                    };
                    result := add(lhs.to_number(), rhs.to_number()).to_value();
                    self.push(result);
                    return();
                };
                outline(self, lhs, rhs);
                outline :: fn(self: *Vm, lhs: Value, rhs: Value) void = {
                if rhs.is(.String) {
                    if !lhs.is(.String) {
                        self.runtime_error("Second operand must be a string.");
                    };
                    lhs := lhs.to(.String);
                    rhs := rhs.to(.String);
                    new := self.gc.alloc_uninit(u8, lhs.data.len + rhs.data.len);
                    new.slice(0, lhs.data.len).copy_from(lhs.data);
                    new.slice(lhs.data.len, new.len).copy_from(rhs.data);
                    o := self.take_string(new, true);
                    self.push(o.to_value());
                    return();
                };
                
                self.runtime_error("Operands must be numbers or strings.");
                };
            }
            Subtract :: fn(self) = self.binary_op(sub); 
            Multiply :: fn(self) = self.binary_op(mul); 
            Divide :: fn(self) = self.binary_op(div); 
            Greater :: fn(self) = self.binary_op(gt); 
            Less :: fn(self) = self.binary_op(lt); 
            True :: fn(self) = self.push(true_value);  
            False :: fn(self) = self.push(false_value);  
            Nil :: fn(self) = self.push(nil_value);  
            Not :: fn(self) = {
                val := self.pop();
                self.push(val.is_falsy().to_value());
            }
            Equal :: fn(self) = {
                rhs := self.pop();
                lhs := self.pop();
                result := @if(rhs.is_number() && lhs.is_number(), rhs.to_number() == lhs.to_number(), lhs == rhs);
                self.push(result.to_value());
            }
            Print :: fn(self) = {
                value := self.pop();
                self'print_callback(Vm.raw_from_ptr(self), self.user_data, value);
            };
            DefineGlobal :: fn(self, name: Value) = {
                value := self.pop();
                @debug_assert(name.is(.String), "LOX_ICE: DefineGlobal expected string name.");
                self.globals&.insert(name.to(.String), value, self.gc);
            };
            GetGlobal :: fn(self, name: Value) = {
                @debug_assert(name.is(.String), "LOX_ICE: GetGlobal expected string name.");
                report_error :: fn(self: *Vm, name: Value) Never #noinline = 
                    self.runtime_error2(@tfmt("Accessed undeclared global variable: %", name.to(.String)[].data));
                value := self.globals&.get(name.to(.String)) 
                    || report_error(self, name);
                    
                self.push(value);
            }
            SetGlobal :: fn(self, name: Value) = {
                @debug_assert(name.is(.String), "LOX_ICE: SetGlobal expected string name.");
                new := self.globals&.insert(name.to(.String), self.peek(), self.gc);
                @if(new) self.runtime_error("Accessed undeclared global variable.");
            };
            SetLocal :: fn(self, idx: i64) = {
                frame := self.frame;
                self.stack[frame.first_local + idx] = self.peek();
            };
            GetLocal :: fn(self, idx: i64) = {
                frame := self.frame;
                self.push(self.stack[frame.first_local + idx]);
            };
            SetUpvalue :: fn(self, idx: i64) = {
                frame := self.frame;
                frame.upvalues[idx].location[] = self.peek();
            };
            GetUpvalue :: fn(self, idx: i64) = {
                frame := self.frame;
                self.push(frame.upvalues[idx].location[]);
            };
            Closure :: op_closure;
            CloseUpvalue :: fn(self) = {
                self.close_upvalues(self.stack_top.offset(-1));
                _ := self.pop();
            };
            Pop :: fn(self) = {
                _ := self.pop();
            };
            JumpIfFalse :: fn(self) = {
                ip := self.frame.ip&;
                distance := self.read_u16();
                if self.peek().is_falsy() {
                    ip[] = ip[].offset(distance);
                };
            };
            Jump :: fn(self) = {
                ip := self.frame.ip&;
                distance := self.read_u16();
                ip[] = ip[].offset(distance);
            };
            Loop :: fn(self) = {
                ip := self.frame.ip&;
                distance := -self.read_u16();
                ip[] = ip[].offset(distance);
                self.maybe_collect_garbage();
            };
            Class :: fn(self, name: Value) #noinline = {
                obj := self.allocate_obj(ObjClass);
                obj.name = name.to(.String);
                self.push(obj.obj&.to_value());
            };
            GetProperty :: fn(self, name: Value) = {
                it, n := self.check_property(name);
                value := it.fields&.get(n)
                    || self.bind_method(it, n)
                    || self.undefined_property(n);
                self.push(value);
            };
            SetProperty :: fn(self, name: Value) = {
                value := self.pop();
                it, n := self.check_property(name);
                it.fields&.insert(n, value, self.gc);
                self.push(value);
            };
            Method :: fn(self, name: Value) #noinline = {
                closure := self.pop();
                class := self.peek().to(.Class);
                class.methods&.insert(name.to(.String), closure, self.gc);
            };
            Invoke :: fn(self, name: Value, arg_count: i64) = {
                name := name.to(.String);
                receiver := self.peek(arg_count);  // :ThisSlotZero
                @if(!receiver.is(.Instance)) self.runtime_error("only instances have properties");
                it := receiver.to(.Instance);
                
                if it.fields&.get(name) { callee |
                    self.stack_top.offset(-arg_count - 1)[] = callee;  // :ThisSlotZero
                    return self.call_value(callee, arg_count)
                };
                self.invoke(it.class, name, arg_count);
            }
            Inherit :: fn(self) #noinline = {
                subclass := self.pop().to(.Class);
                superclass := self.peek();
                @if(!superclass.is(.Class)) self.runtime_error("can only inherit from class");
                each superclass.to(.Class)[].methods& { k, v |
                    subclass.methods&.insert(k, v, self.gc);
                };
            }
            GetSuper :: fn(self, name: Value) = {
                super := self.pop().to(.Class);
                this := self.pop();
                bound := self.bind_method(super, name.to(.String), this)
                    || self.undefined_property(name.to(.String));
                self.push(bound);
            }
            InvokeSuper :: fn(self, name: Value, arg_count: i64) = {
                super := self.pop().to(.Class);
                self.invoke(super, name.to(.String), arg_count);
            }
});

check_property :: fn(self: *Vm, name: Value) Ty(*ObjInstance, *ObjString) #inline = {
    it := self.pop();
    @if(!it.is(.Instance)) self.runtime_error("only instances have properties");
    (it.to(.Instance), name.to(.String))
}

fn invoke(self: *Vm, class: *ObjClass, name: *ObjString, arg_count: i64) void = {
    method := class.methods&.get(name) 
        || self.undefined_property(name);
    self.call_value(method, arg_count);
}

fn bind_method(self: *Vm, it: *ObjInstance, name: *ObjString) ?Value = {
    self.bind_method(it.class, name, it.obj&.to_value())
}

fn bind_method(self: *Vm, class: *ObjClass, name: *ObjString, receiver: Value) ?Value #inline = {
    method := class.methods&.get(name) || return(.None);
    bound := self.allocate_obj(ObjBoundMethod);
    bound.receiver = receiver;
    bound.method = method.to(.Closure);
    (Some = bound.obj&.to_value())
}

binary_op :: fn(self: *Vm, $op: OverloadSet) void = {
    rhs := self.pop();
    lhs := self.pop();
    if !(rhs.is_number() && lhs.is_number()) {
        self.runtime_error("Operands must be numbers.");
    };
    result := op(lhs.to_number(), rhs.to_number()).to_value();
    self.push(result);
};

op_closure :: fn(self: *Vm) void = {
    it := self.new_closure(self.read_constant().to(.Function));
    self.push(it.obj&.to_value());
    enumerate it.upvalues { i, slot |
        local := self.read_byte() == 1;
        idx: i64 = self.read_byte().zext();
        self.open_upvalue(slot, idx, local);
    };
};

fn open_upvalue(self: *Vm, slot: **ObjUpvalue, idx: i64, local: bool) void #inline = {
        frame := self.frame;
        if local {
            slot[] = self.capture_upvalue(self.stack.index(frame.first_local + idx));
        } else {
            slot[] = frame.closure.upvalues[idx];
        };
}

fn capture_upvalue(self: *Vm, value: *Value) *ObjUpvalue = {
    ::ptr_utils(ObjUpvalue);
    // dedup so they share a slot when closed even if referenced by multiple closures at the same nesting level. 
    link := self.open_upvalues&;
    while => !link[].is_null() && ptr_diff(link.location, value) < 0 {
        link = link.next&;
    };
    if !link[].is_null() && identical(link.location, value) {
        return link[];
    };

    it := self.allocate_obj(ObjUpvalue);
    it.location = value;
    it.next = link[];
    link[] = it;
    it
}

fn close_upvalues(self: *Vm, last: *Value) void = {
    open := self.open_upvalues&;
    ::ptr_utils(@type open[][]);
    while => !open[].is_null() && ptr_diff(last, open.location) >= 0 {
        open.closed = open.location[];
        open.location = open.closed&;
        open[] = open.next;
    }
}

fn call_value(self: *Vm, callee: Value, arg_count: i64) void = {
    if !callee.is_obj() {
        self.runtime_error("tried to call non-function");
    }
    f := @match(callee.to_obj()[].type) {
        fn Closure() => callee.to(.Closure);
        fn BoundMethod() => {
            it := callee.to(.BoundMethod)[];
            self.stack_top.offset(-arg_count - 1)[] = it.receiver;  // :ThisSlotZero
            it.method
        }
        fn Native() => {
            callee := callee.to(.Native);
            args := self.stack_top.offset(-arg_count).slice(arg_count);
            result := callee'function(self, args);
            self.stack_top = self.stack_top.offset(-arg_count - 1);
            self.push(result);
            return()
        }
        fn Class() => {
            obj := self.allocate_obj(ObjInstance);
            obj.class = callee.to(.Class);
            self.push(obj.obj&.to_value());
            
            callee = obj.class.methods&.get(self.init_string)
                || return(@if(arg_count != 0, self.runtime_error("missing init()"), ()));
            this := self.pop();
            self.stack_top.offset(-arg_count - 1)[] = this;  // :ThisSlotZero
            callee.to(.Closure)
        };
        @default => self.runtime_error("tried to call non-function");
    };
    if arg_count != f.arity {
        self.runtime_error2(@tfmt("expected % arguments but got %", f.arity, arg_count));
    }
    s := ptr_diff(self.stack.ptr, self.stack_top);
    caller_aot := !self.frame.function.aot.is_null();
    self.frames&.push(
        closure = f, ip = f.chunk.code.index_unchecked(0), 
        first_local = s - arg_count - 1, 
    );
    self.frame = self.frames[self.frames.len - 1]&;
    
    if !self.frame.function.aot.is_null() {
        f := bit_cast_unchecked(rawptr, OpFn, self.frame.function.aot);
        return f(self);
    }; 
    // :FUCKED :FUCKED :FUCKED
    // TODO: wtf? this is super slow. somehow this breaks the sorting in main_thread_pump?????????????
    //       so a bunch of trivial shit doesn't get inlined and it's like 3x slower because you're spilling all your registers for raw() in @is or whatever
    // @if(caller_aot) self.run();
    if caller_aot {
        f := bit_cast_unchecked(rawptr, OpFn, self.xxxxx);
        return f(self);
    };
}

#inline fn read_byte(self: *Vm) u8 = {
    ip := self.frame.ip&;
    b := ip[][];
    ip[] = ip[].offset(1);
    b
}

#inline fn read_u16(self: *Vm) i64 = {
    ip := self.frame.ip&;
    a := bit_cast_unchecked(*u8, *u16, ip[])[];  // TODO: is alignment real?
    ip[] = ip[].offset(2);
    a.zext()
}

#inline fn read_constant(self: *Vm) Value = {
    index := @if(ConstEncoding == u8, @as(i64) self.read_byte().zext(), self.read_u16());
    chunk := self.frame.function.chunk&;
    chunk.constants&[index]
}

fn push(self: *Vm, value: Value) void = {
    @debug_assert(!identical(self.stack.end_pointer(), self.stack_top));
    self.stack_top[] = value;
    self.stack_top = self.stack_top.offset(1);
}

fn pop(self: *Vm) Value = {
    @debug_assert(!identical(self.stack.ptr, self.stack_top));
    self.stack_top = self.stack_top.offset(1.neg());
    self.stack_top[]
}

fn peek(self: *Vm) Value = {
    self.peek(0)
}
fn peek(self: *Vm, n: i64) Value = {
    self.stack_top.offset(-1 - n)[]
}

fn reset_stack(self: *Vm) void = {
    self.stack_top = self.stack.ptr;
}

fn undefined_property(self: *Vm, name: *ObjString) Never #noinline =
    self.runtime_error2(@tfmt("undefined property '%'", name.data));

fn runtime_error(self: *Vm, $msg: Str) Never #noinline =
    self.runtime_error2(msg);

fn runtime_error2(self: *Vm, msg: Str) Never = {
    @fmt(self.errors&, "Runtime Error: %", msg);
    each_rev self.frames& { frame |
        chunk := frame.function.chunk&;
        p := chunk.code&.as_ptr();
        i := p.ptr_diff(frame.ip);
        // aot doesn't give debug info because it doesn't track ip
        line := @if(chunk.lines.len != 0, chunk.lines[i], -1);  
        @fmt(self.errors&, "\n[line %] in %", line, frame.function.name);
    };
    except := self.except 
        || panic(self.errors&.items());
    throw(except);
}

fn flush_debug(self: *Vm) void = {
    print(self.debug&.items());
    self.debug&.clear();
}

fn show_vm_state(self: *Vm, out: *List(u8)) void = {
    @fmt(out, "       stack:");
    for(self.stack.ptr, self.stack_top) {slot|
        @fmt(out, "[ % ]", slot);
    };
    if false {
    @fmt(out, "\n");
    @fmt(out, "\n      global:"); 
    each self.globals& { k, v |
        @fmt(out, "[ % = % ]", k.data, v);
    };
    };
}

fn aot_trace(self: *Vm, inst: Str) void = {
    @if(!debug_trace_execution) return();
    out := self.debug&;
    self.show_vm_state(out);
    @fmt(out, "\n%\n", inst); 
    self.flush_debug();
}

fn trace_inst(self: *Vm) void = {
    @if(!debug_trace_execution) return();
    out := self.debug&;
    self.show_vm_state(out);
    @fmt(out, "\n"); 
    p := self.frame.function.chunk.code&.as_ptr();
    i := p.ptr_diff(self.frame.ip);
    self.frame.function.chunk&.dis_inst(out, i);
    self.flush_debug();
}

#use("@/examples/lox/value.fr");
#use("@/examples/lox/chunk.fr");

fix_opcodes :: fn(t: Type) Type = {
    S := Type.scope_of(t);
    for get_constants(S) { name |
        fid := FuncId.get_constant(S, name).unwrap();
        func := get_function_ast(fid, false, false, false, false);
        func.arg.bindings[0].ty = (Finished = *Vm);
        @if(!func.get_flag(.NoInline)) func.set_flag(.Inline);
    }
    t
}
