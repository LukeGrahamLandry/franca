
main :: fn() void = {
    n := 0;
    for cli_args() { it |
        it := it.str();
        if it.ends_with(".lox") {
            #use("@/lib/sys/fs.fr");
            src := read_entire_file_or_crash(temp(), it);
            vm := zeroed Lox'Vm;
            init(vm&);
            vm&.interpret(src);
            vm&.drop();
            n += 1;
        };
    };
    @assert(n > 0, "USAGE: pass .lox files as cli arguments");
}

Lox :: {
// ugh: my language does not spark joy :(
::ptr_utils(u8);
::ptr_utils(X.Value);
::ptr_utils(X.Obj);
::if(X.Value);
X :: @struct {
    #reexport("@/examples/lox/chunk.fr");
    #reexport("@/examples/lox/value.fr");
    #reexport("@/examples/lox/vm.fr");
    #reexport("@/examples/lox/scanner.fr");
    #reexport("@/examples/lox/compile.fr");
};
X
};
