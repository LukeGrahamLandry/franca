/// predecessor of this code: https://github.com/LukeGrahamLandry/Lox
/// based on Crafting Interpreters by Robert Nystrom (https://craftinginterpreters.com).
/// https://github.com/munificent/craftinginterpreters/tree/4a840f70f69c6ddd17cfef4f6964f8e1bcd8c3d4/c (MIT)
/// this is a bytecode vm for Lox: a dynamically typed, object oriented language. 
/// It's a pretty direct port of clox (the second implementation in the book). 
/// - aot.fr is a fun addition that's not in the book. 
/// - extensions to run loxlox: u16 constants and getc/ch/exit/print_error natives. 
/// Following that book was how I wrote my first compiler so it seems cool to use that as a test project for my new language. 
/// see also: tests/external/lox.fr

main :: fn() void = {
    n := 0;
    for cli_args() { it |
        it := it.str();
        if it.ends_with(".lox") {
            #use("@/lib/sys/fs.fr");
            src := read_entire_file_or_crash(temp(), it);
            vm := zeroed Lox'Vm;
            init(vm&);
            vm&.interpret(src);
            vm&.drop();
            n += 1;
        };
        if it == "-test" {
            lox_stmts();
            n += 1;
        };
    };
    @assert(n > 0, "USAGE: pass .lox files as cli arguments (or -test for builtin tiny test)");
}

#use("@/lib/collections/map.fr");

// also run by tests/fr/examples.fr
fn lox_stmts() = {
    #use(Lox);

    vm := zeroed(Vm);
    init(vm&);
    vm&.interpret("return -(1 + 2);");
    assert_eq(vm.last_return.to_number(), 3.0.neg());
    
    vm&.interpret("return 3 - 1;");
    assert_eq(vm.last_return.to_number(), 2.0);
    
    vm&.interpret("return !true;");
    assert_eq(vm.last_return.to_bool(), false);
    
    vm&.interpret("return !(3 > 5) == 3 <= 5;");
    assert_eq(vm.last_return.to_bool(), true);
    
    vm&.interpret("return \"hello\" == \"world\";");
    assert_eq(vm.last_return.to_bool(), false);
    
    vm&.interpret("return \"hello world\" == \"hello\" + \" world\";");
    assert_eq(vm.last_return.to_bool(), true);
    
    vm&.interpret("var a = 123; // comment!\n return a;");
    assert_eq(vm.last_return.to_number(), 123.0);
    
    vm&.interpret("var a = 123; a = 456; return a;");
    assert_eq(vm.last_return.to_number(), 456.0);
    vm&.interpret("{ var b = 123; b = 456; return b; }");
    assert_eq(vm.last_return.to_number(), 456.0);
    
    vm&.interpret("{ var b = 1; if (b == 1) { b = 2.5; } return b; }");
    assert_eq(vm.last_return.to_number(), 2.5);
    
    vm&.interpret("{ var b = 1; if (b == 1) { b = 5; } else { b = 4; } return b; }");
    assert_eq(vm.last_return.to_number(), 5.0);
    
    vm&.interpret("{ var b = 2; if (b == 1) { b = 4; } else { b = 3; } return b; }");
    assert_eq(vm.last_return.to_number(), 3.0);
    
    vm&.interpret("{ var c = 0; var a = 0; while (c < 3) a = a + (c = c + 1.0); return a; }");
    assert_eq(vm.last_return.to_number(), 6.0);
    vm&.interpret("{ var a = 0; for (var c = 0; c < 3; c = c + 1) a = a + c + 1.0; return a; }");
    assert_eq(vm.last_return.to_number(), 6.0);
    
    vm&.interpret("fun fib(n) { if (n < 2) return n; return fib(n - 2) + fib(n - 1); } return fib(6);");
    assert_eq(vm.last_return.to_number(), 8.0);
    vm&.interpret("{ fun fib2(n) { if (n < 2) return n; return fib2(n - 2) + fib2(n - 1); } return fib2(6); }");
    assert_eq(vm.last_return.to_number(), 8.0);
    
    // if without else needs pop so new locals aren't offset. 
    vm&.interpret("{ var a = 1; if (a == 0) return 111; var b = a; return b; }");
    assert_eq(vm.last_return.to_number(), 1);

    // close upvalues forward in stack not backward in stack when returning. 
    vm&.interpret("""{ var s = ""; fun f(s2) { s = s + s2; } f("a"); f("b"); return s; }""");
    @assert_eq(vm.last_return, vm&.copy_string("ab").to_value());
    
    vm&.interpret(src);
    
    vm&.drop();
}

src :: """
return;
""";

Lox :: {
// ugh: my language does not spark joy :(
::ptr_utils(u8);
::ptr_utils(X.Value);
::ptr_utils(X.Obj);
::if(X.Value);
X :: @struct {
    #reexport("@/examples/lox/chunk.fr");
    #reexport("@/examples/lox/value.fr");
    #reexport("@/examples/lox/vm.fr");
    #reexport("@/examples/lox/scanner.fr");
    #reexport("@/examples/lox/compile.fr");
};
X
};
