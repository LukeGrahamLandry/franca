//! I value doing thing without depending on an objective-c compiler but it does come at a readablility cost. 

#include_std("lib/sys/objective_c.fr");

SappMacos :: @struct(
    Impl :: @struct(
        flags_changed_store: u32,
        mouse_buttons: u8,
        window: ObjCId, // *NSWindow,
        tracking_area: ObjCId, // *NSTrackingArea,
        keyup_monitor: ObjCId,
        app_dlg: ObjCId, // *SappMacos.AppDelegate, 
        win_dlg: ObjCId, // *SappMacos.WindowDelegate,
        view: ObjCId, // *SappMacos.View,
        cursors: EnumMap(Sapp.MouseCursor, ObjCId), // *NSCursor),
        mtl_device: ObjCId, // MTLDevice,
        classes: SappMacos.Classes,
    ),
    
    Classes :: @struct(
        MyAppDelegate: ObjCId #declare #extends(NSObject) #implements(NSApplicationDelegate),
        MyWindow: ObjCId #declare #extends(NSWindow),
        MyWindowDelegate: ObjCId #declare #extends(NSObject) #implements(NSWindowDelegate),
        MyView: ObjCId #declare #extends(MTKView),  // TODO: if not metal, NSOpenGLView
        NSCursor: ObjCId,
        NSApplication: ObjCId,
        NSApp: ObjCId,
        NSEvent: ObjCId,
    ),
);

fn run(m: *SappMacos.Impl, desc: *Sapp.Desc) Never = {
    sapp := m.common();
    c := m.classes&;
    
    register_objective_c_classes(m);
    @objc c.NSApplication.sharedApplication();

    // set the application dock icon as early as possible, otherwise
    // the dummy icon will be visible for a short time
    sapp.set_icon(sapp.desc.icon&);
    m.app_dlg = @objc init(@objc alloc(c.MyAppDelegate));
    @objc c.NSApp.set_delegate(m.app_dlg);

    // TODO: figure out what type it wants me to pass it for callbacks
    // workaround for "no key-up sent while Cmd is pressed" taken from GLFW:
    //NSEvent* (^keyup_monitor)(NSEvent*) = ^NSEvent* (NSEvent* event) {
    keyup_monitor: rawptr : fn(event: ObjCId) ObjCId = {
        flags := @objc @as(i64) event.modifierFlags();
        NSEventModifierFlagCommand :: 1.shift_left(20);
        if flags.bit_and(NSEventModifierFlagCommand) != 0 {
            @objc sendEvent(@objc NSApp.keyWindow(), event);
        };
        event
    };
    NSEventMaskKeyUp :: 1.shift_left(11);
    m.keyup_monitor = @objc c.NSEvent.addLocalMonitorForEventsMatchingMask(NSEventMaskKeyUp, handler = keyup_monitor);

    @objc c.NSApp.run();
    // NOTE: [NSApp run] never returns, instead cleanup code
    // must be put into applicationWillTerminate
    unreachable()
}

fn keytable(self: *SappMacos.Impl) []Sapp.Keycode = {
    keys :: fn(a: FatExpr) FatExpr #macro = {
        T :: Sapp.Keycode;
        N :: 256;
        a := ast_alloc().alloc(T, N);
        each a&.items() { e |
            a[const_eval(i64)(e.parts()[0])] = const_eval(T)(e.parts()[1]);
        };
        @literal a
    };
    @keys(
        (0x1D, ._0),
        (0x12, ._1),
        (0x13, ._2),
        (0x14, ._3),
        (0x15, ._4),
        (0x17, ._5),
        (0x16, ._6),
        (0x1A, ._7),
        (0x1C, ._8),
        (0x19, ._9),
        (0x00, .A),
        (0x0B, .B),
        (0x08, .C),
        (0x02, .D),
        (0x0E, .E),
        (0x03, .F),
        (0x05, .G),
        (0x04, .H),
        (0x22, .I),
        (0x26, .J),
        (0x28, .K),
        (0x25, .L),
        (0x2E, .M),
        (0x2D, .N),
        (0x1F, .O),
        (0x23, .P),
        (0x0C, .Q),
        (0x0F, .R),
        (0x01, .S),
        (0x11, .T),
        (0x20, .U),
        (0x09, .V),
        (0x0D, .W),
        (0x07, .X),
        (0x10, .Y),
        (0x06, .Z),
        (0x27, .APOSTROPHE),
        (0x2A, .BACKSLASH),
        (0x2B, .COMMA),
        (0x18, .EQUAL),
        (0x32, .GRAVE_ACCENT),
        (0x21, .LEFT_BRACKET),
        (0x1B, .MINUS),
        (0x2F, .PERIOD),
        (0x1E, .RIGHT_BRACKET),
        (0x29, .SEMICOLON),
        (0x2C, .SLASH),
        (0x0A, .WORLD_1),
        (0x33, .BACKSPACE),
        (0x39, .CAPS_LOCK),
        (0x75, .DELETE),
        (0x7D, .DOWN),
        (0x77, .END),
        (0x24, .ENTER),
        (0x35, .ESCAPE),
        (0x7A, .F1),
        (0x78, .F2),
        (0x63, .F3),
        (0x76, .F4),
        (0x60, .F5),
        (0x61, .F6),
        (0x62, .F7),
        (0x64, .F8),
        (0x65, .F9),
        (0x6D, .F10),
        (0x67, .F11),
        (0x6F, .F12),
        (0x69, .F13),
        (0x6B, .F14),
        (0x71, .F15),
        (0x6A, .F16),
        (0x40, .F17),
        (0x4F, .F18),
        (0x50, .F19),
        (0x5A, .F20),
        (0x73, .HOME),
        (0x72, .INSERT),
        (0x7B, .LEFT),
        (0x3A, .LEFT_ALT),
        (0x3B, .LEFT_CONTROL),
        (0x38, .LEFT_SHIFT),
        (0x37, .LEFT_SUPER),
        (0x6E, .MENU),
        (0x47, .NUM_LOCK),
        (0x79, .PAGE_DOWN),
        (0x74, .PAGE_UP),
        (0x7C, .RIGHT),
        (0x3D, .RIGHT_ALT),
        (0x3E, .RIGHT_CONTROL),
        (0x3C, .RIGHT_SHIFT),
        (0x36, .RIGHT_SUPER),
        (0x31, .SPACE),
        (0x30, .TAB),
        (0x7E, .UP),
        (0x52, .KP_0),
        (0x53, .KP_1),
        (0x54, .KP_2),
        (0x55, .KP_3),
        (0x56, .KP_4),
        (0x57, .KP_5),
        (0x58, .KP_6),
        (0x59, .KP_7),
        (0x5B, .KP_8),
        (0x5C, .KP_9),
        (0x45, .KP_ADD),
        (0x41, .KP_DECIMAL),
        (0x4B, .KP_DIVIDE),
        (0x4C, .KP_ENTER),
        (0x51, .KP_EQUAL),
        (0x43, .KP_MULTIPLY),
        (0x4E, .KP_SUBTRACT),
    )
}

