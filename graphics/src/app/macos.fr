fn otherMouseDown(view: ObjCId, sel: ObjCSelector, event: ObjCId) void = {
//- (void)otherMouseDown:(NSEvent*)event {
    sapp.gl_make_current();
    sapp.macos_mouse_update_from_nsevent(event, false);
    if (2 == event.buttonNumber) {
        sapp.macos_mouse_event(.MOUSE_DOWN, SAPP_MOUSEBUTTON_MIDDLE, sapp.macos_mods(event));
        sapp.macos.mouse_buttons |= (1<<SAPP_MOUSEBUTTON_MIDDLE);
    }
}

fn otherMouseUp(view: ObjCId, sel: ObjCSelector, event: ObjCId) void = {
//- (void)otherMouseUp:(NSEvent*)event {
    sapp.gl_make_current();
    sapp.macos_mouse_update_from_nsevent(event, false);
    if (2 == event.buttonNumber) {
        sapp.macos_mouse_event(.MOUSE_UP, SAPP_MOUSEBUTTON_MIDDLE, sapp.macos_mods(event));
        sapp.macos.mouse_buttons &= (1<<SAPP_MOUSEBUTTON_MIDDLE);
    }
}

fn otherMouseDragged(view: ObjCId, sel: ObjCSelector, event: ObjCId) void = {
//- (void)otherMouseDragged:(NSEvent*)event {
    sapp.gl_make_current();
    sapp.macos_mouse_update_from_nsevent(event, false);
    if (2 == event.buttonNumber) {
        if (sapp.mouse.locked) {
            sapp.mouse.dx = [event deltaX];
            sapp.mouse.dy = [event deltaY];
        }
        sapp.macos_mouse_event(.MOUSE_MOVE, SAPP_MOUSEBUTTON_INVALID, sapp.macos_mods(event));
    }
}

