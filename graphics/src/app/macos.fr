//- (void)mouseMoved:(NSEvent*)event {
    sapp.gl_make_current();
    sapp.macos_mouse_update_from_nsevent(event, false);
    if (sapp.mouse.locked) {
        sapp.mouse.dx = [event deltaX];
        sapp.mouse.dy = [event deltaY];
    }
    sapp.macos_mouse_event(.MOUSE_MOVE, SAPP_MOUSEBUTTON_INVALID , sapp.macos_mods(event));
}

fn mouseDragged(view: ObjCId, sel: ObjCSelector, event: ObjCId) void = {
//- (void)mouseDragged:(NSEvent*)event {
    sapp.gl_make_current();
    sapp.macos_mouse_update_from_nsevent(event, false);
    if (sapp.mouse.locked) {
        sapp.mouse.dx = [event deltaX];
        sapp.mouse.dy = [event deltaY];
    }
    sapp.macos_mouse_event(.MOUSE_MOVE, SAPP_MOUSEBUTTON_INVALID , sapp.macos_mods(event));
}

fn rightMouseDragged(view: ObjCId, sel: ObjCSelector, event: ObjCId) void = {
//- (void)rightMouseDragged:(NSEvent*)event {
    sapp.gl_make_current();
    sapp.macos_mouse_update_from_nsevent(event, false);
    if (sapp.mouse.locked) {
        sapp.mouse.dx = [event deltaX];
        sapp.mouse.dy = [event deltaY];
    }
    sapp.macos_mouse_event(.MOUSE_MOVE, SAPP_MOUSEBUTTON_INVALID, sapp.macos_mods(event));
}

fn scrollWheel(view: ObjCId, sel: ObjCSelector, event: ObjCId) void = {
//- (void)scrollWheel:(NSEvent*)event {
    sapp.gl_make_current();
    sapp.macos_mouse_update_from_nsevent(event, true);
    if sapp.events_enabled() {
        dx := @objc @as(f32) event.scrollingDeltaX();
        dy := @objc @as(f32) event.scrollingDeltaY();
        if (event.hasPreciseScrollingDeltas) {
            dx *= 0.1;
            dy *= 0.1;
        }
        if ((sapp.absf(dx) > 0.0f) || (sapp.absf(dy) > 0.0f)) {
            sapp.init_event(.MOUSE_SCROLL);
            sapp.event.modifiers = sapp.macos_mods(event);
            sapp.event.scroll_x = dx;
            sapp.event.scroll_y = dy;
            sapp.call_event(&sapp.event);
        }
    }
}

fn keyDown(view: ObjCId, sel: ObjCSelector, event: ObjCId) void = {
//- (void)keyDown:(NSEvent*)event {
    if (sapp.events_enabled()) {
        sapp.gl_make_current();
        mods     := sapp.macos_mods(event);
        key_code := translate_key(@objc @as(i64) event.keyCode());
        sapp.macos_key_event(.KEY_DOWN, key_code, event.isARepeat, mods);
        chars := @objc event.characters(); // NSString
        len   := @objc @as(i64) chars.length();
        if len > 0 {
            sapp.init_event(.CHAR);
            sapp.event.modifiers = mods;
            for (NSUInteger i = 0; i < len; i++) {
                codepoint := @objc @as(i64) chars.characterAtIndex(i); // unichar
                if codepoint.bit_and(0xFF00) != 0xF700 {
                    sapp.event.char_code = codepoint;
                    sapp.event.key_repeat = @objc @as(bool) event.isARepeat();
                    sapp.call_event(sapp.event&);
                };
            }
        }
        /* if this is a Cmd+V (paste), also send a CLIPBOARD_PASTE event */
        if sapp.clipboard.enabled && mods == .MODIFIER_SUPER && key_code == .V {
            sapp.init_event(.CLIPBOARD_PASTED);
            sapp.call_event(sapp.event&);
        };
    }
}

fn keyUp(view: ObjCId, sel: ObjCSelector, event: ObjCId) void = {
//- (void)keyUp:(NSEvent*)event {
    sapp.gl_make_current();
    key    := sapp.translate_key(@objc @as(i64) event.keyCode());
    repeat := @objc @as(bool) event.isARepeat();
    sapp.macos_key_event(.KEY_UP, key, repeat, sapp.macos_mods(event));
}

fn flagsChanged(view: ObjCId, sel: ObjCSelector, event: ObjCId) void = {
//- (void)flagsChanged:(NSEvent*)event {
    old_f := sapp.macos.flags_changed_store;
    new_f := @objc @as(u32) event.modifierFlags();
    sapp.macos.flags_changed_store = new_f;
    key_code := Sapp.Keycode.Invalid;
    down     := false;
    changed  := new_f.bit_xor(old_f);
    check :: fn(bit, key: Sapp.Keycode) => {
        flag := 1.shift_left(bit);
        if changed.bit_and(flag) != 0 {
            key_code = key;
            down = 0 != new_f.bit_and(flag);
        };
    };
    
    // NSEventModifierFlag
    check(17, .LEFT_SHIFT);
    check(18, .LEFT_CONTROL);
    check(19, .LEFT_ALT); // option
    check(20, .SUPER); // command

    if key_code != SAPP_KEYCODE_INVALID {
        sapp.macos_key_event(down ? .KEY_DOWN : .KEY_UP,
            key_code,
            false,
            sapp.macos_mods(event));
    }
}

fn sapp_metal_get_device() rawptr = {
    SOKOL_ASSERT(sapp.valid);
    @debug_assert(SOKOL_BACKEND.is_metal());
    const void* obj = (__bridge const void*) sapp.macos.mtl_device;
    return obj;
}

