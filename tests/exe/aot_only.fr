// This tests something that doesn't happen when running jitted at comptime 
// This is kinda unpleasant as a language semantic but it's needed to make reproducible builds work. 
// TODO: make it behave consistantally through pointers. 
main :: fn() void = {
    A :: @tagged(A: i64, B: @struct(a: i64, b: *u8), C: Array(i64, 2));
    B :: @tagged(A: i64, B: @struct(a: i64, b: i64));
    
    t1 :: {
        s := "hello";
        t0: A = (B = (a = 1, b = s.ptr));
        t0&.tag_ptr()[] = .A;
        t0
    };
    t2 := t1;
    t2&.tag_ptr()[] = .C;
    assert_eq(t2.C&[1], 0);
    
    t4 :: {
        t3: B = (B = (a = 2, b = 3));
        t3&.tag_ptr()[] = .A;
        t3
    };
    t5 := t4;
    t5&.tag_ptr()[] = .B;
    assert_eq(t5.B.b, 0);
    
    Values :: @tagged(
        Big: RawList(u8),
        Small: Ty(i64, u8),
    );
    Expr :: @tagged(
        Poison: i64,
        Value: @struct(bytes: Values, coerced: bool),
    );
    
    unit_value: Values : (Small = (0, 0));
    unit_expr: Expr : (Value = (bytes = unit_value, coerced = false));
    thing(123, unit_expr);
    thing :: fn(_: i64, e: Expr) void = {
        bytes := ptr_cast_unchecked(Expr, Array(u8, size_of(Expr)), e&)[];
        ones := 0;
        for bytes&.items() { b |
            i := @as(i64) b.zext();
            @assert_eq(true, i == 0 || i == 1, "%", i);
            ones += int(i == 1);
        };
        assert_eq(ones, 2);
    };
    
    // has_pointers so baking the slice steps and goes through dyn_bake_relocatable_value for each one. 
    C :: @tagged(A: i64, B: @struct(a: i64, b: i64), C: rawptr);
    c := @run ast_alloc().alloc_init(C, 2, fn(_) => {
        c: C = (B = (a = 0xAA, b = 0xBB));
        c&.tag_ptr()[] = .A;
        c
    });
    for(c, fn(c) => @assert_eq(c.B.b, 0));
    
    ;{
        a :: @static @as(DoNotClearOnAotBake(i64)) (it = 123);
        b :: @static @as(ClearOnAotBake(i64)) (it = 456);
        @assert((@run a.it) == 123 && (@run b.it) == 456 && a.it == 123 && b.it == 0);
    };
}
