root :: Foreign'janet().shallow_copy(ast_alloc());
main :: fn() void = {
    println(root);
    @run bootstrap(root, "target/janet.c");
    
    a := cli_args();
    if a.contains(fn(it) => it[] == "-test") {
        return run_tests();
    };
    i := a.index_of(fn(it) => it[].str().ends_with(".janet")) || 2;
    a := a.rest(i - 1);
    Janet'main(a.len.intcast(), bit_cast_unchecked(@type a.ptr, **i8, a.ptr));
}

run_tests :: fn() void = {
    S :: fn(s: CStr) *i8 = bit_cast_unchecked(CStr, *i8, s);  // ... should really do something about that
    Janet'janet_init();
    env := Janet'janet_core_env(zeroed(*Janet'JanetTable));
    Janet'janet_dostring(env, S("(print `hello, world!`)"), S("main"), zeroed(*Janet.Janet));
    Janet'janet_deinit();
}

Janet :: {
    Ffi  :: import("@/examples/import_c/ffi.fr");
    c_source := @tfmt("""
        #add_include_path "%/src/include"
        #include "target/janet.c"
        #include "%/src/mainclient/shell.c"
    """, root, root);
    Ffi'include(current_compiler_context(), c_source)
}

bootstrap :: fn(root: Str, c_out_path: Str) void = {
    start := timestamp();
    boot_path := @tfmt("%/src/boot", root);
    boot_src := collect_with_extension(boot_path, ".c").unwrap();
    core_path := @tfmt("%/src/core", root);
    core_src := collect_with_extension(core_path, ".c").unwrap();
    
    // TODO: use it through import_module
    C :: import("@/examples/import_c/lib.fr");

    write_entire_file_or_crash(@tfmt("%/src/include/janetconf.h", root), config_h);
    write_entire_file_or_crash(@tfmt("%/src/include/spawn.h", root), "#ifndef JANET_NO_SPAWN\n#error\n#endif");
    files := Str.list(temp());
    for core_src { it |
        files&.push(@tfmt("%/%", core_path, it));
    };
    for boot_src { it |
        files&.push(@tfmt("%/%", boot_path, it));
    };
    
    src := @ref u8.list(temp());
    for files { it |
        @fmt(src, """
            #add_include_path "%/src/include"
            #define JANET_BOOTSTRAP 1
            #include "%"
            #discard_static_scope 1
        """, root, it);
    };
    
    path := "target/janet_boot.out";
    c := C'new_module_and_compiler(.None);
    @assert_ne(c.m.goal.os, .macos, "TODO: #ifdef JANET_APPLE #include <AvailabilityMacros.h> :(");
    c.do_warnings = false;  // hush "non-scalar variadic argument"
    c.compile_src_or_crash(src.items());
    c.finish_aot_module(path);
    end_compile := timestamp();
    
    ok, out, err := exec_and_catch(path, @slice(root), temp());
    @assert(ok, "failed janet bootstrap\n%\n%", out.items(), err.items());
    
    write_entire_file_or_crash(c_out_path, out.items());
    end_run := timestamp();
    // this is meaningless if in an @run because it will hit a shim and need to compile the c compiler itself in the middle. 
    // @println("compile boot: %ms; run bootstrap: %ms;", end_compile - start, end_run - end_compile);
}

config_h :: """
#ifndef JANETCONF_H
#define JANETCONF_H

int strerror_r(int a, char *b, long c);

#define JANET_VERSION_MAJOR 1
#define JANET_VERSION_MINOR 41
#define JANET_VERSION_PATCH 3
#define JANET_VERSION_EXTRA "-c6b802b_FRANCA"
#define JANET_VERSION "1.41.3" JANET_VERSION_EXTRA

#define JANET_USE_STDATOMIC
// realpath(_, NULL) is actually a primitive provided by the linker -- bane of my fucking existance
#define JANET_NO_REALPATH  

#define JANET_SINGLE_THREADED

#define JANET_REDUCED_OS
#define JANET_NO_EV
#define JANET_NO_FILEWATCH
#define JANET_NO_NET
#define JANET_NO_SPAWN
#define JANET_SIMPLE_GETLINE

#endif
""";

#use("@/examples/testing.fr");
