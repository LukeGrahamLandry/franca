// this is a runtime for https://wasm4.org (which is a fantasy console where each game is a wasm module). 
// it uses their runtimes/native for the exports that draw shapes/text on the framebuffer, 
// but implements the "/backend/* with @/graphics and @/examples/import_wasm. 
// limitations: no audio. no netplay. 
//     THIS IS NOT A SANDBOX (don't run untrusted wasm modules).
// 
// pass a wasm file as a cli arg to run a cart (otherwise defaults to a builtin one).
// you can also drop a wasm file on the window to run it. 
// controls: arrows,x,z,mouse. 
// press enter to show menu. 
// press escape to exit to gallery of the examples in site/static/carts (click one to play it).
// 
// TODO: FEAT_FROM_SOURCE doesn't work in the web demo because i pretend pointers are 64 bit. 
// TODO: make the shader less ugly (need arrays)
// TODO: add to tests/gpu.fr
//       that test runner also needs to stop leaking the pool resources.
// TODO: player2 controls
// (there are more todo comments in the actual code)
// TODO: runtime.c doesn't implement w4_runtimeTraceUtf16
// TODO: do i want to auto save disk like their native version? 
//       rn you have to manually do it in the menu because i find it annoying to spew files when im testing. 
//       should probably put them next to the cart instead of with short name in cwd. 
//

// compile builtin carts to native code at comptime instead of including the wasm module as bytes so starts up faster. 
FEAT_AOT_CART :: true;
// false can only run builtin carts (and gets you a smaller binary if AOT_CART=false because doesn't have to include the wasm jit)
FEAT_LOADER :: true;
// build wasm4/examples/(watris,platformer-test,multiplayer) with import_c and include them as builtin carts. 
FEAT_FROM_SOURCE :: true 
    && !GRAPHICS_TARGET_WEB;  // TODO
builtin_franca_carts: []FuncId : @const_slice(MandelbrotCart);
// prebuilt files in wasm4/site/static/carts to be bundled into the exe.
// note: these are the (CC BY-NC-SA 4.0) blobs submitted to wasm4.org, might not be reproducible, etc.
builtin_static_carts: []Str : empty();  // @const_slice("watris");

wasm4 :: fn() = group(
    url = "https://github.com/aduros/wasm4/archive/bed690f456bfa716ed21d410162c1c6e7c4e9c6c.tar.gz",
    legacy = "20894af584ebe86d72382c3712d9c0de281302fb677f4b69291d78511e91cb07",
    discard = @const_slice("cli", "devtools", "scripts", "test", "runtimes/web", "site/src", "site/blog"),
);
Wasm :: import("@/examples/import_wasm/runtime.fr");
Ffi :: import("@/examples/import_c/ffi.fr");
Viewer :: import("@/examples/gpu/viewer.fr");
#use("@/graphics/lib.fr");

Game :: @struct {
    rt: Wasm.Engine;
    memory: SaneRawList(u8);
    update: Wasm.Callable;
    disk: Wasm4.w4_Disk;  // TODO: persist this?
    active: bool;
    cart: Cart;
    instance: *Wasm.Instance;  // need this to access globals for save/load state
};

State :: @struct {
    WIDTH :: 500; HEIGHT :: 500;
    menu_pipe: Sgl.Pipeline;
    carts: []Cart;
    draw: Sgl.Self;
    mouse_pos: Vec2;  // event pixel coordinates
    dirty: bool;
    arena: Arena.Allocator;
    hovered: i64;  // annoying that i update this in rendering instead of event but it lets me not paste the coordinate math twice
    loaded_carts: bool;
    text: Sdtx.Self;
    
    game_pipe: Sg.Pipeline;
    game: Game;
    exports: Wasm.ExportsEnv;
    frame: Sg.Buffer;
    uni: Shaders.Uni;
    key_pressed: u8;
    mouse_pressed: u8;
    disable_gallery: bool;
    
    screen: @enum(Game, Menu, Gallery);
};

Cart :: @struct {
    name: Str;
    logo: Sg.Image = (id = 0);
    impl: @tagged(
        Raw: []u8, 
        Aot: @struct(mod: *Wasm.Module, hash: *Sha256.Digest),
    );
};

fn on_init(state: *State, sapp: *Sapp.Self, sg: *Sg.Self) void = {
    // TODO: this is annoying because when using easy_init can't do desc at all
    //       but want to use easy_init so it works with tests/gpu.fr 
    //       but also this breaks that test anyway because the sg was already used so this is pointless. 
    R :: Sg.Image;
    @if(FEAT_LOADER)
    init_pool(sg.pools&.index(R.Tag), sg.desc.allocator, 1024, size_of(R.T));  // SNEAK

    sapp.desc.enable_dragndrop = FEAT_LOADER;
    state.arena = init(page_allocator, 1.shift_left(16));
    init_gfx(state, sg);
    a := state.arena&.borrow();
    state.exports = (_ = init(a));
    fill_exports(state.exports&, state.game&);
    state.set_scale(sapp);
    state.carts = builtin_carts;
    
    for cli_args() { it |
        it := it.str();
        @if(it.ends_with(".wasm"))
        if read_entire_file(a, it) { wasm |
            @if(!FEAT_LOADER) panic("wasm4 FEAT: runtime loading is disabled");
            state.start_game(impl = (Raw = wasm), name = it);
            return();
        };
    };
    
    @run @assert(FEAT_LOADER || builtin_carts.len() != 0, "wasm4 FEAT: this program will do nothing");
    if state.carts.len > 0 {
        state.start_game(state.carts[0]);
    };
    state.screen = @if(state.game.active, .Game, .Gallery);
    state.dirty = true;
}

fn load_carts(state: *State, sg: *Sg.Self) void = {
    start := timestamp();
    a := state.arena&.borrow();
    carts_dir := @tfmt("%/site/static/carts", wasm4());  // TODO: make this an arg
    #use("@/examples/testing.fr");
    @if_let(collect_with_extension(carts_dir, ".wasm")) fn Ok(files) => {
        carts := @ref Cart.list(files.len, a);
        carts.push_all(builtin_carts);
        for files { it |
            name := it.slice(0, it.len - ".wasm".len());
            if read_entire_file(a, @tfmt("%/%.wasm", carts_dir, name)) { wasm_bytes |
                cart: Cart = (impl = (Raw = wasm_bytes), name = name.shallow_copy(a));
                @if(Viewer.FEAT_PNG)
                if read_entire_file(temp(), @tfmt("%/%.png", carts_dir, name)) { logo |
                    break :: local_return;
                    img, _0, _1 := Viewer'load_texture_from_data(sg, logo)
                        .or(fn(msg) => { eprintln(msg); break(); });
                
                    // TODO: handle POOL_EXHAUSTED
                    // TODO: this is dumb, use an atlas
                    // TODO: could be cool to automate just rendering the first frame of the game and using that instead of the committed thumbnails
                    cart.logo = img;
                };
                carts.push(cart);
            };
        };
        state.carts = carts.items();
        @eprintln("found % carts in %ms", carts.len, timestamp() - start);    // :SLOW
    };
}

fn start_game(state: *State, cart: Cart) void = {
    state.dirty = true;
    game := state.game&;
    rt := game.rt&;
    if game.active {
        drop(rt);
        game[] = zeroed(Game);
    };
    game.active = true;
    game.cart = cart;
    a := general_allocator();
    rt[] = init_for_jit(a, "");
    @eprintln("loading (%): %", cart.impl&.tag(), cart.name);
    mod := @match(cart.impl) {
        fn Raw(wasm) => {
            @if(@run (!FEAT_LOADER && FEAT_AOT_CART)) panic("FEAT_LOADER=false, cannot load raw cart");  // show the compiler it's unreachable
            // could not bother so it would work for debug builds if those were bigger?
            @assert_le(wasm.len, 1.shift_left(16), "(arbitrary wasm4 cart size limit)");
            rt.compile(wasm)
        }
        fn Aot(it) => it.mod;
    };
    
    // TODO: move this logic to runtime.fr so everyone gets it 
    // TODO: tecnically should be <<33, memory access instructions have u32+u32 static+dynamic range. 
    //       could track max static offset and convert them to faults if it's past memory.max?
    // on native, over allocate so bounds checks are free 
    // (will only cost page table entries if we trust the os to overcommit). 
    // however if doing nested wasm, it doesn't expose virtual memory so reusing after munmap i have to zero the whole thing which is expensive. 
    web, page := (query_current_arch() == .wasm32, 1.shift_left(16));
    buf := page_allocator.alloc_uninit(u8, @if(web, page, 1.shift_left(32)));  
    if !web {
        Syscall'mprotect(u8.raw_from_ptr(buf.ptr.offset(page)), buf.len - page, 0);
    };
    
    rt.memories&.push(buf, rt.gpa);
    game.memory = (ptr = buf.ptr, cap = page, len = page);
    state.run_menu_item(.ImportDisk);

    // w4_runtimeInit zeroes the memory so must be called before instantiate (which copies in active data sections)
    Wasm4'w4_runtimeInit(game.memory.ptr, game.disk&);
    
    instance := instantiate(rt, mod, state.exports&);
    state.game.instance = instance;
    
    game.update = get_fn("update");
    get_fn :: fn(name: Str) => {
        it := instance.exports&.get(name)
            || (Function = (callee = fn(_: rawptr) void = (), context = zeroed(rawptr)));
        @assert(it&.is(.Function), "expected exports[%] to be a function", name);
        it.Function
    };
    
    // instantiate() already called the Start section of the module if present. 
    // idk why wasi wants redundant blessed names instead of just using ^ 
    // but this matches what the other wasm4 runtimes do. 
    // `start` is specified by wasm4 itself. 
    names := @const_slice("_start", "_initialize", "start");
    for names { name |
        // TODO: provide easy way to call a Callable after checking its signature
        start := get_fn(name);
        bit_cast_unchecked(rawptr, @FnPtr(_: rawptr) void, start.callee)(start.context);
    };
    state.screen = .Game;
}

fn init_gfx(state: *State, sg: *Sg.Self) void = {
    @assert(!(query_current_arch() == .x86_64 && query_current_os() == .macos), "TODO: old metal doesn't like non-const u32 buffer");
    state.game_pipe = sg.make(
        shader = sg.make(choose_shader_impl(SOKOL_BACKEND, Shaders)),
    );
    state.frame = sg.make(
        usage = .DYNAMIC,
        size = cast(W * W).int() / 4,
    );
    
    state.draw&.setup(allocator = general_allocator(), sg = sg);
    init_pipeline(state.draw&, state.menu_pipe&, sg, ());
    
    state.text&.setup(sg = sg, allocator = general_allocator(), fonts = @slice(Sdtx.font.cpc));
}

Shaders :: @struct {
    OutV :: @struct(pos: Vec4 #position);
    vs   :: fn(i: u32 #vertex_id) OutV = (pos = @vec(Easy'six_vertex_full_square(i), 0.0, 1.0));
    OutF :: @struct(colour: Vec4 #colour);
    fs   :: fn(
        in: OutV #input,
        uni: Uni #uniform(0), 
        frame: Buf(u32) #buffer(0),
    ) Shaders.OutF = {
        p := in.pos / uni.scale;
        x := @swizzle p.x;
        y := @swizzle p.y;
        @if(x >= W || y >= W) return(colour = vec4(0.0, 0.0, 0.0, 1.0));
        
        pixel_i := (floor(y) * W + floor(x));
        slot := frame[f32_to_u32(pixel_i) / 16];
        local_i := f32_to_i32(pixel_i).mod(16).zext();
        i := 8 * (local_i / 4);
        i += local_i.mod(4) * 2;
        c := slot.shift_right_logical(i).bit_and(0b11);
        c := @switch(c) {  // stupid :( need array
            @case(0) => uni.c0;
            @case(1) => uni.c1;
            @case(2) => uni.c2;
            @default => uni.c3;
        };
        c := c.unpack();
        if uni.paused == 1 {
            // when in the menu, still draw the last frame of the game but darkened
            c = c / 10;
        };
        (colour = @vec(@swizzle c.zyx, 1.0))
    };
    Uni :: @struct {
        // TODO: need arrays in shader translation
        c0: UByte4;
        c1: UByte4;
        c2: UByte4;
        c3: UByte4;
        scale: f32;
        paused: i32;  // bool
    };
};

fn on_render(state: *State, sapp: *Sapp.Self, sg: *Sg.Self) void = {
    is_ui := @is(state.screen, .Menu, .Gallery);
    @if(is_ui && Easy'should_skip_frame(sapp, state.dirty&)) return();
    
    sdtx := state.text.default_context&;
    memory := bit_cast_unchecked(*u8, *Wasm4.Memory, state.game.memory.ptr);
if @is(state.screen, .Menu, .Game) {
    @debug_assert(state.game.active);
    if memory.systemFlags.bit_and(Wasm4.SYSTEM_PRESERVE_FRAMEBUFFER_[]) == 0 {
        Wasm4'w4_framebufferClear();
    }
    screen_size := min(sapp.width().float().cast(), sapp.height().float().cast());
    mouse := state.mouse_pos / vec2(screen_size) * W;
    x, y := (mouse.x.cast().int().toi16(), mouse.y.cast().int().toi16());
    toi16 :: fn(a: i64) i16 #ir(.extsh, .Kw);
    Wasm4'w4_runtimeSetGamepad(0, state.key_pressed);
    Wasm4'w4_runtimeSetMouse(x, y, state.mouse_pressed);
    f := state.game.update;
    bit_cast_unchecked(rawptr, @FnPtr(_: rawptr) void, f.callee)(f.context);
    // Wasm4'w4_apuTick();  // i don't do audio thus far. 
    
    state.uni.c0._ = memory.palette&[0];
    state.uni.c1._ = memory.palette&[1];
    state.uni.c2._ = memory.palette&[2];
    state.uni.c3._ = memory.palette&[3];
    state.uni.paused = int(state.screen == .Menu).intcast();
    
    ::Array(u8, 6400);
    sg.update_buffer(state.frame, memory.framebuffer&.items());
    
    bind := zeroed Sg.Bindings;
    bind.storage_buffers&[0] = state.frame;
    Easy'glue_begin_pass(sapp, sg, zeroed Sg.PassAction);
    sg.apply_pipeline(state.game_pipe);
    ::[]Shaders.Uni;
    sg.apply_uniforms(0, state.uni&.slice(1).interpret_as_bytes());
    sg.apply_bindings(bind&);
    draw(sg = sg, base = 0, elements = 6, instances = 1);
};
    
    if state.screen == .Menu {
        sdtx.canvas(sapp, 1/4);
        i := 0;
        for_enum MenuItem { it |
            sdtx.color = @if(i == state.hovered, 0xFFFFFFFF, 0xFFAAAAAA);
            sdtx.put(@tfmt("%\n", it));
            i += 1;
        };
        sdtx.canvas(sapp, 1);
        sdtx.color = 0xFFFFFFFF;
        sdtx.pos.y = 4 * (0.5 + MenuItem.enum_count());
        sdtx.put(HELP);
        sdtx.pos.y += 1;
        sdtx.put(@tfmt("CART: %\n", state.game.cart.name));
    };
if state.screen == .Gallery {
    if FEAT_LOADER && !state.loaded_carts {
        state.load_carts(sg);
        state.loaded_carts = true;
    };
    
    sgl := state.draw&;
    sgl.defaults();
    sgl.viewport(0.intcast(), 0.intcast(), sapp.width().intcast(), sapp.height().intcast(), true);
    sgl.load_pipeline(state.menu_pipe);
    sgl.cur_matrix_mode = .TEXTURE;
    sgl.rotate(PI, 0.0, 1.0, 0.0);
    sgl.rotate(PI, 0.0, 0.0, 1.0);

    sgl.texturing_enabled = true;
    step := sqrt(state.carts.len.float()).int() + 1;
    
    screen := vec2(sapp.width().float().cast(), sapp.height().float().cast());
    scale: f32 = 1.5;
    mouse := (state.mouse_pos / screen * 2 - vec2(1)) * vec2(1, -1);
    state.hovered = -1;
    sdtx.canvas(sapp, 1/2);
    enumerate state.carts { i, cart |
        xx, yy := i.div_mod(step);
        // 1/step is sane and then fix to be -1..+1
        s := cast(1.0 / step.float()) * scale;
        x, y := (xx.float().cast(), yy.float().cast());
        h: f32 = 1;
        (x1: f32, x2: f32, y1: f32, y2: f32) := (x*s -h, (x+1)*s -h, y*s -h, (y+1)*s -h);
        sgl.color = 0xFFFFFFFF;
        if x1 < mouse.x && mouse.x < x2 && y1 < mouse.y && mouse.y < y2 {
            sgl.color = pack_rgba(1.0, 0.0, 0.0, 1.0);
            state.hovered = i;
            sdtx.color = 0xFF00FFFF;
            sdtx.put(cart.name);
        };
        
        sgl.texture(cart.logo, (id = Sg.INVALID_ID));
        sgl.begin(.QUADS);
        sgl.v2f_t2f(x1, y1, 0, 0);
        sgl.v2f_t2f(x2, y1, 1, 0);
        sgl.v2f_t2f(x2, y2, 1, 1);
        sgl.v2f_t2f(x1, y2, 0, 1);
        sgl.end();
    };
    Easy'glue_begin_pass(sapp, sg, zeroed Sg.PassAction);
    sgl.draw_layer(sg, 0);
};
    sdtx.draw_layer(0);
    sg.end_pass();
    sg.commit();
}

fn on_event(state: *State, sapp: *Sapp.Self, event: *Sapp.Event) void = {
    @match(event.type) {
        fn KEY_DOWN() => {
            menu := state.screen == .Menu;
            @match(event.key_code) {
                fn ESCAPE() => {
                    state.dirty = true;
                    sapp.set_window_title("franca/wasm4");
                    state.screen = @if(state.screen == .Gallery && state.game.active, .Game, .Gallery);
                }
                fn R() => if state.game.active {
                    state.start_game(state.game.cart);
                }
                fn ENTER() => {
                    if menu {
                        state.run_menu_item(@as(MenuItem) state.hovered);
                    } else {
                        state.screen = .Menu;
                    };
                    state.dirty = true;
                    state.hovered = 0;
                }
                fn UP() => if menu {
                    state.dirty = true;
                    state.hovered = state.hovered.sub(1).add(MenuItem.enum_count()).mod(MenuItem.enum_count());
                };
                fn DOWN() => if menu {
                    state.dirty = true;
                    state.hovered = state.hovered.add(1).mod(MenuItem.enum_count());
                };
                @default => ();
            }
        }
        fn MOUSE_DOWN() => if state.screen == .Gallery && state.hovered.ult(state.carts.len) {
            cart := state.carts[state.hovered];
            sapp.set_window_title(cart.name);
            state.start_game(cart);
        }
        fn MOUSE_MOVE() => {
            state.dirty = state.screen == .Gallery;
            state.mouse_pos = vec2(event.mouse_x, event.mouse_y);
        };
        fn RESIZED() => { 
            set_scale(state, sapp);
            state.dirty = true; 
        }
        fn FILES_DROPPED() => {
            @if(!FEAT_LOADER) return();
            @if(event.drop.len == 0) return();
            path := event.drop[0];
            buf := read_entire_file(temp(), path) || return();
            open_from_file(state, path, buf);
        };
        @default => ();
    };
    
    @if(state.screen == .Game)
    set_key_masks(event, state.mouse_pressed&, state.key_pressed&);
}

fn open_from_file(state: *State, path: Str, buf: []u8) void = {
    if buf.starts_with(Wasm.Wasm.version_magic) {
        a := state.arena&.borrow(); // :LEAK
        path = @if(path.ends_with(".wasm"), path.slice(0, path.len - 5), path);
        state.start_game(impl = (Raw = buf.shallow_copy(a)), name = path.shallow_copy(a));
        return();
    };
    if state.game.active {
        if buf.starts_with((@slice Save.MAGIC).interpret_as_bytes()) {
            @eprintln("loading (%) as memory dump of (%)", path, state.game.cart.name);
            load_state(state.game&, buf)
                .or(fn(msg) => @eprintln("FAIL: %", msg));
            return();
        };
        
        if buf.len >= 2 {
            size: i64 = buf&.pop_type(u16)[].zext();
            if size <= 1024 && (buf.len == 1024 || buf.len == size) {
                @eprintln("loading (%) as disk of (%)", path, state.game.cart.name);
                state.game.disk.size = size.trunc();
                ::Array(u8, 1024);
                state.game.disk.data&.items().slice(0, size).copy_from(buf.slice(0, size));
                return();
            }
        };
    };
    @eprintln("couldn't open dropped file (%)", path);
}

// i just send events but it wants current state of key, 
// so need to remember the old flags and just toggle the bits. 
set_key_masks :: fn(event: *Sapp.Event, mouse_pressed: *u8, key_pressed: *u8) void #once = {
    #use(Wasm4);
    bit_xor :: fn(a: u8, b: u8) u8 #ir(.xor, .Kw);
    if @is(event.type, .MOUSE_DOWN, .MOUSE_UP) {
        o := mouse_pressed[];
        X :: fn(it: Sapp.Mousebutton, $flag: u8) => 
            { o = o.bit_xor(@if(event.mouse_button == it, flag, 0)); }
        X(.LEFT, W4_MOUSE_LEFT_[]);
        X(.RIGHT, W4_MOUSE_RIGHT_[]);
        X(.MIDDLE, W4_MOUSE_MIDDLE_[]);
        mouse_pressed[] = o;
    };
    if !event.key_repeat && @is(event.type, .KEY_DOWN, .KEY_UP) {
        o := key_pressed[];
        X :: fn(it: Sapp.Keycode, $flag: u8) => 
            { o = o.bit_xor(@if(event.key_code == it, flag, 0)); }
        X(.X, W4_BUTTON_X_[]);
        X(.Z, W4_BUTTON_Z_[]);
        X(.LEFT, W4_BUTTON_LEFT_[]);
        X(.RIGHT, W4_BUTTON_RIGHT_[]);
        X(.UP, W4_BUTTON_UP_[]);
        X(.DOWN, W4_BUTTON_DOWN_[]);
        key_pressed[] = o;
    }
}

MenuItem :: @enum(Continue, SaveState, LoadState, ExportDisk, ImportDisk, ClearDisk, ResetCart, ScreenShot, Gallery);
fn run_menu_item(state: *State, it: MenuItem) void = {
    disk_path := @tfmt("%.disk", state.game.cart.name);
    state_path := @tfmt("%.dump", state.game.cart.name);
    disk := state.game.disk&;
    @match(it) {
        fn Continue() => ();
        fn SaveState() => {
            buf := save_state(state.game&);
            if !write_entire_file(state_path, buf) {
                @eprintln("SaveState: failed to write %", state_path);
            };
        }
        fn LoadState() => {
            buf := read_entire_file(temp(), state_path) || return();
            load_state(state.game&, buf)
                .or(fn(msg) => println(msg));
        }
        // TODO: their native one automatically read/write the file on start/stop. 
        fn ExportDisk() => {
            ::[]@type disk[];
            @debug_assert_le(disk.size, 1024);
            it := disk.slice(1).interpret_as_bytes().slice(0, 2 + disk.size.zext());
            if !write_entire_file(disk_path, it) {
                @eprintln("ExportDisk: failed to write to %", disk_path);
            } else {
                @eprintln("ExportDisk(%)", disk_path);
            };
        }
        fn ImportDisk() => {
            data := read_entire_file(temp(), disk_path) || return();
            @if(data.len < 2) return();
            size := data&.pop_type(u16)[];
            @if(data.len < size.zext() || size > 1024) return();
            @eprintln("ImportDisk(%)", disk_path);
            data = data.slice(0, size.zext());
            disk.size = size;
            ::Array(u8, 1024);
            disk.data&.items().slice(0, data.len).copy_from(data);
        }
        fn ClearDisk() => {
            disk.size = 0;
            state.run_menu_item(.ExportDisk);
        }
        fn ResetCart() => state.start_game(state.game.cart);
        fn Gallery() => {
            state.screen = .Gallery;
            return();
        }
        fn ScreenShot() => {
            memory := bit_cast_unchecked(*u8, *Wasm4.Memory, state.game.memory.ptr);
            ppm := screenshot(memory);
            path := "target/a.ppm";
            make_dirs_or_crash("target");
            write_entire_file_or_crash(path, ppm);
            println(path);
        }
    };
    state.screen = .Game; 
}

screenshot :: fn(memory: *Wasm4.Memory) []u8 = {
    ::Array(u8, 6400);
    w := W.cast().int();
    out := @ref u8.list(15 + w*w*3, temp());
    @fmt(out, "P6 % % 255\n", w, w);
    range(0, w) { y |
        range(0, w) { x |
            i := y*w+x;
            // TODO: be able to share this three decoding lines with the shader. to prove a point. problem is that Buf is a magic type. 
            byte: i64 = memory.framebuffer&[i / 4].zext();
            bits := byte.shift_right_logical(i.mod(4)*2).bit_and(0b11);
            c := memory.palette&[bits];
            out.reserve_type(u32)[] = c.byte_swap().shift_right_logical(8);
            out.len -= 1;
        };
    };
    out.items()
}

// TODO: this doesn't work if they mutated a table (but neither does the official one)
Save :: @struct {
    MAGIC :: "FR\x00WASM4".peek_type(i64)[];
    magic: i64;
    size: i64;
    global_count: i64;
    cart_hash: Sha256.Digest;
    disk: Wasm4.w4_Disk;
    memory: Array(u8, 1.shift_left(16));
    // globals: Array(Wasm.GlobalValue, global_count) #inline;
};

fn save_state(g: *Game) []u8 = {
    view := g.instance.view();
    size := size_of(Save) + size_of(Wasm.GlobalValue) * view.local_globals.len;
    out := @ref u8.list(size, temp());
    save := out.reserve_type(Save);
    save.magic = Save.MAGIC;
    save.size = size;
    save.global_count = view.local_globals.len;
    save.disk = g.disk;
    save.cart_hash = g.cart&.wasm_hash();
    save.memory&.items().copy_from(g.instance.memory.items());
    for view.local_globals { it |
        out.reserve_type(Wasm.GlobalValue)[] = it;
    };
    out.items()
}

fn load_state(g: *Game, buf: []u8) Result(void, Str) = {
    view := g.instance.view();
    @if(buf.len < size_of(Save)) return(Err = "truncated");
    save := buf&.pop_type(Save);
    n := view.local_globals.len * size_of(Wasm.GlobalValue);
    @if(save.magic != Save.MAGIC || save.size != size_of(Save) + n) return(Err = "bad magic");
    @if(save.global_count != view.local_globals.len) return(Err = "wrong global count for wasm module");
    @if(save.cart_hash&.items() != (@ref g.cart&.wasm_hash()).items()) return(Err = "different wasm module");
    @assert(buf.len >= n);
    
    g.instance.memory.items().copy_from(save.memory&.items());
    g.disk = save.disk;
    each view.local_globals { it |
        it[] = buf&.pop_type(Wasm.GlobalValue)[];
    };
    .Ok
}

fn wasm_hash(cart: *Cart) Sha256.Digest = 
    @match(cart.impl) { fn Raw(wasm) => Sha256'hash(wasm); fn Aot(it) => it.hash[]; };

fn set_scale(state: *State, sapp: *Sapp.Self) void = {
    state.uni.scale = min(sapp.width().float().cast(), sapp.height().float().cast()) / W;
}

fill_exports :: fn(it: *Wasm.ExportsEnv, game: *Game) void = {
    S :: Type.scope_of(Exports);
    inline_for get_constants(S) { $name |
        fid :: FuncId.get_constant(S, name[]).unwrap();
        it.insert("env", @run name[].str(), fid, game);
    };
    it.insert("env", "memory", (Memory = game.memory&));
}

// TODO: this is tedious but doing it with reflection is also tedious :(
Exports :: @struct {
    blit :: fn(g: *Game, a: u32, b: i32, c: i32, d: i32, e: i32, f: i32) void = 
        Wasm4'w4_runtimeBlit(g.memory.index(a.zext()), b, c, d, e, f);
    blitSub :: fn(g: *Game, a: u32, b: i32, c: i32, d: i32, e: i32, f: i32, gg: i32, h: i32, i: i32) void = 
        Wasm4'w4_runtimeBlitSub(g.memory.index(a.zext()), b, c, d, e, f, gg, h, i);
    line :: WrapI4 Wasm4.w4_runtimeLine;
    hline :: WrapI3 Wasm4.w4_runtimeHLine;
    vline :: WrapI3 Wasm4.w4_runtimeVLine;
    oval :: WrapI4 Wasm4.w4_runtimeOval;
    rect :: WrapI4 Wasm4.w4_runtimeRect;
    text :: fn(g: *Game, a: u32, b: i32, c: i32) void = 
        Wasm4'w4_runtimeText(g.memory.index(a.zext()), b, c);
    textUtf8 :: fn(g: *Game, a: u32, b: i32, c: i32, d: i32) void = 
        Wasm4'w4_runtimeTextUtf8(g.memory.index(a.zext()), b, c, d);
    textUtf16 :: fn(g: *Game, a: u32, b: i32, c: i32, d: i32) void = 
        Wasm4'w4_runtimeTextUtf16(bit_cast_unchecked(*u8, *u16, g.memory.index(a.zext())), b, c, d);
    tone :: WrapI4 Wasm4.w4_runtimeTone;
    diskr :: WrapPI Wasm4.w4_runtimeDiskr;
    diskw :: WrapPI Wasm4.w4_runtimeDiskw;
    trace :: fn(g: *Game, a: u32) void = 
        Wasm4'w4_runtimeTrace(g.memory.index(a.zext()));
    traceUtf8 :: WrapPI Wasm4.w4_runtimeTraceUtf8;
    traceUtf16 :: WrapP16I Wasm4.w4_runtimeTraceUtf16;
    tracef :: fn(g: *Game, a: u32, b: u32) void = 
        Wasm4'w4_runtimeTracef(g.memory.index(a.zext()), bit_cast_unchecked(*u8, rawptr, g.memory.index(b.zext())));
};
WrapPI :: fn($fid: FuncId) FuncId = (fn(g: *Game, a: u32, b: i32) = 
    fid(g.memory.index(a.zext()), b));
WrapP16I :: fn($fid: FuncId) FuncId = (fn(g: *Game, a: u32, b: i32) = 
    fid(bit_cast_unchecked(*u8, *u16, g.memory.index(a.zext())), b));
WrapI3 :: fn($fid: FuncId) FuncId = (fn(g: *Game, a: i32, b: i32, c: i32) = fid(a, b, c));
WrapI4 :: fn($fid: FuncId) FuncId = (fn(g: *Game, a: i32, b: i32, c: i32, d: i32) = fid(a, b, c, d));

MandelbrotCart :: fn() void = {
    memory :: bit_cast_unchecked(i64, *Wasm4.Memory, 0);
    w :: W.cast().int();
    M :: import("@/examples/mandelbrot.fr");
    memory.palette&[0] = 0xFF0000;
    memory.palette&[1] = 0x0000FF;
    
    max_steps, x_speed, y_speed, x_start, y_start := (45, 0.015, 0.03, -1.5, -1.0);
    pos: M.Pos = (x = x_start, y = y_start);
    range(0, w) { y |
        range(0, w) { x |
            steps := mandelbrot(pos, (x = 0, y = 0), max_steps);
            set_pixel(x, y, @if(steps == max_steps, 0, 1));
            pos.x += x_speed;
        };
        pos.x = x_start;
        pos.y += y_speed;
    };
    
    set_pixel :: fn(x: i64, y: i64, bits: i64) void = {
        i := y*w+x;
        byte := memory.framebuffer&[i / 4]&;
        shift := i.mod(4)*2;
        b: i64 = byte[].zext();
        b = b.bit_and(0b11.shift_left(shift).bit_not());
        b = b.bit_or(bits.shift_left(shift));
        byte[] = b.trunc();
    };
};

builtin_carts :: {
    carts := Cart.list(4, ast_alloc()); 
    
    for builtin_static_carts { builtin_cart_name |
        path := @tfmt("%/site/static/carts/%.wasm", wasm4(), builtin_cart_name);
        wasm := include_bytes(path);
        carts&.push(name = builtin_cart_name, impl = (Raw = wasm));
    };
    
    names := @slice("watris", "platformer-test", "multiplayer");
    // TODO: make these cachable like ffi'include so don't have to compile the c compiler every time
    @if(FEAT_FROM_SOURCE)
    for names { it |
        carts&.push(name = it, impl = (Raw = build_example(it)));
    };
    
    fr := current_compiler_context();
    for builtin_franca_carts { it |
        name := fr'vtable'mangle_name(fr.data, it).shallow_copy(ast_alloc());
        carts&.push(name = name, impl = (Raw = fr.build_franca(it)));
    };

    @if(FEAT_AOT_CART) 
    each carts { it |
        @if_let(it.impl) fn Raw(wasm) => {
            mod := import("@/examples/import_wasm/ffi.fr")'include(wasm, current_compiler_context());
            hash := ast_alloc().boxed(Sha256.Digest, Sha256'hash(wasm));
            it.impl = (Aot = (mod = mod, hash = hash));
        }; 
    };
    
    carts.items()
};

build_example :: fn(it: Str) []u8 = {
    src := @ref u8.list(temp());
    @fmt(src, """
        #add_include_path "%/examples/%/src"
        %
        #include "main.c"
    """, wasm4(), it, @if(it == "watris", """#include "utils.c" """ , ""));
    #use("@/examples/import_c/lib.fr");
    c := new_module_and_compiler(Some = target);
    c.compile_src_or_crash(src.items());
    m, ctx := (c.m, c.emitter);
    ctx.join_codegen_thread();
    chunks := {m.target.finish_module}(m);
    wasm := concat(chunks, ast_alloc());
    drop(m);
    c.arena_storage&.deinit();
    wasm
};

build_franca :: fn(c: CompCtx, update: FuncId) []u8 = {
    M :: Wasm.Qbe.Module;
    m := @uninitialized M;
    init_default_module_dyn(m&, c.vtable, target);
    
    fake_write :: fn(_: Fd, p: *u8, l: i64) i64 = {
        traceUtf8 :: fn(p: u32, l: u32) void #libc;
        traceUtf8(u8.int_from_ptr(p).trunc(), l.trunc());
        l
    };
    set_name(fake_write, "write", false);
    set_name(update, "update", true);
    set_name :: fn(dest: FuncId, src: Str, export: bool) => 
        declare_alias(m = m&, target = m&.intern(c'vtable'mangle_name(c.data, dest)), alias = @ref @as(Wasm.Qbe.Lnk) (
            id = m&.intern(src),
            export = export,
        ));
    
    fns := @slice(update, fake_write);
    wasm := c'vtable'emit_qbe_included(M.raw_from_ptr(m&), c&, fns, .ExportWithNames);
    wasm := wasm.concat(ast_alloc());
    c'vtable'drop_qbe_module(M.raw_from_ptr(m&));
    // if you want to test it in the official wasm4 runtime: 
    // write_entire_file_or_crash("target/a.wasm", wasm);
    // TODO: rn it works in mine and wasm4/web but not wasm4/native 
    wasm
}

target: Wasm.Qbe.Goal : (
    arch = .wasm32, os = .linux, type = .Exe, 
    wasm_shared_memory = false /*use active memory*/,
    // limited to one page so can't be as wasteful as i default to being
    wasm = ast_alloc().boxed(Wasm.Qbe.WasmLayout, (
        global_base = 6560,  // header of Wasm4.Memory is used for memory mapped io
        stack_size = 1024,
        import_memory = ("env", "memory"),
        null_import = false,
        embed_import_names = false,
        exceptions = false,
    )),
);

W :: Wasm4.WIDTH_[];
Wasm4 :: {
    src := @ref u8.list(temp());
    root := wasm4();
    println(root);
    files := @slice("apu.c", "framebuffer.c", "runtime.c", "util.c");
    for files { it |
        @fmt(src, """
            #add_include_path "%/runtimes/native/src"
            #include "%"
            #discard_static_scope 0
        """, root, it);
    };
    @fmt(src, """
        const uint8_t SYSTEM_PRESERVE_FRAMEBUFFER_ = SYSTEM_PRESERVE_FRAMEBUFFER;
        const uint8_t W4_BUTTON_X_ = W4_BUTTON_X;
        const uint8_t W4_BUTTON_Z_ = W4_BUTTON_Z;
        const uint8_t W4_BUTTON_LEFT_ = W4_BUTTON_LEFT;
        const uint8_t W4_BUTTON_RIGHT_ = W4_BUTTON_RIGHT;
        const uint8_t W4_BUTTON_UP_ = W4_BUTTON_UP;
        const uint8_t W4_BUTTON_DOWN_ = W4_BUTTON_DOWN;
        const uint8_t W4_MOUSE_LEFT_ = W4_MOUSE_LEFT;
        const uint8_t W4_MOUSE_RIGHT_ = W4_MOUSE_RIGHT;
        const uint8_t W4_MOUSE_MIDDLE_ = W4_MOUSE_MIDDLE;
        const float WIDTH_ = WIDTH;
        _Static_assert(WIDTH == HEIGHT);
        _Static_assert(sizeof(w4_Disk) == sizeof(short) + 1024);
    """);
    Ffi'include(src.items())
};
#use("@/examples/fetch.fr");

