// this is a runtime for https://wasm4.org (which is a fantasy console where each game is a wasm module). 
// it uses their runtimes/native for the exports that draw shapes/text on the framebuffer, 
// but implements the "/backend/* with @/graphics and @/examples/import_wasm. 
// limitations: no audio. no netplay. 
//     THIS IS NOT A SANDBOX (don't run untrusted wasm modules).
// 
// pass a wasm file as a cli arg to run a cart (otherwise defaults to a builtin one).
// controls: arrows,x,z,mouse. 
// press escape to exit to gallery of the examples in site/static/carts (click one to play it).
// 
// THIS IS UNFINISHED
// TODO: most of the modules i can't deal with yet (and will crash if you try to load them)
// - Start section
// - Select(K) when both inputs are constants can't just assume Kl. need to track the types harder. 
// - more missing float instructions
// - "int_reg RCon:239" !!! assertion
// TODO: im still doing something wrong: tetris freezes instead of clearing a row.
// TODO: persist the save disk somewhere when end_game()
// TODO: menu when press enter like runtimes/web does 
//       (then maybe get rid of R to reset even tho they do it, i don't really like it because it feels easy to press by mistake)
//       especially the save/load whole state would be nice so i didn't keep having to play tetris all the way. 
// TODO: running this in the web demo it works for the builtin_cart but breaks when you try to select a new one from the gallery
// TODO: make the shader less ugly (need arrays)
// TODO: add to tests/gpu.fr
//       that test runner also needs to stop leaking the pool resources.
// TODO: player2 controls
// TODO: compile examples/watris/src/main.c myself instead of using the committed blob
// (there are more todo comments in the actual code)
//

// true includes `builtin_cart_name` aot in the executable instead of including the wasm module as bytes so starts up faster. 
FEAT_AOT_CART :: true;
// false gets smaller binary but can only run `builtin_cart_name`
FEAT_GALLERY :: true;
// a file in wasm4/site/static/carts to be bundled into the exe. empty string for none (only load them at runtime)
builtin_cart_name :: "watris";
@run @assert(FEAT_GALLERY || builtin_cart_name.len() != 0, "wasm4 FEAT: this program will do nothing");

wasm4 :: fn() = group(
    url = "https://github.com/aduros/wasm4/archive/bed690f456bfa716ed21d410162c1c6e7c4e9c6c.tar.gz",
    legacy = "20894af584ebe86d72382c3712d9c0de281302fb677f4b69291d78511e91cb07",
    discard = @const_slice("cli", "devtools", "scripts", "test", "runtimes/web", "site/src", "site/blog"),
);
Wasm :: import("@/examples/import_wasm/runtime.fr");
Ffi :: import("@/examples/import_c/ffi.fr");
Viewer :: import("@/examples/gpu/viewer.fr");
#use("@/graphics/lib.fr");

Game :: @struct {
    rt: Wasm.Engine;
    memory: SaneRawList(u8);
    update: Wasm.Callable;
    disk: Wasm4.w4_Disk;  // TODO: persist this?
    active: bool;
    cart: Cart;
};

State :: @struct {
    WIDTH :: 500; HEIGHT :: 500;
    menu_pipe: Sgl.Pipeline;
    carts: []Cart;
    draw: Sgl.Self;
    mouse_pos: Vec2;  // event pixel coordinates
    dirty: bool;
    arena: Arena.Allocator;
    hovered: i64;  // annoying that i update this in rendering instead of event but it lets me not paste the coordinate math twice
    loaded_carts: bool;
    
    game_pipe: Sg.Pipeline;
    game: Game;
    exports: Wasm.ExportsEnv;
    frame: Sg.Buffer;
    uni: Shaders.Uni;
    key_pressed: u8;
    mouse_pressed: u8;
};

Cart :: @tagged(
    Raw: @struct(wasm: []u8, logo: Sg.Image, name: Str),
    Aot: @struct(mod: *Wasm.Module, name: Str),
);
fn on_init(state: *State, sapp: *Sapp.Self, sg: *Sg.Self) void = {
    // TODO: this is annoying because when using easy_init can't do desc at all
    //       but want to use easy_init so it works with tests/gpu.fr 
    //       but also this breaks that test anyway because the sg was already used so this is pointless. 
    R :: Sg.Image;
    @if(FEAT_GALLERY)
    init_pool(sg.pools&.index(R.Tag), sg.desc.allocator, 1024, size_of(R.T));  // SNEAK

    sapp.set_window_title(@tfmt("%%", builtin_cart_name, @if(FEAT_GALLERY, " (press escape to see gallery)", "")));
    state.arena = init(page_allocator, 1.shift_left(16));
    init_gfx(state, sg);
    a := state.arena&.borrow();
    state.exports = (_ = init(a));
    fill_exports(state.exports&, state.game&);
    state.set_scale(sapp);
    
    for cli_args() { it |
        it := it.str();
        @if(it.ends_with(".wasm"))
        if read_entire_file(a, it) { wasm |
            @if(FEAT_GALLERY) panic("wasm4 FEAT: runtime loading is disabled");
            state.start_game(Raw = (wasm = wasm, logo = (id = 0), name = it));
            return();
        };
    };
    
    @if(builtin_cart_name.len() != 0) {
        state.start_game(builtin_cart);
    };
}

fn load_carts(state: *State, sg: *Sg.Self) void = {
    start := timestamp();
    a := state.arena&.borrow();
    carts_dir := @tfmt("%/site/static/carts", wasm4());  // TODO: make this an arg
    #use("@/examples/testing.fr");
    @if_let(collect_with_extension(carts_dir, ".wasm")) fn Ok(files) => {
        carts := @ref Cart.list(files.len, a);
        for files { it |
            name := it.slice(0, it.len - ".wasm".len());
            if read_entire_file(a, @tfmt("%/%.wasm", carts_dir, name)) { wasm_bytes |
                cart: Cart = (Raw = (wasm = wasm_bytes, logo = (id = 0), name = name.shallow_copy(a)));
                @if(Viewer.FEAT_PNG)
                if read_entire_file(temp(), @tfmt("%/%.png", carts_dir, name)) { logo |
                    break :: local_return;
                    img, _0, _1 := Viewer'load_texture_from_data(sg, logo)
                        .or(fn(msg) => { eprintln(msg); break(); });
                
                    // TODO: handle POOL_EXHAUSTED
                    // TODO: this is dumb, use an atlas
                    // TODO: could be cool to automate just rendering the first frame of the game and using that instead of the committed thumbnails
                    cart.Raw.logo = img;
                };
                carts.push(cart);
            };
        };
        state.carts = carts.items();
        @eprintln("found % carts in %ms", carts.len, timestamp() - start);    // :SLOW
    };
}

fn end_game(game: *Game) void = if game.active {
    drop(game.rt&);
    game[] = zeroed(Game);
};

fn start_game(state: *State, cart: Cart) void = {
    state.dirty = true;
    game := state.game&;
    rt := game.rt&;
    game.end_game();
    game.active = true;
    game.cart = cart;
    a := general_allocator();
    rt[] = init_for_jit(a, "");
    @eprintln("loading (%): %", cart&.tag(), cart&.name());
    mod := @match(cart) {
        fn Raw(it) => {
            @if(@run (!FEAT_GALLERY && FEAT_AOT_CART)) panic("FEAT_GALLERY=false, cannot load raw cart");  // show the compiler it's unreachable
            @assert_le(it.wasm.len, 1.shift_left(16), "(arbitrary wasm4 cart size limit)");
            rt.compile(it.wasm)
        }
        fn Aot(it) => it.mod;
    };
    
    // TODO: move this logic to runtime.fr so everyone gets it 
    // TODO: tecnically should be <<33, memory access instructions have u32+u32 static+dynamic range. 
    //       could track max static offset and convert them to faults if it's past memory.max?
    // on native, over allocate so bounds checks are free 
    // (will only cost page table entries if we trust the os to overcommit). 
    // however if doing nested wasm, it doesn't expose virtual memory so reusing after munmap i have to zero the whole thing which is expensive. 
    web, page := (query_current_arch() == .wasm32, 1.shift_left(16));
    buf := page_allocator.alloc_uninit(u8, @if(web, page, 1.shift_left(32)));  
    if !web {
        Syscall'mprotect(u8.raw_from_ptr(buf.ptr.offset(page)), buf.len - page, 0);
    };
    
    rt.memories&.push(buf, rt.gpa);
    game.memory = (ptr = buf.ptr, cap = page, len = page);

    // w4_runtimeInit zeroes the memory so must be called before instantiate (which copies in active data sections)
    Wasm4'w4_runtimeInit(game.memory.ptr, game.disk&);
    
    instance := instantiate(rt, mod, state.exports&);
    
    game.update = get_fn("update");
    get_fn :: fn(name: Str) => {
        it := instance.exports&.get(name)
            || (Function = (callee = fn(_: rawptr) void = (), context = zeroed(rawptr)));
        @assert(it&.is(.Function), "expected exports[%] to be a function", name);
        it.Function
    };
    
    names := @const_slice("start", "_start", "_initialize");
    for names { name |
        start := get_fn(name);
        bit_cast_unchecked(rawptr, @FnPtr(_: rawptr) void, start.callee)(start.context);
    };
}

fn init_gfx(state: *State, sg: *Sg.Self) void = {
    @assert(!(query_current_arch() == .x86_64 && query_current_os() == .macos), "TODO: old metal doesn't like non-const u32 buffer");
    state.game_pipe = sg.make(
        shader = sg.make(choose_shader_impl(SOKOL_BACKEND, Shaders)),
    );
    state.frame = sg.make(
        usage = .DYNAMIC,
        size = cast(W * W).int() / 4,
    );
    
    state.draw&.setup(allocator = general_allocator(), sg = sg);
    init_pipeline(state.draw&, state.menu_pipe&, sg, ());
}

Shaders :: @struct {
    OutV :: @struct(pos: Vec4 #position);
    vs   :: fn(i: u32 #vertex_id) OutV = (pos = @vec(Easy'six_vertex_full_square(i), 0.0, 1.0));
    OutF :: @struct(colour: Vec4 #colour);
    fs   :: fn(
        in: OutV #input,
        uni: Uni #uniform(0), 
        frame: Buf(u32) #buffer(0),
    ) Shaders.OutF = {
        p := in.pos / uni.scale;
        x := @swizzle p.x;
        y := @swizzle p.y;
        @if(x >= W || y >= W) return(colour = vec4(0.0, 0.0, 0.0, 1.0));
        
        pixel_i := (floor(y) * W + floor(x));
        slot := frame[f32_to_u32(pixel_i) / 16];
        local_i := f32_to_i32(pixel_i).mod(16).zext();
        i := 8 * (local_i / 4);
        i += local_i.mod(4) * 2;
        c := slot.shift_right_logical(i).bit_and(0b11);
        c := @switch(c) {  // stupid :( need array
            @case(0) => uni.c0;
            @case(1) => uni.c1;
            @case(2) => uni.c2;
            @default => uni.c3;
        };
        c := c.unpack();
        (colour = @vec(@swizzle c.zyx, 1.0))
    };
    Uni :: @struct {
        // TODO: need arrays in shader translation
        c0: UByte4;
        c1: UByte4;
        c2: UByte4;
        c3: UByte4;
        scale: f32;
    };
};

fn on_render(state: *State, sapp: *Sapp.Self, sg: *Sg.Self) void = {
if state.game.active {
    memory := bit_cast_unchecked(*u8, *Wasm4.Memory, state.game.memory.ptr);
    if memory.systemFlags.bit_and(Wasm4.SYSTEM_PRESERVE_FRAMEBUFFER_[]) == 0 {
        Wasm4'w4_framebufferClear();
    }
    screen_size := min(sapp.width().float().cast(), sapp.height().float().cast());
    mouse := state.mouse_pos / vec2(screen_size) * W;
    x, y := (mouse.x.cast().int().toi16(), mouse.y.cast().int().toi16());
    toi16 :: fn(a: i64) i16 #ir(.extsh, .Kw);
    Wasm4'w4_runtimeSetGamepad(0, state.key_pressed);
    Wasm4'w4_runtimeSetMouse(x, y, state.mouse_pressed);
    f := state.game.update;
    bit_cast_unchecked(rawptr, @FnPtr(_: rawptr) void, f.callee)(f.context);
    // Wasm4'w4_apuTick();  // i don't do audio thus far. 
    
    state.uni.c0._ = memory.palette&[0];
    state.uni.c1._ = memory.palette&[1];
    state.uni.c2._ = memory.palette&[2];
    state.uni.c3._ = memory.palette&[3];
    
    ::Array(u8, 6400);
    sg.update_buffer(state.frame, memory.framebuffer&.items());
    
    bind := zeroed Sg.Bindings;
    bind.storage_buffers&[0] = state.frame;
    Easy'glue_begin_pass(sapp, sg, zeroed Sg.PassAction);
    sg.apply_pipeline(state.game_pipe);
    ::[]Shaders.Uni;
    sg.apply_uniforms(0, state.uni&.slice(1).interpret_as_bytes());
    sg.apply_bindings(bind&);
    draw(sg = sg, base = 0, elements = 6, instances = 1);
} else {
    @if(Easy'should_skip_frame(sapp, state.dirty&)) return();
    @if(!FEAT_GALLERY) unreachable();
    if !state.loaded_carts {
        state.load_carts(sg);
        state.loaded_carts = true;
    };
    
    sgl := state.draw&;
    sgl.defaults();
    sgl.viewport(0.intcast(), 0.intcast(), sapp.width().intcast(), sapp.height().intcast(), true);
    sgl.load_pipeline(state.menu_pipe);
    sgl.cur_matrix_mode = .TEXTURE;
    sgl.rotate(PI, 0.0, 1.0, 0.0);
    sgl.rotate(PI, 0.0, 0.0, 1.0);

    sgl.texturing_enabled = true;
    step := sqrt(state.carts.len.float()).int() + 1;
    
    screen := vec2(sapp.width().float().cast(), sapp.height().float().cast());
    scale: f32 = 1.5;
    mouse := (state.mouse_pos / screen * 2 - vec2(1)) * vec2(1, -1);
    state.hovered = -1;
    enumerate state.carts { i, cart |
        xx, yy := i.div_mod(step);
        // 1/step is sane and then fix to be -1..+1
        s := cast(1.0 / step.float()) * scale;
        x, y := (xx.float().cast(), yy.float().cast());
        h: f32 = 1;
        (x1: f32, x2: f32, y1: f32, y2: f32) := (x*s -h, (x+1)*s -h, y*s -h, (y+1)*s -h);
        sgl.color = 0xFFFFFFFF;
        if x1 < mouse.x && mouse.x < x2 && y1 < mouse.y && mouse.y < y2 {
            sgl.color = pack_rgba(1.0, 0.0, 0.0, 1.0);
            state.hovered = i;
        };
        
        sgl.texture(cart.logo(), (id = Sg.INVALID_ID));
        sgl.begin(.QUADS);
        sgl.v2f_t2f(x1, y1, 0, 0);
        sgl.v2f_t2f(x2, y1, 1, 0);
        sgl.v2f_t2f(x2, y2, 1, 1);
        sgl.v2f_t2f(x1, y2, 0, 1);
        sgl.end();
    };
    Easy'glue_begin_pass(sapp, sg, zeroed Sg.PassAction);
    sgl.draw_layer(sg, 0);
};
    sg.end_pass();
    sg.commit();
}

fn on_event(state: *State, sapp: *Sapp.Self, event: *Sapp.Event) void = {
    @match(event.type) {
        fn KEY_DOWN() => if state.game.active {
            @match(event.key_code) {
                fn ESCAPE() => if FEAT_GALLERY {
                    state.dirty = true;
                    state.game&.end_game();
                    sapp.set_window_title("franca/wasm4");
                }
                fn R() => {  // matches their runtimes/web
                    state.start_game(state.game.cart);
                }
                @default => ();
            }
        }
        fn MOUSE_DOWN() => if !state.game.active && state.hovered.ult(state.carts.len) {
            cart := state.carts[state.hovered];
            sapp.set_window_title(cart&.name());
            state.start_game(cart);
        }
        fn MOUSE_MOVE() => {
            state.dirty = true;
            state.mouse_pos = vec2(event.mouse_x, event.mouse_y);
        };
        fn RESIZED() => { 
            set_scale(state, sapp);
            state.dirty = true; 
        }
        @default => ();
    };
    
    set_key_masks(event, state.mouse_pressed&, state.key_pressed&);
}

// i just send events but it wants current state of key, 
// so need to remember the old flags and just toggle the bits. 
set_key_masks :: fn(event: *Sapp.Event, mouse_pressed: *u8, key_pressed: *u8) void #once = {
    #use(Wasm4);
    bit_xor :: fn(a: u8, b: u8) u8 #ir(.xor, .Kw);
    if @is(event.type, .MOUSE_DOWN, .MOUSE_UP) {
        o := mouse_pressed[];
        X :: fn(it: Sapp.Mousebutton, $flag: u8) => 
            { o = o.bit_xor(@if(event.mouse_button == it, flag, 0)); }
        X(.LEFT, W4_MOUSE_LEFT_[]);
        X(.RIGHT, W4_MOUSE_RIGHT_[]);
        X(.MIDDLE, W4_MOUSE_MIDDLE_[]);
        mouse_pressed[] = o;
    };
    if !event.key_repeat && @is(event.type, .KEY_DOWN, .KEY_UP) {
        o := key_pressed[];
        X :: fn(it: Sapp.Keycode, $flag: u8) => 
            { o = o.bit_xor(@if(event.key_code == it, flag, 0)); }
        X(.X, W4_BUTTON_X_[]);
        X(.Z, W4_BUTTON_Z_[]);
        X(.LEFT, W4_BUTTON_LEFT_[]);
        X(.RIGHT, W4_BUTTON_RIGHT_[]);
        X(.UP, W4_BUTTON_UP_[]);
        X(.DOWN, W4_BUTTON_DOWN_[]);
        key_pressed[] = o;
    }
}

fn set_scale(state: *State, sapp: *Sapp.Self) void = {
    state.uni.scale = min(sapp.width().float().cast(), sapp.height().float().cast()) / W;
}

fill_exports :: fn(it: *Wasm.ExportsEnv, game: *Game) void = {
    S :: Type.scope_of(Exports);
    inline_for get_constants(S) { $name |
        fid :: FuncId.get_constant(S, name[]).unwrap();
        it.insert("env", @run name[].str(), fid, game);
    };
    it.insert("env", "memory", (Memory = game.memory&));
}

// TODO: this is tedious but doing it with reflection is also tedious :(
Exports :: @struct {
    blit :: fn(g: *Game, a: u32, b: i32, c: i32, d: i32, e: i32, f: i32) void = 
        Wasm4'w4_runtimeBlit(g.memory.index(a.zext()), b, c, d, e, f);
    blitSub :: fn(g: *Game, a: u32, b: i32, c: i32, d: i32, e: i32, f: i32, gg: i32, h: i32, i: i32) void = 
        Wasm4'w4_runtimeBlitSub(g.memory.index(a.zext()), b, c, d, e, f, gg, h, i);
    line :: WrapI4 Wasm4.w4_runtimeLine;
    hline :: WrapI3 Wasm4.w4_runtimeHLine;
    vline :: WrapI3 Wasm4.w4_runtimeVLine;
    oval :: WrapI4 Wasm4.w4_runtimeOval;
    rect :: WrapI4 Wasm4.w4_runtimeRect;
    text :: fn(g: *Game, a: u32, b: i32, c: i32) void = 
        Wasm4'w4_runtimeText(g.memory.index(a.zext()), b, c);
    textUtf8 :: fn(g: *Game, a: u32, b: i32, c: i32, d: i32) void = 
        Wasm4'w4_runtimeTextUtf8(g.memory.index(a.zext()), b, c, d);
    textUtf16 :: fn(g: *Game, a: u32, b: i32, c: i32, d: i32) void = 
        Wasm4'w4_runtimeTextUtf16(bit_cast_unchecked(*u8, *u16, g.memory.index(a.zext())), b, c, d);
    tone :: WrapI4 Wasm4.w4_runtimeTone;
    diskr :: WrapPI Wasm4.w4_runtimeDiskr;
    diskw :: WrapPI Wasm4.w4_runtimeDiskw;
    trace :: fn(g: *Game, a: u32) void = 
        Wasm4'w4_runtimeTrace(g.memory.index(a.zext()));
    traceUtf8 :: WrapPI Wasm4.w4_runtimeTraceUtf8;
    traceUtf16 :: WrapP16I Wasm4.w4_runtimeTraceUtf16;
    tracef :: fn(g: *Game, a: u32, b: u32) void = 
        Wasm4'w4_runtimeTracef(g.memory.index(a.zext()), bit_cast_unchecked(*u8, rawptr, g.memory.index(b.zext())));
};
WrapPI :: fn($fid: FuncId) FuncId = (fn(g: *Game, a: u32, b: i32) = 
    fid(g.memory.index(a.zext()), b));
WrapP16I :: fn($fid: FuncId) FuncId = (fn(g: *Game, a: u32, b: i32) = 
    fid(bit_cast_unchecked(*u8, *u16, g.memory.index(a.zext())), b));
WrapI3 :: fn($fid: FuncId) FuncId = (fn(g: *Game, a: i32, b: i32, c: i32) = fid(a, b, c));
WrapI4 :: fn($fid: FuncId) FuncId = (fn(g: *Game, a: i32, b: i32, c: i32, d: i32) = fid(a, b, c, d));
    
builtin_cart_bytes :: import("@/lib/sys/fs.fr")'read_entire_file_or_crash(ast_alloc(), @tfmt("%/site/static/carts/%.wasm", wasm4(), builtin_cart_name));

builtin_cart :: @as(Cart) @if(FEAT_AOT_CART, {
    mod := import("@/examples/import_wasm/ffi.fr")'include(builtin_cart_bytes, current_compiler_context());
    (Aot = (name = builtin_cart_name, mod = mod))
}, (Raw = (wasm = builtin_cart_bytes, name = builtin_cart_name, logo = (id = 0))));

W :: Wasm4.WIDTH_[];
Wasm4 :: {
    src := @ref u8.list(temp());
    root := wasm4();
    println(root);
    files := @slice("apu.c", "framebuffer.c", "runtime.c", "util.c");
    for files { it |
        @fmt(src, """
            #add_include_path "%/runtimes/native/src"
            #include "%"
            #discard_static_scope 0
        """, root, it);
    };
    @fmt(src, """
        const uint8_t SYSTEM_PRESERVE_FRAMEBUFFER_ = SYSTEM_PRESERVE_FRAMEBUFFER;
        const uint8_t W4_BUTTON_X_ = W4_BUTTON_X;
        const uint8_t W4_BUTTON_Z_ = W4_BUTTON_Z;
        const uint8_t W4_BUTTON_LEFT_ = W4_BUTTON_LEFT;
        const uint8_t W4_BUTTON_RIGHT_ = W4_BUTTON_RIGHT;
        const uint8_t W4_BUTTON_UP_ = W4_BUTTON_UP;
        const uint8_t W4_BUTTON_DOWN_ = W4_BUTTON_DOWN;
        const uint8_t W4_MOUSE_LEFT_ = W4_MOUSE_LEFT;
        const uint8_t W4_MOUSE_RIGHT_ = W4_MOUSE_RIGHT;
        const uint8_t W4_MOUSE_MIDDLE_ = W4_MOUSE_MIDDLE;
        const float WIDTH_ = WIDTH;
        _Static_assert(WIDTH == HEIGHT);
    """);
    Ffi'include(src.items())
};
#use("@/examples/fetch.fr");

fn name(it: *Cart) Str = @match(it) { fn Raw(it) => it.name; fn Aot(it) => it.name; };
fn logo(it: *Cart) Sg.Image = @match(it) { fn Raw(it) => it.logo; fn Aot(it) => (id = 0); };

main :: fn() void = Easy'start(State);
driver :: fn(vtable: *ImportVTable) void = Easy'build_for_graphics(vtable, @source_file_name());
