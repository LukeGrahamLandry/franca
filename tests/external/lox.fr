//! This parses the format used by https://github.com/munificent/craftinginterpreters/tree/master/test
//! and runs those tests on my @/examples/lox interpreter. 
//! Currently checks exact output for programs that are not supposed to error but otherwise just expects 
//! runtime vs compile error to be correct (my error messages don't match). 
// note: since i don't check exact error messages it will look like i pass tests that are supposed to error just because they use features i don't support yet
// as a fun bonus, the lox repo has a lox interpreter written in c 
// that i can compile with my c compiler (examples/import_c) and run on the same tests. 

#use("@/examples/testing.fr");
driver :: fn(vtable: *ImportVTable) void = main2(Some = vtable);
main :: fn() void = main2(.None);
main2 :: fn(vtable: ?*ImportVTable) void = {
    args := cli_args();
    
    root := Foreign'craftinginterpreters();
    
    go := false;
    hush, do_skips, aot := (false, false, false);
    clox: ?Str = .None;
    test_paths := @ref Test.list(temp());
    collect_tests :: fn(s) => 
        test_paths.run_test_at_path(@if(do_skips, skip_, empty()), "", s);
    for args { s |
        continue :: local_return;
        s := s.str();
        if !go {
            if s == "--" {
                go = true;
            };
            if s == "-pass" {
                do_skips = true;
                collect_tests(@tfmt("%/test", root));
            };
            if s == "-hush" {
                hush = true;
            }
            if s == "-clox" {
                path := compile_c_lox(root);
                clox = (Some = path);
            };
            if s == "-all" {
                collect_tests(@tfmt("%/test", root));
            };
            if s == "-aot" {
                aot = true;
            }
            continue();
        };
        @assert(!do_skips, "only skip failing tests when running all");
        collect_tests(@tfmt("%/test/%", root, s));
    };
    
    c := zeroed(CompCtx);
    if aot {
        vtable := vtable.expect("run as driver to test lox/aot.fr (-aot)");
        opts := vtable.default_build_options();
        cc := vtable'init_compiler(opts);
        c = vtable.with(cc);
        make_and_resolve_and_compile_top_level(cc, vtable, "#include_std(\"lib/core.fr\");\n", "prelude");
    };
    
    @assert(!(clox.is_some() && aot), "choose -clox XOR -aot");
    total, pass := (0, 0);
    enumerate test_paths { i, it |
        continue :: local_return;
        if !it.is_file {
            @if(!hush) @println("=== % ===", it.s);
            continue();
        };
        
        ::FmtPad(Str);
        mark := temp().mark();
        @if(!hush) @print("%", f_pad(it.s.rest(it.prefix_len), 40, .After));
        lox_filename := it.s;
        src := temp().read_to_string_or_crash(lox_filename);
        want := expected_output(src.items());
        r := @if_else {
            @if(aot) => run_aot(c, src.items(), i);
            @if(clox.is_some()) => run_clox(clox.Some, lox_filename); 
            @else => run_interp(src.items());
        };
        ok := check_test(want, r);
        @if(!hush) @println("[%]", @if(ok, "ok", "fail"));
        total += 1;
        pass += int(ok);
        temp().reset(mark);
    };
    
    @println("\npassed %/% tests.", pass, total);
    @if(aot) c'vtable'destroy_compiler(c.data);
    if pass != total {
        panic("tests failed");
    }
    @assert(total != 0, "didn't run any tests");
    Syscall'exit(@if(pass == total, 0, 1));
}

skip_ :: @const_slice(
    "string/multiline.lox",   // TODO: my test runner is dumb about multiline prints
    "number/literals.lox",  // i don't print -0
    "variable/duplicate_local.lox", 
    "variable/use_local_in_initializer.lox", 
    "function/print.lox",
    "return/at_top_level.lox",  // currently i allow this since it makes the test in lox_main easier
    "variable/duplicate_parameter.lox",
    "variable/collide_with_parameter.lox",
    "benchmark", "limit/stack_overflow.lox", 
    
    "limit/no_reuse_constants.lox", // expects error but i reuse constant pool slots
    "limit/too_many_constants.lox", // loxlox needs more than 255 constants
    
    // these are for chapters before the vm
    "expressions", "scanning",
);

Test :: @struct(s: Str, prefix_len: i64, is_file: bool);
fn run_test_at_path(out: *List(Test), skip_: []Str, prefix: Str, s: Str) void = {
    if skip_.contains(fn(check) => s.ends_with(@tfmt("/%", check[]))) {
        return();
    };
    if s.ends_with(".lox") {
        out.push(s = s, prefix_len = prefix.len, is_file = true);
    } else {
        children := collect_directory_ordered(s, temp(), temp()) 
            || @panic("failed to collect test files from %", s);
        out.push(s = s.rest(prefix.len), prefix_len = 0, is_file = false);
        for children { e |
            if e.name.ends_with(".lox") || e.is(.Directory) {
                path := @tfmt("%/%", s, e.name);
                out.run_test_at_path(skip_, s, path);
            }
        };
    }
}

TestOutput :: @struct(found: []Str, result: Lox.InterpretResult, errors: Str);
fn run_interp(src: Str) TestOutput = 
    with_vm(fn(vm) => vm.interpret(src, true));

fn with_vm($run: @Fn(vm: *Lox.Vm) Lox.InterpretResult) TestOutput = {
    #use(Lox);
    found: List(Str) = list(temp());
    errors := u8.list(temp());
    vm := zeroed Vm;
    init(vm&);
    vm.user_data = List(Str).raw_from_ptr(found&);
    vm.print_callback = fn(_, user_data, value) = {
        found := List(Str).ptr_from_raw(user_data);
        found.push(@tfmt("%", value));
    }
    result := run(vm&);
    errors := vm.errors.items().shallow_copy(temp());
    vm&.drop();  // test a forced full collection
    (found = found.items(), result = result, errors = errors)
}

fn run_clox(clox_path: Str, lox_filename: Str) TestOutput = {
    cargs := make_args_for_exec(clox_path, @slice(lox_filename), temp());
    out, errors := (u8.list(temp()), u8.list(temp()));
    it := sys_capture_exec(cargs).unwrap();
    status := it&.poll_until_exit(out&, errors&, "");
    // TODO: do the WEXITSTATUS shift in poll_until_exit
    result: Lox.InterpretResult = @switch(status.shift_right_logical(8)) {
        @case(0) => .Ok;
        @case(70) => .RuntimeError;
        @case(65) => .CompileError;
        @default => @panic("bad status %\n%", status.shift_right_logical(8), errors.items());
    };
    lines := out.items().split("\n", temp()).items();
    lines.len -= 1;
    (found = lines, result = result, errors = errors.items())
}

// run all the tests in the same compiler instance so some work can be reused (ie. compiling comptime/vm helper functions, etc.) 
// TODO: this is crazy verbose/fragile :(
// worth it for ~30x speedup over writing to a file and exec-ing franca on it. 
fn run_aot(c: CompCtx, lox_src: Str, i: i64) TestOutput = {
    franca_src := @match(import("@/examples/lox/aot.fr")'translate_src(lox_src)) {
        fn Ok(it) => it;
        fn Err(it) => return(found = empty(), result = .CompileError, errors = it);
    };

    src := @tfmt("(fn() = { % \n(script_index, const_count, ::@as(rawptr)init_lox_constants)\n });", franca_src);
    src := src.shallow_copy(c.get_alloc());  // :SLOW just fmt into it in the first place
    name := (@tfmt("lox%.g.fr", i)).shallow_copy(c.get_alloc());
    file := {c.vtable.add_file}(c.data, name, src).shrink();

    stmts := {c.vtable.parse_stmts}(c.data, file&);
    stmts := stmts.or(fn(err) => c.report_error(err));
    @assert(stmts.len == 2 && stmts[0].stmt&.is(.Eval) && stmts[1].stmt&.is(.Noop), "ast shape changed");
    expr: *FatExpr = stmts[0].stmt.Eval&;
    
    c'vtable'compile_ast(c.data, expr, FuncId);
    @assert(expr.expr&.is(.Value) && expr.ty == FuncId, "didn't compile all the way?");
    
    fid := FuncId.assume_cast(expr.expr.Value.bytes&)[];
    #use("@/compiler/ast_external.fr");
    func := c.get_function(fid);
    func.resolve_scope = TOP_LEVEL_SCOPE;  // needed because it didn't go through the normal parser->resolve pass that would save its parent scope
    
    p := c.get_jitted(fid);
    p := bit_cast_unchecked(rawptr, @FnPtr() Ty(i64, i64, F), p);
    script_index, const_count, init_lox_constants := p();
    
    F :: @FnPtr(vm: *Lox.Vm, o: []*Lox.Obj) void;
    
    // mirrors examples/lox/aot.fr/prelude
    with_vm { vm |
        o := vm.gc.alloc_zeroed(*Lox.Obj, const_count);
        vm.aot_roots = o;
        init_lox_constants(vm, o);
        script := o[script_index].to(.Function);
        result := vm.interpret(script, true);
        vm.aot_roots = empty();
        vm.gc.dealloc(*Lox.Obj, o);
        result
    }
}

fn check_test(want: TestResult, r: TestOutput) bool = {
    result, found, errors := (r.result, r.found, r.errors);
    pass := @match(want) {
        fn Ok(want) => {
            print(errors);
            if(result != .Ok || errors.len != 0, => return(false));
            if want.len != found.len {
                @println("Expected % outputs but found %", want.len, found.len);
                return(false);
            };
            
            range(0, want.len) { i |
                if want[i] != found[i] {
                    @println("[%] Expected '%' but found '%'", i, want[i], found[i]);
                    return(false);
                };
            };
            
            true
        }
        fn RuntimeError() => result == .RuntimeError;
        fn CompileError() => result == .CompileError;
    };
    if pass {
        s := want&.tag();
        s := s.name_str();
        @print("%", s.slice(0, 1));
    }

    if !want&.is(.Ok) && !pass {
        print(errors);
        print("(expected an error)");
    };
    
    pass
}

// TODO: do any of the tests require some prints and then an error later? rn i only return one or the other. 
TestResult :: @tagged(Ok: List(Str), CompileError, RuntimeError);
fn expected_output(src: Str) TestResult = {
    want: List(Str) = list(temp());
    cursor := 0;
    tag := "// expect: ";
    runtime_tag := "expect runtime error: ";
    comptime_tag := "[line ";
    other_comptime_tag := "// Error at ";
    while => cursor < src.len - tag.len {
        if cursor < src.len - runtime_tag.len {
            if src.subslice(cursor, runtime_tag.len) == runtime_tag {
                return(.RuntimeError)
            };
        };
        if src.subslice(cursor, comptime_tag.len) == comptime_tag {
            return(.CompileError)
        };
        if src.subslice(cursor, other_comptime_tag.len) == other_comptime_tag {
            return(.CompileError)
        };
        if src.subslice(cursor, tag.len) == tag {
            cursor += tag.len;
            start := cursor;
            while => cursor < src.len && src[cursor] != "\n".ascii() {
                cursor += 1;
            };
            want&.push(src.slice(start, cursor));
            cursor -= 1;
        };
        cursor += 1;
    };
    (Ok = want)
}

// TODO: far too verbose. can't just cc.fr all the files because need to discardstaticscope
compile_c_lox :: fn(root: Str) Str = {
    files := collect_with_extension(@tfmt("%/c", root), ".c").unwrap();
    
    // TODO: use it through import_module
    Qbe :: import("@/backend/ir.fr");
    C :: import("@/examples/import_c/lib.fr");
    
    c := @ref zeroed(C.Compile.Ctx);
    m := @ref zeroed(Qbe.Module);
    Qbe'backend'init_module(m, (
        arch = query_current_arch(),
        os = query_current_os(),
        type = .Exe,
        wrap_entry_for_linux_libc = true,
        exe_debug_symbol_table = true,
    ));
    ctx := init_codegen_worker(m, true);
    C'init_ctx(c, m, ctx);
    c.include_paths&.push(@tfmt("%/c", root));
    
    for files { it |
        // :discard_static_scope
        c.macros&.clear();
        c.scope.vars&.clear();
        C'Preprocess'init_macros(c);
    
        it := @tfmt("%/c/%", root, it);
        src := read_entire_file_or_crash(temp(), it);
        result := C'catch_call(c, void) {
            tok := c.tokenize_string(it, src);
            tok  = c.C'Preprocess'preprocess(tok);
            c.C'Compile'parse(tok);
        };
        @if_let(result) fn Err(msg) => {
            @panic("failed to compile %\n%", "", msg);
        };
    };
    
    path := "target/clox.out";
    ctx.join_codegen_thread();
    chunks := {m.target.finish_module}(m);
    write_chunks_or_crash(path, chunks);
    c.arena_storage&.deinit();
    drop(m);
    path
}

#use("@/lib/collections/map.fr");
#use("@/lib/sys/fs.fr");

Lox :: import("@/examples/lox/lox_main.fr").Lox;
