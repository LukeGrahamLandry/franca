with_cc_deps :: @S(
    @S("tests/backend.fr", "all", "-bin", "./target/q.out", "-cc", "-force_linker"), // dep:clang
    @S("tests/backend.fr", "all", "-bin", "./target/q.out"),  // dep:clang
    @S("tests/external/tcc.fr", "-ddc"),  // ddc is dep:clang and tcc bootstrap is dep:headers anyway.
);

driver :: fn(vtable: *ImportVTable) void = {
    c := cli_args();
    for c {s: CStr|
        do_it(vtable, s.str());
    };
};

do_it :: fn(vtable: *ImportVTable, s: Str) void = {
    #use("@/lib/sys/process.fr");
    #use("@/lib/sys/fs.fr");
    driver_path := "examples/default_driver.fr";
    franca_path := get_executable_path(temp());
    ::display_slice(Str);
    run :: fn(args) => {
        @println("%", args);
        run_cmd_blocking(franca_path, args) || @panic("failed %", args);
    };
    
        @switch(s) {
            @case("--") => ();
            @case("fetch") => reach_all_deps();
            @case("strap") => {
                do_it(vtable, "boot");
                sh(@slice("./target/f.out", driver_path, "build", "compiler/main.fr", "-o", "target/franca.out", 
                    "-unsafe", "-keep-names", "-debug-info"));
            };
            @case("-hush") => {
                HUSH[] = true;
            };
            @case("boot") => {
                make_dirs_or_crash("target");
                // f0 - new source built by old compiler
                // f  - new source built by new compiler
                sh(@slice(franca_path, driver_path, "build", "compiler/main.fr", "-o", "./target/f0.out", "-keep-names", "-unsafe"));
                sh(@slice("./target/f0.out", driver_path, "build", "compiler/main.fr", "-o", "./target/f1.out", "-keep-names"));
                sh(@slice("./target/f1.out", driver_path, "build", "compiler/main.fr", "-o", "./target/f.out", "-keep-names"));
                diff("./target/f1.out", "./target/f.out");
            };
            @case("core") => {
                do_it(vtable, "boot");
                println("=== re-exec ===");
                sh(@slice("./target/f.out", "tests/run_tests.fr", "run"));
            };
            @case("release") => {
                build_release(vtable);
                run(@slice(driver_path, "build", "compiler/main.fr", "-o", "target/franca.out", 
                    "-unsafe", "-keep-names", "-debug-info"));
            };
            @case("run") => {
                start_repro_file();
                if get_environment_variable(Foreign.ENV.FRANCA_ELF_INTERP_PATH) { it |
                    s := @tfmt("FRANCA_ELF_INTERP_PATH-%\n", it);
                    @assert append_to_file(choose_repro_path(), s);
                };
                
                do_it(vtable, "run-no-deps");
                // the rules are everything before this must not download dependencies or exec system binaries. 
                println("=== end of dependency free tests ===");
                do_it(vtable, "run-yes-deps");
                // on macos everything before this works without installing the xcode commandline tools
                println("=== end of sys-c-toolchain free tests ===");
                
                skip_cc := query_current_os() == .macos && !check_for_xcode();
                if !skip_cc {
                    do_it(vtable, "run-cc-deps");
                } else {
                    eprintln("SKIP: run-cc-deps (on macos and doesn't look like xcode cli is installed)");
                    @assert(!IS_GITHUB, "seems unlikely they're break everyone else");
                };
                finish_repro_file();
                println(choose_repro_path());
                maybe_deploy_srht_site();
            };
            @case("run-no-deps") => {
                for bins { code, dest |
                    sh(@slice(franca_path, driver_path, "build", code, "-o", dest, "-keep-names"));
                };
                
                for test_cmds { cmd | 
                    run(cmd);
                };
                
                if !tls(.deny_syscalls)[] {  // SKIP: examples/os
                    // examples/os can't use elf_loader standalone because it's strict about how callstacks are allocated
                    run(@S("tests/exe/sys.fr"));
                    run(@S("tests/exe/cli_args.fr", "a", "b", "c", "d"));  // /proc/self/cmdline
                    run(@S("tests/exe/dylibs.fr"));                        // real dlopen
                    test_static_repro(franca_path);                        // syscalls
                };
                
                build_aoc(franca_path);
                
                for dylib_compile_only { file |
                    sh(@slice(franca_path, "examples/default_driver.fr", "build", file, "-dynamiclib", "-o", "target/out/compileonly.dylib"));
                };
                
                run(@slice("examples/os/build.fr"));
                @if(false)  // :TodoSketchyRepro
                cross_repro("target/kernel.out", "examples/os/build.fr", "kernel-aarch64");
                
                // TODO: this is a source of confusion if you had run run_tests.fr with the release compiler
                do_it(vtable, "release");
            };
            @case("emit-c") => {
                run(@slice("examples/default_driver.fr", "build", "compiler/main.fr", "-unsafe", "-o", "target/iI.out")); // extra step only matters if running this case directly not as part of all the tests that already bootstrapped
                sh(@slice("target/iI.out", "examples/default_driver.fr", "build", "compiler/main.fr", "-unsafe", "-o", "target/iII.out", "-keep-names"));
            
                run(@slice("examples/emit_c.fr", "-i", "compiler/main.fr", "-o", "target/a.c", "-unsafe"));
                run(@slice("examples/import_c/cc.fr", "target/a.c", "-o", "target/a.out"));
                check(false);
                Syscall'remove("target/a.out").unwrap();
                @if(false)  // :TodoSketchyRepro
                cross_repro("target/a.c", "compiler/main.fr", "emit_c");
                
                @if(query_current_arch() == .rv64) return(println("SKIP: emit_c clang on rv"));  // TODO
                
                clang_triple := import("@/examples/default_driver.fr")'target_triple(query_current_arch(), query_current_os());
                hack := @if(query_current_os() == .macos, Foreign.EXE.cc, Foreign.EXE.clang);
                sh(@slice(hack, "target/a.c", "-O0", "-o", "target/a.out", "-Wl,-undefined,dynamic_lookup", "-lm", "-target", clang_triple));
                check(true);
                check :: fn(HACK_clang: bool) => {
                    // TODO: should FRANCA_NO_CACHE=1 
                    ok, o, e := exec_and_catch("target/a.out", @slice("examples/toy/hello2.fr"), temp());
                    @assert_eq(o.items(), "Hello World!\n", "%", e.items());
                    @assert(ok);
                    print(o.items());
                    
                    if !HACK_clang || query_current_os() == .macos || query_current_arch() == .aarch64 {  // TODO: why? i assume its not really a platform thing, just the versions of clang i happen to have?
                    // now can that compiler self-compile and get the same bytes as if it didn't go through c
                    sh(@slice("target/a.out", "examples/default_driver.fr", "build", "compiler/main.fr", "-unsafe", "-o", "target/iCI.out", "-keep-names"));
                    diff("target/iII.out", "target/iCI.out");
                    println("i()->I()->I() == i()->C()->I()");
                    };
                };
            };
            @case("build_graphics") => build_graphics(franca_path);
            @case("run-yes-deps") => {
                prospero(franca_path);
                for(with_fetch_deps, fn(it) => run(it));
                
                // (with_fetch_deps -> tests/exe/wasm -> examples/web/build) creates these files
                @if(false)  // :TodoSketchyRepro
                cross_repro("target/web/target/demo.wasm", "examples/web/build.fr", "wasm32");
                rootfs_hash := temp().read_entire_file_or_crash("target/web/target/rootfs_hash.txt");
                cross_repro_hash(rootfs_hash, "examples/web/build.fr", "rootfs");
                
                build_graphics(franca_path);
                for deps_compile_only { file |
                    run(@slice("examples/default_driver.fr", "build", file, "-o", "target/a.out"));
                };
                
                ci := IS_GITHUB;
                if current_os() == .macos {
                    run(@slice("examples/gpu/trivial_compute.fr", "-jit"));  // only supports metal so far
                    run(@slice("tests/gpu.fr", "-jit"));  // "
                    print("SKIP: 'Hare does not and will not officially support proprietary operating systems upstream.'\n");
                } else {
                    print("SKIP: @/graphics is metal only rn\n");
                    run(@slice("tests/external/hare.fr"));
                    write_entire_file_or_crash("target/a.ppm", "");  // test.yml wants to upload output from tests/gpu.fr
                
                    run(@slice("tests/external/janet.fr", "-test"));
                };
                @if(false)
                if current_os() == .macos && current_arch() == .aarch64 && !ci {
                    // TODO: -smp 1 frequently hangs
                    // TODO: need to error if it errors (host/vzf.fr doesn't know if you crashed) 
                    run(@slice("examples/os/build.fr", "-vzf", "-smp", "2", "-append", "nocache on; kaleidoscope; quit;"));
                };
                if ci {
                    run(@slice("tests/external/other.fr"));
                };
            };
            // TODO: hare and luajit should be here on amd64 (because i didn't do assembler there yet)
            @case("run-cc-deps") => {
                more_cache := Foreign.ENV.FRANCA_MORE_CACHE.get_environment_variable().is_some() ;
                ci := IS_GITHUB;
                for(with_cc_deps, fn(it) => run(it));
                
                // dep:clang
                // TODO: doesn't implement all the ops yet
                @if(!more_cache)
                do_it(vtable, "emit-c");
                
                // dep:headers
                if current_os() == .linux {
                    break :: local_return;
                    if !dir_exists("/usr/include") {
                        eprintln("SKIP: bubblewrap/curl. TODO: use $NIX_CFLAGS_COMPILE somehow instead of #add_include_path /usr/include/...");
                        break();
                    };
                
                    @if(query_current_arch() != .rv64)  // TODO: doesn't work with my multiarch situation so idk if it actually works. this is why we can't be depending on the system headers. 
                    if ci {
                        // github actions can't actually run it (sr.ht works tho)
                        // "bwrap: loopback: Failed RTM_NEWADDR: Operation not permitted"
                        run(@slice("tests/external/bubblewrap.fr"));
                    } else {
                        run(@slice("tests/external/bubblewrap.fr", "-fr", "examples/toy/hello2.fr"));
                    };
                    if query_current_arch() != .rv64 {
                        run(@slice("tests/external/curl.fr"));
                    };
                    print("SKIP: (TODO) raylib.\n");
                } else {
                    @if(!ci || query_current_arch() == .aarch64)  // TODO: should make it work but debugging when it only dies in github actions is ass
                    if dir_exists("/Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX.sdk") {
                        run(@slice("tests/external/raylib.fr", "-compileonly"));
                    } else {
                        print("SKIP: compile raylib (didn't find xcode sdk)\n");
                    };
                    
                    print("SKIP: bubblewrap does linux specific sandboxing stuff.\n");
                    print("SKIP: (TODO) curl.\n");
                };
                
                // dep:node
                if ci {
                    rootfs_hash := temp().read_entire_file_or_crash("target/web/target/rootfs_hash.txt");
                    sh(@slice("node", "target/web/test.js", rootfs_hash));
                } else {
                    eprintln("SKIP: node/wasm tests are :SLOW, only run in actions");
                };
            };
            @case("ci-end") => ci_end();
            @default => @eprintln("IGNORE: %", s);
        };
};

build_web_and_get_hash :: fn(franca_path: Str) Str = {
    ok, out, err := exec_and_catch(franca_path, @slice("examples/web/build.fr"), temp());
    err := err.items();
    @assert(ok, "%%", out.items(), err);
    prefix := "rootfs_hash=";
    while => !err.starts_with(prefix) {
        err = err.rest(1);
    };
    err = err.rest(prefix.len);
    rootfs_hash := err.slice(0, 64);
    rootfs_hash
};

#use("@/backend/lib.fr")
build_release :: fn(vtable: *ImportVTable) void = {
    make_dirs_or_crash("target/release");
    
    unsafe := true;
    keep_names := false;
    
    opts := vtable.default_build_options();
    if unsafe {
        it := opts.safety_checks&;
        it.insert(.Bounds, false);
        it.insert(.DebugAssertions, false);
        it.insert(.InvalidTag, false);
    };
    opts.retain_function_names = keep_names;
    opts.debug_info = false;  // TODO: this being true breaks repro because it embeds source with #comptime_addr
    c := new_with_src(vtable, """#include_std("lib/core.fr");#include_std("compiler/main.fr");""", opts);
    c := vtable.with(c);
    m := @ref zeroed(Qbe.Module);
    // TODO: "need to be consistant about how to handle modules like this that don't actually compile anything"
    init_default_module_dyn(m, c.vtable, (
        arch = .aarch64, os = .macos, type = .CachedEarly, 
        exe_debug_symbol_table = opts.retain_function_names, 
    ));
    fid := c.get_unique_named("main").expect("'main' when building the compiler");
    chunks := {c.vtable.emit_qbe_included}(QbeModule.raw_from_ptr(m), c&, @slice(fid), .WrapMain);
    bytes := concat(chunks&, temp());
    cross_repro_bytes(bytes, "compiler/main.fr", "release-CachedEarly");
    c'vtable'drop_qbe_module(QbeModule.raw_from_ptr(m));
    
    ;{
        // don't have to do this. just a little test that dump doesn't crash on nontrivial program.
        out := u8.list(bytes.len, temp());
        import("@/backend/meta/dump_bin.fr")'dump(out&, bytes);
    };

    targets := @S((Os.macos, Arch.aarch64), (.macos, .x86_64), (.linux, .aarch64), (.linux, .x86_64), (.linux, .rv64));
    
    // TODO: this is still takes like 200ms each. 
    //       it would be nice if i could just compile functions once per architecture if they don't depend on varargs abi. 
    for targets { os, arch |
        m := c'vtable'get_alloc(c.data).box_uninit(QbeModule);  // for good luck
        init_default_module_dyn(m, c.vtable, (
            arch = arch, os = os, type = .Exe, 
            exe_debug_symbol_table = opts.retain_function_names, 
        ));
        
        ::Result(*Incremental.Header, Str);
        header: *Incremental.Header = or check(bytes) { e |
            @panic("generated an invalid frc file: %", e)
        };
        compile_all_symbols(header, m);
        
        // TODO: this is confusing. 
        //       the module has its own debug info so need to not touch that 
        //       but do need to fill the import of base_address so franca_runtime_init can do relocations. 
        seal_debug_info(m, "", false, "");  // :AnnoyingDoubleSeal
        
        chunks := {vtable.finish_qbe_module}(QbeModule.raw_from_ptr(m));
        
        bytes := concat(chunks&, temp());
        cross_repro_bytes(bytes, "compiler/main.fr", @tfmt("release-%-%", os, arch));
        arch := @match(arch) {
            fn x86_64() => "amd64";
            fn aarch64() => "arm64";
            @default => @tfmt("%", arch);
        };
        @println("%-%", arch, os);
        path := @tfmt("target/release/franca-%-%", os, arch);
        write_entire_file_or_crash(path, bytes);
        if os == .linux {
            import("@/backend/elf/emit.fr")'patch_out_interp_header(bytes);
            write_entire_file_or_crash(@tfmt("%-sta", path), bytes);
        };
        
        c'vtable'drop_qbe_module(QbeModule.raw_from_ptr(m));
    };
    c'vtable'destroy_compiler(c.data);
};

// these are annoying to actually test for various reasons but at least make sure they compile. 
dylib_compile_only :: @const_slice(
    "examples/default_driver.fr",  // so meta, many wow
    "examples/60fps.fr",  // interactive
    "examples/soft_draw.fr", // interactive & no aot so just make sure the driver still compiles
    "examples/parsegen/main.fr",  // TODO: bootstrapping decision
    "examples/chess/web.fr",
);

deps_compile_only :: @S(
    "examples/view_image.fr",  // dep:wuffs
    "examples/ascii_table.fr",  // dep:stb
);

// seperate because they need the build_for_graphics driver. 
// (also they have deps: stb, fonts, dawn.json)
// interactive so we just compile them. 
// TODO: run one frame and show screen shot as a sanity check? 
graphics_demos :: @S(
    "examples/gpu/geo/main.fr",
    "examples/chess/gui.fr",
);

build_graphics :: fn(franca: Str) void = {
    sh(@slice(franca, "graphics/web/webgpu_api.fr"));
    
    files := collect_with_extension("examples/gpu", ".fr").unwrap();
    each files { it |
        it[] = @tfmt("examples/gpu/%", it[]);
    };
    files&.push_all(graphics_demos);
    
    run_tests_main_threaded(Str, Str, franca, files.items(), fn(_, a) = a[], fn(franca, it) = {
        path := @tfmt("target/gfx.out%", tls(.thread_index)[]);
        ok, out, err := exec_and_catch(franca, @slice(it[], "-arch", "aarch64", "-os", "macos", "-o", path), temp());
        broken := it[].ends_with("stackie.fr") || it[].ends_with("multiplexer.fr");
        @if(!broken)  // :TodoSketchyRepro
        cross_repro(path, it[], "macos-aarch64");
        if it[] != "examples/gpu/terminal.fr" {  // TODO
            ok, out, err := exec_and_catch(franca, @slice(it[], "-arch", "wasm32", "-wgpu", "-o", path), temp());
            @if(!broken)  // :TodoSketchyRepro
            cross_repro(path, it[], "web");
            if !ok {
                return(ok, out, err, "");
            };
        };
        (ok, out, err, "")
    });
};

test_static_repro :: fn(franca_path: Str) void = {
    // If running linux with libc, can still run the compiler built without libc and make sure it repros. 
    if !(query_current_os() == .linux && is_linking_libc()) {
        println("SKIP: linux_native_no_libc(): native target is not linux+libc");
        return();
    };
    more_cache := Foreign.ENV.FRANCA_MORE_CACHE.get_environment_variable().is_some();
    if more_cache {
        println("SKIP: test_static_repro with FRANCA_MORE_CACHE?");
        return();
    };
    
    // TODO: have default_driver do -syscalls the same way as build_release so sta0==target/release/franca-linux-x-x-sta
    sta0, sta1 := ("target/sta0.out", "target/sta1.out");
    sh(@slice(franca_path, "examples/default_driver.fr", "build", "compiler/main.fr", "-unsafe", "-syscalls", "-o", sta0));
    _ := Syscall'remove(sta1.as_cstr());
    sh(@slice(sta0, "examples/default_driver.fr", "build", "compiler/main.fr", "-unsafe", "-syscalls", "-o", sta1));
    diff(sta0, sta1);
    println("OK: linux_native_no_libc");
};

build_aoc :: fn(franca: Str) void = {
    // TODO: aoc/2025 too
    files := collect_with_extension("examples/aoc/2024", ".fr").unwrap();
    run_tests_main_threaded(Str, Str, franca, files.items(), fn(_, a) = a[], fn(franca, file) = {
        ok, out, err := exec_and_catch(franca, @slice("examples/default_driver.fr", "build", @tfmt("examples/aoc/2024/%", file[]), "-o", Foreign.PATH.dev_null), temp());
        (ok, out, err, "")
    });
};

prospero :: fn(franca_path: Str) void = {
    args := @slice("examples/prospero.fr", "-width", "64", "-hush");
    ok, o, e := exec_and_catch(franca_path, args, temp());
    @assert(ok && e.items().contains("23/253:3578\nok!"), "failed prospero\n%%", o.items(), e.items());
    print(e.items());
    
    {
        args := @slice("examples/prospero.fr");
        ok, o, e := exec_and_catch(franca_path, args, temp());
        expect := "eaf99bcf6ab0ee750678cbef374e5fcbc7548d2385b4718c6d1e0e04ae0cc656";
        @assert_eq(expect, Sha256'hex(o.items()), "update https://lukegrahamlandry.ca/words/prospero#:~:text=sha256");
        // something for viewer to read in tests/gpu.fr
        write_entire_file_or_crash("target/a.ppm", o.items());
    };
};

// TODO: do this and then run the tests in bubblewrap
// TODO: threads but fetch_git_commit uses chdir
reach_all_deps :: fn() void = {
    Foreign :: import("@/tests/deps.fr");
    inline_for get_constants(Foreign) { $n |
        it :: get_constant(Foreign, n[]).unwrap();
        // get_constant(Foreign, FuncId, n[]) doesn't work because :ThisIsTheProblemIdiot
        // so this is ugly instead of being ?FuncId
        @if(@run { it := it; it._1 == FuncId }) {
            f :: { it := it; FuncId.ptr_from_raw(it._0)[] };
            _ := f();
            @print("%, ", @run n[].str());
        };
    };
    println("");
};

fn sh(a: []Str) void = {
    show :: fn() => {
        for a { a |
            @print("% ", a);
        };
        println("");
    };
    show();
    ok := if HUSH[] {
        ok, out, err := exec_and_catch(a[0], a.rest(1), temp());
        if !ok {
            print(out.items());
            print(err.items());
        };
        ok
    } else {
        run_cmd_blocking(a[0], a.slice(1, a.len))
    };
    if !ok {
        print("Failed to run: ");
        show();
        panic("sh failed");
    };
}

diff :: fn(path0: Str, path1: Str) void = {
    a := read_entire_file_or_crash(temp(), path0);
    b := read_entire_file_or_crash(temp(), path1);
    @assert(a == b, "diff % %", path0, path1);
};

maybe_deploy_srht_site :: fn() void = {
    it := get_environment_variable("BUILD_SUBMITTER") || return();
    @if(it.str() != "git.sr.ht") return(@println("SKIP: submitter is %", it));
    token := get_environment_variable("OAUTH2_TOKEN") || return(println("missing oauth"));
    commit := git_rev_parse();
    
    out := u8.list(temp());
    @fmt(out&, "<a href='https://franca.lukegrahamlandry.ca'>https://franca.lukegrahamlandry.ca</a><hr>\n");
    files := collect_directory_ordered("target/release", temp(), temp()).unwrap();
    each files { it |
        @fmt(out&, "<a href='./%'> % </a><br>\n", it.name, it.name);
    };
    @fmt(out&, "<hr><a href='https://git.sr.ht/~lukegrahamlandry/franca/commit/%'>%</a>", commit, commit);
    @fmt(out&, "\n<script>console.log(new SharedArrayBuffer());</script> <!-- this is why i can't use srht for the compiler demo -->");
    write_entire_file_or_crash("target/release/index.html", out.items());
    
    copy :: fn(dest, src) => write_entire_file_or_crash(dest, read_entire_file_or_crash(temp(), src));
    dir := @tfmt("target/release/%", commit);
    make_dirs_or_crash(dir);
    copy(@tfmt("%/repro.txt", dir), "target/release/repro.txt");  // make it less confusing if github actions wins the race
    
    Syscall'chdir("target/release");
    sh(@slice("tar", "-cvzf", "../site.tar.gz", "."));
    Syscall'chdir("../..");

    // not using sh() avoids printing the token
    ok, _out, _err := exec_and_catch(Foreign.EXE.curl, @slice(
        "--oauth2-bearer", token.str(), "-Fcontent=@target/site.tar.gz", "https://pages.sr.ht/publish/fr.lukegrahamlandry.ca",
    ), temp());
    @assert(ok, "failed publish to srht.site");
};

git_rev_parse :: fn() Str = {
    git := Foreign.EXE.git;
    ok, o, e := exec_and_catch(git, @slice("rev-parse", "HEAD"), temp());
    @assert(ok, "failed git rev-parse");
    while => o[o.len - 1].is_ascii_whitespace() {
        o.len -= 1;
    };
    @assert_eq(o.len, 40, "failed git rev-parse");
    o.items()
};

#use("@/lib/sys/subprocess.fr");
#use("@/examples/testing.fr");

IS_GITHUB :: Foreign.ENV.GITHUB_REPOSITORY.get_environment_variable().is_some();

check_for_xcode :: fn() bool = {    
    ok, _o, _e := exec_and_catch("xcode-select", @slice("-p"), temp());
    ok
};

ci_end :: fn() void = {
    i := cli_args().index_of(fn(it) => it[] == "ci-end") || 0;
    commit := cli_args().index(i + 1)[].str();
    path := "repro-macos-14.txt/repro-macos-14.txt";
    check :: fn(s) => { diff(path, s); @println("OK: %", s); };
    check("repro-macos-15-intel.txt/repro-macos-15-intel.txt");
    check("repro-ubuntu-latest.txt/repro-ubuntu-latest.txt");
    check("repro-ubuntu-24.04-arm.txt/repro-ubuntu-24.04-arm.txt");
    sh(@slice(get_executable_path(temp()), "examples/web/build.fr"));
    
    srht_path := "repro-srht.txt";
    url := @tfmt("https://fr.lukegrahamlandry.ca/%/repro.txt", commit);
    println(url);
    ok, out, err := exec_and_catch(Foreign.EXE.curl, @slice(
        url, "-o", srht_path, "-L", "-f", "-s", 
    ), temp());
    if !ok {
        @println("SKIP: builds.sr.ht LOST THE RACE\n%\n%", out.items(), err.items());
    } else {
        check(srht_path);
    };
}
