HUSH :: @static_mut false;

S :: const_slice;

bins :: @S(
    ("examples/import_c/cc.fr",     "target/cc.out"),
    ("backend/meta/qbe_frontend.fr", "target/q.out"),
    ("examples/import_wasm/run.fr",  "target/w.out"),
);

// TODO: pass in ./cc.out and ./w.out instead of assuming
