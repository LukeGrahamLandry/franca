main :: fn() void = {
    // TODO: error message quality
    // "Type Error: expected i64 but found FatExpr"
    // is a much worse error message than "missing runtime var e" 
    // (which you get if `g :: fn(a: FatExpr)`). 
    // The mistake was not unquoting like @[e]
    g :: fn(a: i64) void = ();
    f :: fn(e: FatExpr) FatExpr #macro = @{ g(e) };
    
    @f(1);
}
