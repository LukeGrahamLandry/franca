
// after chaning @static syntax: no longer gives a stupid result, 
// just a confusing error if you don't know. 
main :: fn() void = {
    S :: @struct(a := 123);
    
    // since this gets the default value...
    s: S = ();
    assert_eq(s.a, 123);
    
    // it looks like this would be the same, 
    // ss := @static @as(S) ();
    // but that doesn't compile because macro with void literal is treated as single arg 
    // and i don't do single arg @as. instead:
    ss := @static { x: S = (); x };
    assert_eq(s.a, 123);
}
