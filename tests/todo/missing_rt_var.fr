
main :: fn() = {
    // S :: @struct(_: u32);  // this works. also with @rec which should make it TypeInfo.Named just like the builtin one. 
    S :: ScopeId;   // this doesn't
    // "Compile Error: missing runtime var a"
    f :: fn(a: S, b: S) bool = a._ == b._;
    x := zeroed(S);
    f(x, x);
}
