//
// this compiles the graphical programs in one compilation unit 
// and runs them with a headless app instance. each program is sent  
// a few events and renders a few frames which are merged into one image. 
// very fragile (click at (x, y) pixel, etc.) and not comprehensive 
// (not all features tested and no output assertions beyond not crashing) 
// but it's a big improvement over ci not running them at all. 
//
// TODO: this doesn't work in browser because i can't read_buffer_borrow_blocking, 
//       but since just want to show the result anyway could keep the textures on gpu
//       and have this program include viewer.fr with the same Sg instance to show them 
//       (instead of exec-ing franca to compile it, then will also work without -jit)
// TODO: would be cool if it was easy to pass arguments to import() to recompile with 
//       redefined variables. ie. FEAT_PNG, so could make sure both ways compile. 
//       letting the more dependencies way toggle into the ugly rendering at runtime 
//       gets most of the benefit for zero work tho so not a priority rn. 
// TODO: could also do tests that directly poke at the state instead of indirectly through events. 
//       

// clunky: contain the #use(graphics) so the child programs can't depend on the top level scope importing things. 
// (import() inherits the main program's top level scope, not the caller's)
// TODO: this should work as @struct. it doesn't like the @run :compiler
local_scope :: FuncId.scope_of(fn() = {  
#use("@/graphics/lib.fr");

// [](entry file, frame count, event generator)
TestCase :: Ty(Str, i64, @FnPtr(t: *Test) void);
tests :: filter_tests @const_slice(@as(TestCase)
    ("@/examples/gpu/mandelbrot.fr", 5, fn(t) = {
        range(0, 4) { _ |
            t.frame();
            t.drag(delta = vec2(-40, 20));
        };
        t.scroll(y = -500);
        t.frame();
    }),
    ("@/examples/gpu/stackie.fr", 5, fn(t) = {
        t.frame();
        // TODO: have delta time be passed in instead of calling timestamp
        range(0, 50, fn(_) => t.app.frame());  
        t.frame();
        t.keys(text = "oooooooo");  // make an error
        t.frame();
        range(0, 10, fn(_) => t.key(press = .BACKSPACE));
        t.keys(text = "xy9o");  // the xor texture
        t.frame();
        range(0, 4, fn(_) => t.key(press = .BACKSPACE));
        t.keys(text = "z!eZvz/9+duz/9+d;:3w0:-;:t8/-8%7w+ze2*1-:z*<|xy!+");  // from c50.fingswotidun.com
        t.frame();
    }),
    ("@/examples/gpu/farm_game.fr", 1, fn(t) = t.frame()),
    ("@/examples/gpu/rtc.fr", 1, fn(t) = t.frame()),
    ("@/examples/gpu/hello_triangle.fr", 1, fn(t) = t.frame()),
    ("@/examples/gpu/epicycles.fr", 1, fn(t) = {
        t.drag(delta = vec2(10, 10));
        t.frame();
    }),
    ("@/examples/gpu/lambda.fr", 1, fn(t) = t.frame()),
    ("@/examples/chess/gui.fr", 5, fn(t) = {
        t.frame();
        t.click(at = vec2(177, 297));
        t.frame();
        t.click(at = vec2(184, 222));
        t.frame();
        t.key(press = .SPACE);  // show fen
        t.frame();
        t.key(press = .P);  // toggle ugly
        t.frame();
    }), 
    ("@/examples/gpu/viewer.fr", 3, fn(t) = {
        t.frame();
        t.paste(text = "target/a.ppm");
        t.frame();
        t.key(press = .SPACE);  // show title
        t.drag(delta = vec2(40, 40));
        t.scroll(y = 50);
        t.frame();
    }),
    ("@/examples/gpu/multiplexer.fr", 2, fn(t) = {
        t.frame();
        t.key(press = ._2, ctrl = true);
        t.key(press = .BACKSPACE);  // HACK: switching active app doesn't eat the event so still types a "2"
        t.frame();
    }),
    // TODO: terminal and app_events don't use Easy'start. 
    // TODO: geo " and also needs an input file
);

filter_tests :: fn(tests: []TestCase) []TestCase = {
    if query_current_arch() == .x86_64 && query_current_os() == .macos {
        // TODO: shader compiler for old versions of metal
        tests&.ordered_retain(fn(it) => false 
            || it._0.ends_with("mandelbrot.fr") 
            || it._0.ends_with("hello_triangle.fr")
        );
    }
    tests
}

// TODO: deal with this when copying out of the buffer instead. 
//       so then need to support asking for padding when the copying to the buffer so the image doesn't have to be a multiple of this size. 
COPY_BYTES_PER_ROW_ALIGNMENT :: 256;  // fuckin wnebsnites :(
@run @assert_eq(W.mod(COPY_BYTES_PER_ROW_ALIGNMENT), 0, "COPY_BYTES_PER_ROW_ALIGNMENT :(");
W :: 512;
H :: W;
N_DEMO :: { x := 0; for tests { _, n, __ | x += n; }; x.align_to(N_FRAME) / N_FRAME };
N_FRAME :: 5;

main :: fn() void = {
    sg := @ref zeroed(Sg.Self);
    setup(sg, (
        environment = Easy'headless_environment(),
        allocator = general_allocator(),
    ));
    
    scratch: Sg.Buffer = sg.make(
        usage = .MAP_READ,
        size = W * H * 4,
    );
    // TODO: allow making pixel format not match default. need to change it in pipelinedesc.colors.pixel_format. 
    //       actually i guess just pass it into headless_environment instead. 
    //       it's just the blessed one that's pretending to be the screen that has this restriction 
    image: Sg.Image = sg.make(
        width = W,
        height = H,
        pixel_format = .BGRA8,
        render_target = true,
        copy_source = true,
    );
    // TODO: in website ask for features: Depth32FloatStencil8
    dimage: Sg.Image = @if(SOKOL_BACKEND == .WGPU, (id = 0), sg.make(
        width = W,
        height = H,
        pixel_format = .DEPTH_STENCIL,
        render_target = true,
    ));
    at: Sg.Attachments = sg.make(
        colors = ((
            image = image,
        ), ..),
        depth_stencil = (image = dimage),
    );
    
    all_w, all_h := (W*N_FRAME, H*N_DEMO);
    prefix := @tfmt("P6 % % 255\n", all_w, all_h);
    out := temp().alloc_zeroed(u8, all_w*all_h*3 + prefix.len);
    out.slice(0, prefix.len).copy_from(prefix);
    
    demo_i := 0;
    out_index := 0;
    inline_for tests { $it |
        mark := temp().mark();
        app := init_headless_app(it._0, sg, at, W, H);
        t := @ref @as(Test) (
            app = app, sg = sg, scratch = scratch, image = image,
            out = out.rest(prefix.len),
            out_index = out_index, limit = it._1,
        );
        
        (it._2)(t);
        @debug_assert(sg.valid, "don't deinit the Sg instance");
        out_index = t.out_index;
        // TODO: release gpu resources (and remove commit listeners)
        //temp().reset(mark);
    };
    #use("@/lib/sys/fs.fr");
    println(Sha256'hex(out));
    write_entire_file_or_crash(dest, out);
    
    dest :: "target/a.ppm";
    if cli_args().contains(fn(it) => it[] == "-show") {
        #use("@/lib/sys/subprocess.fr");
        @assert(cli_args().contains(fn(it) => it[] == "-jit"), "// TODO: only works if not aot");
        franca := get_executable_path(temp());
        a := make_args_for_exec(franca, @slice("examples/gpu/viewer.fr", "-jit", dest), temp());
        become(a[0], a);
    } else {
        @println("wrote frames to %\n(pass '-show' cli arg to open the viewer)", dest);
    };
}

// :paste from multiplexer example. TODO: factor out stuff that lets you run a headless app?
init_headless_app :: fn($path: Str, sg: *Sg.Self, at: Sg.Attachments, W: i64, H: i64) *Sapp.Self = {
    a := temp();
    app := a.box_zeroed(Sapp.Self);
    app.first_frame = true; 
    app.events = list(a);  // annoying to reset after temp()
    user := a.box_zeroed(UserData);
    instance := a.boxed(Instance, (sg = sg, app = app, user = user));
    UserData :: import(path).State;
    app.desc.init_cb = fn(it) = {
        it := Instance.ptr_from_raw(it);
        it.user.on_init(it.app, it.sg);
    };
    app.desc.frame_cb = fn(it) = {
        it := Instance.ptr_from_raw(it);
        it.user.on_render(it.app, it.sg);
        it.app.clear_requests();  // nowhere for these to go
    };
    app.desc.event_cb = fn(it, e) = {
        it := Instance.ptr_from_raw(it);
        it.user.on_event(it.app, e);
    };
    Instance :: @struct(sg: *Sg.Self, app: *Sapp.Self, user: *UserData);
    app.desc.user_data = Instance.raw_from_ptr(instance);
    app.first_frame = true;
    app.valid = true;
    app.force_render_target = at.id;
    app.window_width = W;
    app.window_height = H;
    app.framebuffer_width = W;
    app.framebuffer_height = H;
    app.dpi_scale = 1;
    app.webgpu.headless = true;
    app
} 

perform_copy :: fn(sg: *Sg.Self, dest: Sg.Buffer, src: Sg.Image) void = {
    // hack: create an encoder outside a frame
    pass := zeroed Sg.Pass;
    pass.compute = true;
    sg.begin_pass(pass&);
    sg.end_pass();
    
    sg.copy(dest, src);
    sg.commit(true);
}

Test :: @struct {
    app: *Sapp.Self;
    sg: *Sg.Self;
    scratch: Sg.Buffer;
    image: Sg.Image;
    out_index: i64;
    out: []u8;
    limit: i64;
};

fn frame(t: *Test) void = {
    @assert(t.limit > 0, "called frame() more times than declared in test data");
    t.limit -= 1;
    t.app.frame();
    t.sg.perform_copy(t.scratch, t.image);
    result := t.sg.read_buffer_borrow_blocking(t.scratch);
    y, x := t.out_index.div_mod(N_FRAME);
    copy_bgra8_ppm(t.out, result, W, H, W*N_FRAME, x*W, y*H);
    t.out_index += 1;
}

// TODO: this event sending stuff is very clunky. 
//       should unify the way modifers are handled and be symetric for key and mouse button. 

fn click(t: *Test, a: @struct(at: Vec2, button := Sapp.Mousebutton.LEFT)) void = {
    t := t.app;
    t.mouse.x = a.at.x;  
    t.mouse.y = a.at.y;
    e := t.init_event(.MOUSE_DOWN);
    e.mouse_button = a.button;
    t.call_event(e);
    e := t.init_event(.MOUSE_UP);
    e.mouse_button = a.button;
    t.call_event(e);
}

fn drag(t: *Test, a: @struct(delta: Vec2, button := Sapp.Mousebutton.LEFT)) void = {
    t := t.app;
    e := t.init_event(.MOUSE_DOWN);
    e.mouse_button = a.button;
    t.call_event(e);
    e.mouse_button = a.button;
    t.mouse.dx = a.delta.x; 
    t.mouse.dy = a.delta.y;
    t.mouse.x += e.mouse_dx;  
    t.mouse.y += e.mouse_dy;
    e := t.init_event(.MOUSE_MOVE);
    @if(a.button == .LEFT) e.modifiers&.set(.left_mouse, 1);
    @if(a.button == .RIGHT) e.modifiers&.set(.right_mouse, 1);
    t.call_event(e);
    t.mouse.dx = 0; 
    t.mouse.dy = 0;
    e := t.init_event(.MOUSE_UP);
    e.mouse_button = a.button;
    t.call_event(e);
}

fn scroll(t: *Test, a: @struct(x: f32 = 0, y: f32 = 0)) void = {
    t := t.app;
    e := t.init_event(.MOUSE_SCROLL);
    e.scroll_x = a.x;
    e.scroll_y = a.y;
    t.call_event(e);
}

fn keys(t: *Test, a: @struct(text: Str)) void = {
    for a.text { c |
        t.key(press = @as(Sapp.Keycode) @as(u16) c.zext());
    };
}

fn key(t: *Test, a: @struct(press: Sapp.Keycode, ctrl := false)) void = {
    code := a.press;
    t := t.app;
    e := t.init_event(.KEY_DOWN);
    @if(a.ctrl) e.modifiers&.set(.control, 1);
    e.key_code = code;
    t.call_event(e);
    c := @as(u16) code;
    if c >= 32 && c < 127 {
        e := t.init_event(.CHAR);
        @if(a.ctrl) e.modifiers&.set(.control, 1);
        e.char_code = c.zext();
        t.call_event(e);
    };
    e := t.init_event(.KEY_UP);
    @if(a.ctrl) e.modifiers&.set(.control, 1);
    e.key_code = code;
    t.call_event(e);
}

fn paste(t: *Test, a: @struct(text: Str)) void = {
    t := t.app;
    e := t.init_event(.CLIPBOARD_PASTED);
    e.pasted = a.text;
    t.call_event(e);
}

copy_bgra8_ppm :: fn(p: []u8, in: []u8, W: i64, H: i64, stride: i64, X: i64, Y: i64) void = {
    i := 0;
    range(Y, Y+H) { y |
        range(X, X+W) { x |
            operator_index :: index_unchecked;
            j := (y*stride + x) * 3;
            p[j+0] = in[i+2];
            p[j+1] = in[i+1];
            p[j+2] = in[i+0];
            i += 4;
        };
    };
}

driver :: fn(vtable: *ImportVTable) void = 
    Easy'build_for_graphics(vtable, @source_file_name());
});

main :: local_scope.main;
driver :: local_scope.driver;
