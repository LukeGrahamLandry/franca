fn giant_const_slice() #test = {
    n :: 200_000;
    s :: import({
        code := u8.list(n*5, ast_alloc());
        code&.push_all("{ get_a_number :: fn(i: i64) f64 = {\nfloats := @const_slice(");
        range(0, n) {i|
            @fmt(code&, "%.0, ", i);
        };
        @fmt(code&, ");\n floats[i] }; };");
        code.items()
    });
    i := s'get_a_number(n - 1);
    @assert_eq(i, n.float() - 1);
}

fn giant_expression_fold() #test = {
    n :: 750;  // TODO: make compile_expr iterative so can go higher without running out of stack
    assert_eq(add_literals_to(n)(), n);
    add_literals_to :: fn(total: i64) (@Fn() i64) #fold = {
        src := u8.list(total * 4, ast_alloc());
        @fmt(src&, "{ f :: fn() i64 = 0 ");
        range(0, total) { _ |
            @fmt(src&, "+ %", 1);
        };
        @fmt(src&, "; };");
        s := import(src.items());
        (@Fn() i64).const_eval(@{ @[@literal s].f })
    };
}
