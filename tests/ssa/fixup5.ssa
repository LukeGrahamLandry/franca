export function w $main() {
@start
    call $local()
    
    %f =l sub $strlen, 1
    %a =l sub $empty, 1
    %r =l call $inc_call(l %f, l $empty)
    ret %r
}

data $empty = { b 0 }
function l $inc_call(l %f, l %a) {
@start
    %g =l add %f, 1
    %b =l add %a, 1
    %r =l call %g(l %b)
    ret %r
}

export function $hack_declare_signeture_for_wasm_import() {
@start
    %_ =l call $strlen(l 0)
    ret
}

# bug from qbe mailing list
# https://gist.github.com/kengorab/da319f45f7f871d0601395f76af76761

data $arr = { z 64 }
data $arridx = { l 8 }
data $fmt = { b "%d\n", b 0 }

function $local() {
@start
  %_1 =l loadl $arridx
  %_2 =l sub %_1, 8

  %_3 =l add %_2, $arr
  storel 1234, %_3

  %_4 =l loadl %_3
  %_ =w call $printf(l $fmt, ..., l %_4)
  ret
}

