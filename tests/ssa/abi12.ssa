# c [/n1570#J.2]: it's ub when "A structure or union is defined without any named members."
# but clang and gcc both allow them and agree on the abi 
# and the abis specs say what you're supposed to do. 
# happily everyone agrees on the sane thing. 
# - wasm: empty struct or union: Parameter:ignored Result:ignored
# - arm: "Any language-level members that have zero size must therefore disappear in the language-to-ABI mapping"

type :Empty = { }
type :Long = { :Empty, l }

export function w $main() {
@start
    %a =l alloc8 0
    %b =l alloc8 8
    storel 3, %b
    %b =:Empty call $f(:Empty %a, l 1, :Empty %a, :Long %b)
    ret 0
}

export function :Empty $g(l %b, :Empty %a, :Long %d, :Empty %c) {
@start
    %e =l alloc8 0
    %d =l load %d
    %x =l ceql %b, 11
    %y =l ceql %d, 33
    %z =l and %x, %y
    jnz %z, @t, @f
@t
    ret %e
@f
    hlt
}

