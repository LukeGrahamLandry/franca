# this is interesting because some arguments are passed on the stack but it doesn't need its own stack frame. 
export
function l $add10q(l %x1, l %x2, l %x3, l %x4, l %x5, l %x6, l %x7, l %x8, l %x9, l %x10) {
@start
    %x =l add 0, %x1
    %x =l add %x, %x2
    %x =l add %x, %x3
    %x =l add %x, %x4
    %x =l add %x, %x5
    %x =l add %x, %x6
    %x =l add %x, %x7
    %x =l add %x, %x8
    %x =l add %x, %x9
    %x =l add %x, %x10
    ret %x
}

export
function l $call_add10c() {
@start
    %x =l call $add10c(l 1, l 2, l 3, l 4, l 5, l 6, l 7, l 8, l 9, l 10)
    ret %x
}

# "Function arguments may consume slots on the stack that are not multiples of 8 bytes. 
# If the total number of bytes for stack-based arguments is not a multiple of 8 bytes, 
# insert padding on the stack to maintain the 8-byte alignment requirements."
# -- writing-arm64-code-for-apple-platforms
export
function ub $small_add10q(ub %x1, ub %x2, ub %x3, ub %x4, ub %x5, ub %x6, ub %x7, ub %x8, ub %x9, ub %x10) {
@start
    %x =w add 0, %x1
    %x =w add %x, %x2
    %x =w add %x, %x3
    %x =w add %x, %x4
    %x =w add %x, %x5
    %x =w add %x, %x6
    %x =w add %x, %x7
    %x =w add %x, %x8
    %x =w add %x, %x9
    %x =w add %x, %x10
    ret %x
}

export
function ub $small_call_add10c() {
@start
    %x =w call $small_add10c(ub 1, ub 2, ub 3, ub 4, ub 5, ub 6, ub 7, ub 8, ub 9, ub 10)
    ret %x
}

