
type :T3 = { b 12 }
data $s = { l 0 0 }

export function w $main() {
@start
    call $coalesced_blits()
    
    %xx =:T3 call $const_array()
    %a =l add %xx, 8
    %b =l loadub %a
    %c =l cnel %b, 0
    retw %c
}

function :T3 $const_array() {
@start
    %s0 =l alloc8 16
    %s8 =l add %s0, 8
    storel 255, %s8
    blit0 $s, %s0
    blit1 I12
    ret %s0
}

function $coalesced_blits() {
@start
    %A =l alloc8 12
    %B =l alloc8 24
    %C =l alloc8 24
    %b8 =l add %B, 8
    storel 1, %b8
    blit %B, %A, 12
    storel 0, %b8     # should do nothing because saved in %A and blit it back
    blit %A, %B, 12
    blit %B, %C, 24
    call $check8(l %C)
    ret
}

function $check8(l %a) {
@start
    %b =l add %a, 8
    %c =w loadw %b
    %d =w ceqw %c, 0
    jnz %d, @die, @ok
 @die
    call $exit(w 1)
 @ok
    ret
}
